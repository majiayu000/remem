{"type":"item.completed","item":{"id":"item_33","type":"command_execution","command":"/bin/zsh -lc 'git diff -- memory_demo/visibility.py tests/test_visible.py'","aggregated_output":"diff --git a/memory_demo/visibility.py b/memory_demo/visibility.py\nindex f3e4484..1227ea4 100644\n--- a/memory_demo/visibility.py\n+++ b/memory_demo/visibility.py\n@@ -1,2 +1,14 @@\n+EXCLUDED_CONTEXT_STATUSES = {\n+    \"archived\",\n+    \"deleted\",\n+    \"hidden\",\n+    \"suppressed\",\n+}\n+\n+\n def visible_context_sections(sections):\n-    return [section for section in sections if section.get(\"status\") != \"suppressed\"]\n+    return [\n+        section\n+        for section in sections\n+        if str(section.get(\"status\", \"\")).lower() not in EXCLUDED_CONTEXT_STATUSES\n+    ]\ndiff --git a/tests/test_visible.py b/tests/test_visible.py\nindex 682586e..cc31ee2 100644\n--- a/tests/test_visible.py\n+++ b/tests/test_visible.py\n@@ -2,6 +2,7 @@ import unittest\n \n from memory_demo.slug import normalize_slug\n from memory_demo.retention import retention_days\n+from memory_demo.visibility import visible_context_sections\n \n \n class VisibleTests(unittest.TestCase):\n@@ -11,6 +12,35 @@ class VisibleTests(unittest.TestCase):\n     def test_default_retention(self):\n         self.assertEqual(retention_days(\"unknown\"), 30)\n \n+    def test_context_visibility_excludes_non_visible_statuses(self):\n+        sections = [\n+            {\"id\": \"active\", \"status\": \"active\"},\n+            {\"id\": \"missing\"},\n+            {\"id\": \"suppressed\", \"status\": \"suppressed\"},\n+            {\"id\": \"archived\", \"status\": \"archived\"},\n+            {\"id\": \"deleted\", \"status\": \"deleted\"},\n+            {\"id\": \"hidden\", \"status\": \"hidden\"},\n+        ]\n+\n+        self.assertEqual(\n+            visible_context_sections(sections),\n+            [\n+                {\"id\": \"active\", \"status\": \"active\"},\n+                {\"id\": \"missing\"},\n+            ],\n+        )\n+\n+    def test_context_visibility_status_matching_is_case_insensitive(self):\n+        sections = [\n+            {\"id\": \"visible\", \"status\": \"active\"},\n+            {\"id\": \"archived\", \"status\": \"Archived\"},\n+        ]\n+\n+        self.assertEqual(\n+            visible_context_sections(sections),\n+            [{\"id\": \"visible\", \"status\": \"active\"}],\n+        )\n+\n \n if __name__ == \"__main__\":\n     unittest.main()\n","exit_code":0,"status":"completed"}}
