{"type":"item.completed","item":{"id":"item_22","type":"command_execution","command":"/bin/zsh -lc 'git diff -- memory_demo/tickets.py tests/test_visible.py'","aggregated_output":"diff --git a/memory_demo/tickets.py b/memory_demo/tickets.py\nindex c0ddf5e..c43041c 100644\n--- a/memory_demo/tickets.py\n+++ b/memory_demo/tickets.py\n@@ -1,3 +1,20 @@\n+import re\n+\n+\n+_DIGITS_ONLY_RE = re.compile(r\"^#?\\s*(\\d+)\\s*$\")\n+_TICKET_KEY_RE = re.compile(r\"^#?\\s*([A-Za-z]+)[ _-]*(\\d+)\\s*$\")\n+\n+\n def normalize_ticket_key(value):\n-    cleaned = str(value).strip().replace(\"_\", \"-\").replace(\" \", \"-\")\n-    return cleaned.upper()\n+    raw = str(value)\n+\n+    digits_only = _DIGITS_ONLY_RE.fullmatch(raw)\n+    if digits_only:\n+        return f\"MEM-{digits_only.group(1)}\"\n+\n+    ticket_key = _TICKET_KEY_RE.fullmatch(raw)\n+    if ticket_key:\n+        prefix, digits = ticket_key.groups()\n+        return f\"{prefix.upper()}-{digits}\"\n+\n+    raise ValueError(f\"invalid ticket key: {value!r}\")\ndiff --git a/tests/test_visible.py b/tests/test_visible.py\nindex 682586e..a38044c 100644\n--- a/tests/test_visible.py\n+++ b/tests/test_visible.py\n@@ -2,6 +2,7 @@ import unittest\n \n from memory_demo.slug import normalize_slug\n from memory_demo.retention import retention_days\n+from memory_demo.tickets import normalize_ticket_key\n \n \n class VisibleTests(unittest.TestCase):\n@@ -11,6 +12,20 @@ class VisibleTests(unittest.TestCase):\n     def test_default_retention(self):\n         self.assertEqual(retention_days(\"unknown\"), 30)\n \n+    def test_ticket_key_memory_convention(self):\n+        cases = {\n+            \"abc 123\": \"ABC-123\",\n+            \"abc_123\": \"ABC-123\",\n+            \"abc-123\": \"ABC-123\",\n+            \"#abc 123\": \"ABC-123\",\n+            \"123\": \"MEM-123\",\n+            \"#123\": \"MEM-123\",\n+        }\n+\n+        for value, expected in cases.items():\n+            with self.subTest(value=value):\n+                self.assertEqual(normalize_ticket_key(value), expected)\n+\n \n if __name__ == \"__main__\":\n     unittest.main()\n","exit_code":0,"status":"completed"}}
