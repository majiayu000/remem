diff --git a/memory_demo/tickets.py b/memory_demo/tickets.py
index c0ddf5e..c43041c 100644
--- a/memory_demo/tickets.py
+++ b/memory_demo/tickets.py
@@ -1,3 +1,20 @@
+import re
+
+
+_DIGITS_ONLY_RE = re.compile(r"^#?\s*(\d+)\s*$")
+_TICKET_KEY_RE = re.compile(r"^#?\s*([A-Za-z]+)[ _-]*(\d+)\s*$")
+
+
 def normalize_ticket_key(value):
-    cleaned = str(value).strip().replace("_", "-").replace(" ", "-")
-    return cleaned.upper()
+    raw = str(value)
+
+    digits_only = _DIGITS_ONLY_RE.fullmatch(raw)
+    if digits_only:
+        return f"MEM-{digits_only.group(1)}"
+
+    ticket_key = _TICKET_KEY_RE.fullmatch(raw)
+    if ticket_key:
+        prefix, digits = ticket_key.groups()
+        return f"{prefix.upper()}-{digits}"
+
+    raise ValueError(f"invalid ticket key: {value!r}")
