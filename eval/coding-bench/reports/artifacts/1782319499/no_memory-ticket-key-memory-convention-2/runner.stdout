{"type":"item.completed","item":{"id":"item_34","type":"command_execution","command":"/bin/zsh -lc 'git diff -- memory_demo/tickets.py tests/test_visible.py'","aggregated_output":"diff --git a/memory_demo/tickets.py b/memory_demo/tickets.py\nindex c0ddf5e..a48689f 100644\n--- a/memory_demo/tickets.py\n+++ b/memory_demo/tickets.py\n@@ -1,3 +1,18 @@\n+import re\n+\n+\n def normalize_ticket_key(value):\n-    cleaned = str(value).strip().replace(\"_\", \"-\").replace(\" \", \"-\")\n-    return cleaned.upper()\n+    if value is None:\n+        return \"\"\n+\n+    cleaned = re.sub(r\"[^A-Za-z0-9]+\", \"-\", str(value).strip()).strip(\"-\")\n+    if not cleaned:\n+        return \"\"\n+\n+    normalized = cleaned.upper()\n+    match = re.fullmatch(r\"([A-Z][A-Z0-9]*)-(\\d+)\", normalized)\n+    if match:\n+        project, number = match.groups()\n+        normalized = f\"{project}-{int(number)}\"\n+\n+    return normalized\ndiff --git a/tests/test_visible.py b/tests/test_visible.py\nindex 682586e..4bfcf95 100644\n--- a/tests/test_visible.py\n+++ b/tests/test_visible.py\n@@ -2,6 +2,7 @@ import unittest\n \n from memory_demo.slug import normalize_slug\n from memory_demo.retention import retention_days\n+from memory_demo.tickets import normalize_ticket_key\n \n \n class VisibleTests(unittest.TestCase):\n@@ -11,6 +12,11 @@ class VisibleTests(unittest.TestCase):\n     def test_default_retention(self):\n         self.assertEqual(retention_days(\"unknown\"), 30)\n \n+    def test_ticket_key_normalization(self):\n+        self.assertEqual(normalize_ticket_key(\" abc_00123 \"), \"ABC-123\")\n+        self.assertEqual(normalize_ticket_key(\"abc / 123\"), \"ABC-123\")\n+        self.assertEqual(normalize_ticket_key(None), \"\")\n+\n \n if __name__ == \"__main__\":\n     unittest.main()\n","exit_code":0,"status":"completed"}}
