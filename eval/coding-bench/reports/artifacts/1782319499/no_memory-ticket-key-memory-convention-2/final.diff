diff --git a/memory_demo/tickets.py b/memory_demo/tickets.py
index c0ddf5e..a48689f 100644
--- a/memory_demo/tickets.py
+++ b/memory_demo/tickets.py
@@ -1,3 +1,18 @@
+import re
+
+
 def normalize_ticket_key(value):
-    cleaned = str(value).strip().replace("_", "-").replace(" ", "-")
-    return cleaned.upper()
+    if value is None:
+        return ""
+
+    cleaned = re.sub(r"[^A-Za-z0-9]+", "-", str(value).strip()).strip("-")
+    if not cleaned:
+        return ""
+
+    normalized = cleaned.upper()
+    match = re.fullmatch(r"([A-Z][A-Z0-9]*)-(\d+)", normalized)
+    if match:
+        project, number = match.groups()
+        normalized = f"{project}-{int(number)}"
+
+    return normalized
