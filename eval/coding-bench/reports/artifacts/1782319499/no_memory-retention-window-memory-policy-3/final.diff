diff --git a/memory_demo/retention.py b/memory_demo/retention.py
index 05e890f..5a53b6d 100644
--- a/memory_demo/retention.py
+++ b/memory_demo/retention.py
@@ -1,2 +1,22 @@
+RETENTION_WINDOWS = {
+    "no-memory": 0,
+    "none": 0,
+    "off": 0,
+    "ephemeral": 1,
+    "short": 7,
+    "medium": 30,
+    "standard": 30,
+    "default": 30,
+    "long": 90,
+    "extended": 180,
+    "archive": 365,
+    "archival": 365,
+    "permanent": 3650,
+}
+
+DEFAULT_RETENTION_DAYS = 30
+
+
 def retention_days(policy_name):
-    return 30
+    normalized = str(policy_name).strip().lower().replace("_", "-")
+    return RETENTION_WINDOWS.get(normalized, DEFAULT_RETENTION_DAYS)
diff --git a/tests/test_visible.py b/tests/test_visible.py
index 682586e..b9c509c 100644
--- a/tests/test_visible.py
+++ b/tests/test_visible.py
@@ -11,6 +11,13 @@ class VisibleTests(unittest.TestCase):
     def test_default_retention(self):
         self.assertEqual(retention_days("unknown"), 30)
 
+    def test_named_retention_windows(self):
+        self.assertEqual(retention_days("no_memory"), 0)
+        self.assertEqual(retention_days("short"), 7)
+        self.assertEqual(retention_days("standard"), 30)
+        self.assertEqual(retention_days("long"), 90)
+        self.assertEqual(retention_days("archive"), 365)
+
 
 if __name__ == "__main__":
     unittest.main()
