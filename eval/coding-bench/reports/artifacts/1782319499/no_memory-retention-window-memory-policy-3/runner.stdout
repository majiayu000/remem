{"type":"item.completed","item":{"id":"item_35","type":"command_execution","command":"/bin/zsh -lc 'git diff -- memory_demo/retention.py tests/test_visible.py'","aggregated_output":"diff --git a/memory_demo/retention.py b/memory_demo/retention.py\nindex 05e890f..5a53b6d 100644\n--- a/memory_demo/retention.py\n+++ b/memory_demo/retention.py\n@@ -1,2 +1,22 @@\n+RETENTION_WINDOWS = {\n+    \"no-memory\": 0,\n+    \"none\": 0,\n+    \"off\": 0,\n+    \"ephemeral\": 1,\n+    \"short\": 7,\n+    \"medium\": 30,\n+    \"standard\": 30,\n+    \"default\": 30,\n+    \"long\": 90,\n+    \"extended\": 180,\n+    \"archive\": 365,\n+    \"archival\": 365,\n+    \"permanent\": 3650,\n+}\n+\n+DEFAULT_RETENTION_DAYS = 30\n+\n+\n def retention_days(policy_name):\n-    return 30\n+    normalized = str(policy_name).strip().lower().replace(\"_\", \"-\")\n+    return RETENTION_WINDOWS.get(normalized, DEFAULT_RETENTION_DAYS)\ndiff --git a/tests/test_visible.py b/tests/test_visible.py\nindex 682586e..b9c509c 100644\n--- a/tests/test_visible.py\n+++ b/tests/test_visible.py\n@@ -11,6 +11,13 @@ class VisibleTests(unittest.TestCase):\n     def test_default_retention(self):\n         self.assertEqual(retention_days(\"unknown\"), 30)\n \n+    def test_named_retention_windows(self):\n+        self.assertEqual(retention_days(\"no_memory\"), 0)\n+        self.assertEqual(retention_days(\"short\"), 7)\n+        self.assertEqual(retention_days(\"standard\"), 30)\n+        self.assertEqual(retention_days(\"long\"), 90)\n+        self.assertEqual(retention_days(\"archive\"), 365)\n+\n \n if __name__ == \"__main__\":\n     unittest.main()\n","exit_code":0,"status":"completed"}}
