diff --git a/memory_demo/tickets.py b/memory_demo/tickets.py
index c0ddf5e..ee6c6e4 100644
--- a/memory_demo/tickets.py
+++ b/memory_demo/tickets.py
@@ -1,3 +1,21 @@
+import re
+
+
+_PREFIXED_TICKET_RE = re.compile(r"^([A-Za-z]+)[\s_-]*(\d+)$")
+_DIGITS_ONLY_RE = re.compile(r"^\d+$")
+
+
 def normalize_ticket_key(value):
-    cleaned = str(value).strip().replace("_", "-").replace(" ", "-")
-    return cleaned.upper()
+    cleaned = str(value).strip()
+    if cleaned.startswith("#"):
+        cleaned = cleaned[1:].strip()
+
+    if _DIGITS_ONLY_RE.fullmatch(cleaned):
+        return f"MEM-{cleaned}"
+
+    match = _PREFIXED_TICKET_RE.fullmatch(cleaned)
+    if not match:
+        raise ValueError(f"invalid ticket key: {value!r}")
+
+    prefix, digits = match.groups()
+    return f"{prefix.upper()}-{digits}"
