{"type":"item.completed","item":{"id":"item_18","type":"command_execution","command":"/bin/zsh -lc 'git diff -- memory_demo/tickets.py tests/test_visible.py'","aggregated_output":"diff --git a/memory_demo/tickets.py b/memory_demo/tickets.py\nindex c0ddf5e..ee6c6e4 100644\n--- a/memory_demo/tickets.py\n+++ b/memory_demo/tickets.py\n@@ -1,3 +1,21 @@\n+import re\n+\n+\n+_PREFIXED_TICKET_RE = re.compile(r\"^([A-Za-z]+)[\\s_-]*(\\d+)$\")\n+_DIGITS_ONLY_RE = re.compile(r\"^\\d+$\")\n+\n+\n def normalize_ticket_key(value):\n-    cleaned = str(value).strip().replace(\"_\", \"-\").replace(\" \", \"-\")\n-    return cleaned.upper()\n+    cleaned = str(value).strip()\n+    if cleaned.startswith(\"#\"):\n+        cleaned = cleaned[1:].strip()\n+\n+    if _DIGITS_ONLY_RE.fullmatch(cleaned):\n+        return f\"MEM-{cleaned}\"\n+\n+    match = _PREFIXED_TICKET_RE.fullmatch(cleaned)\n+    if not match:\n+        raise ValueError(f\"invalid ticket key: {value!r}\")\n+\n+    prefix, digits = match.groups()\n+    return f\"{prefix.upper()}-{digits}\"\ndiff --git a/tests/test_visible.py b/tests/test_visible.py\nindex 682586e..f7a0f52 100644\n--- a/tests/test_visible.py\n+++ b/tests/test_visible.py\n@@ -2,6 +2,7 @@ import unittest\n \n from memory_demo.slug import normalize_slug\n from memory_demo.retention import retention_days\n+from memory_demo.tickets import normalize_ticket_key\n \n \n class VisibleTests(unittest.TestCase):\n@@ -11,6 +12,11 @@ class VisibleTests(unittest.TestCase):\n     def test_default_retention(self):\n         self.assertEqual(retention_days(\"unknown\"), 30)\n \n+    def test_ticket_key_memory_convention(self):\n+        self.assertEqual(normalize_ticket_key(\"abc 123\"), \"ABC-123\")\n+        self.assertEqual(normalize_ticket_key(\"#abc_001\"), \"ABC-001\")\n+        self.assertEqual(normalize_ticket_key(\"123\"), \"MEM-123\")\n+\n \n if __name__ == \"__main__\":\n     unittest.main()\n","exit_code":0,"status":"completed"}}
