{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/bin/zsh -lc 'git diff -- memory_demo/visibility.py tests/test_visible.py'","aggregated_output":"diff --git a/memory_demo/visibility.py b/memory_demo/visibility.py\nindex f3e4484..eb54813 100644\n--- a/memory_demo/visibility.py\n+++ b/memory_demo/visibility.py\n@@ -1,2 +1,9 @@\n+HIDDEN_STATUSES = {\"suppressed\", \"terminal\"}\n+\n+\n def visible_context_sections(sections):\n-    return [section for section in sections if section.get(\"status\") != \"suppressed\"]\n+    return [\n+        section\n+        for section in sections\n+        if section.get(\"status\") not in HIDDEN_STATUSES\n+    ]\ndiff --git a/tests/test_visible.py b/tests/test_visible.py\nindex 682586e..c878161 100644\n--- a/tests/test_visible.py\n+++ b/tests/test_visible.py\n@@ -2,6 +2,7 @@ import unittest\n \n from memory_demo.slug import normalize_slug\n from memory_demo.retention import retention_days\n+from memory_demo.visibility import visible_context_sections\n \n \n class VisibleTests(unittest.TestCase):\n@@ -11,6 +12,18 @@ class VisibleTests(unittest.TestCase):\n     def test_default_retention(self):\n         self.assertEqual(retention_days(\"unknown\"), 30)\n \n+    def test_visible_context_sections_excludes_hidden_statuses(self):\n+        sections = [\n+            {\"id\": \"a\", \"status\": \"active\"},\n+            {\"id\": \"b\", \"status\": \"suppressed\"},\n+            {\"id\": \"c\", \"status\": \"stale\"},\n+            {\"id\": \"d\", \"status\": \"terminal\"},\n+        ]\n+\n+        visible = visible_context_sections(sections)\n+\n+        self.assertEqual([section[\"id\"] for section in visible], [\"a\", \"c\"])\n+\n \n if __name__ == \"__main__\":\n     unittest.main()\n","exit_code":0,"status":"completed"}}
