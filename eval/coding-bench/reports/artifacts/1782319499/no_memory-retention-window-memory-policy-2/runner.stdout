{"type":"item.completed","item":{"id":"item_18","type":"command_execution","command":"/bin/zsh -lc \"for f in memory_demo/*.py; do sed -n '1,220p' \\\"\"'$f\"; done'","aggregated_output":"def retention_days(policy_name):\n    return 30\ndef render_session_footer(title, budget_label):\n    return f\"{title}\\n\\u2514\\u2500 Budget: {budget_label}\"\nimport re\n\n\ndef normalize_slug(value):\n    slug = re.sub(r\"[^a-z0-9]+\", \"-\", str(value).lower()).strip(\"-\")\n    return slug[:32]\ndef normalize_ticket_key(value):\n    cleaned = str(value).strip().replace(\"_\", \"-\").replace(\" \", \"-\")\n    return cleaned.upper()\ndef visible_context_sections(sections):\n    return [section for section in sections if section.get(\"status\") != \"suppressed\"]\n","exit_code":0,"status":"completed"}}
