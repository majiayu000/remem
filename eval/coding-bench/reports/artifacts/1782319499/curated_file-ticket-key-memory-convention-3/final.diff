diff --git a/memory_demo/tickets.py b/memory_demo/tickets.py
index c0ddf5e..672c991 100644
--- a/memory_demo/tickets.py
+++ b/memory_demo/tickets.py
@@ -1,3 +1,15 @@
+import re
+
+
+_TICKET_KEY_RE = re.compile(
+    r"^#?\s*(?:(?P<prefix>[A-Za-z]+)[\s_-]*)?(?P<number>\d+)\s*$"
+)
+
+
 def normalize_ticket_key(value):
-    cleaned = str(value).strip().replace("_", "-").replace(" ", "-")
-    return cleaned.upper()
+    match = _TICKET_KEY_RE.match(str(value).strip())
+    if not match:
+        raise ValueError("ticket key must be an optional letter prefix followed by digits")
+
+    prefix = match.group("prefix") or "MEM"
+    return f"{prefix.upper()}-{match.group('number')}"
