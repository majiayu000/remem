datetime.fromisoformat(value.replace(\\\"Z\\\", \\\"+00:00\\\"))\\n    except ValueError:\\n        return False\\n    return True\\n\\n\\ndef sha256_file(path: Path) -> str:\\n    digest = hashlib.sha256()\\n    with path.open(\\\"rb\\\") as handle:\\n        for chunk in iter(lambda: handle.read(1024 * 1024), b\\\"\\\"):\\n            digest.update(chunk)\\n    return digest.hexdigest()\\n\\n\\ndef add_error(errors: list[LintError], fixture_dir: Path, message: str) -> None:\\n    errors.append(LintError(fixture=fixture_dir, message=message))\\n\\n\\ndef add_warning(warnings: list[str], fixture_dir: Path, message: str) -> None:\\n    warnings.append(f\\\"{fixture_dir}: {message}\\\")\\n\\n\\ndef path_is_relative_and_safe(base_dir: Path, raw_path: Any) -> bool:\\n    if not isinstance(raw_path, str) or raw_path.strip() == \\\"\\\":\\n        return False\\n    candidate = Path(raw_path)\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/Users/lifcc/Desktop/code/AI/research/harness-framework-improvement-runner/logs/iteration_058.log:47:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_23\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc \\\"sed -n '760,1095p' /Users/lifcc/Desktop/code/AI/research/harness-eval-runner/workspace/reports/eval-fixtures/tests/test_lint_fixture_package.py\\\"\",\"aggregated_output\":\"        payload = json.loads(result.stdout)\\n        messages = {error[\\\"message\\\"] for error in payload[\\\"errors\\\"]}\\n        self.assertTrue(\\n            any(\\n                message.startswith(\\n                    \\\"evidence/manifest.json artifacts[0].path line 1 is not valid JSONL for restart_log:\\\"\\n                )\\n                for message in messages\\n            ),\\n            messages,\\n        )\\n\\n    def test_schema_sample_packages_are_linter_regression_inputs(self) -> None:\\n        valid_result = self.run_lint(SAMPLES_ROOT / \\\"valid\\\" / \\\"minimal-package\\\")\\n        self.assertEqual(valid_res