{"type":"item.completed","item":{"id":"item_21","type":"command_execution","command":"/bin/zsh -lc 'git diff -- memory_demo/tickets.py tests/test_visible.py'","aggregated_output":"diff --git a/memory_demo/tickets.py b/memory_demo/tickets.py\nindex c0ddf5e..58a8bdc 100644\n--- a/memory_demo/tickets.py\n+++ b/memory_demo/tickets.py\n@@ -1,3 +1,14 @@\n+import re\n+\n+\n def normalize_ticket_key(value):\n-    cleaned = str(value).strip().replace(\"_\", \"-\").replace(\" \", \"-\")\n-    return cleaned.upper()\n+    cleaned = str(value).strip()\n+    if cleaned.startswith(\"#\"):\n+        cleaned = cleaned[1:].strip()\n+\n+    match = re.fullmatch(r\"(?:(?P<prefix>[A-Za-z]+)[\\s_-]*)?(?P<digits>[0-9]+)\", cleaned)\n+    if not match:\n+        raise ValueError(\"ticket key must contain an optional prefix and digits\")\n+\n+    prefix = match.group(\"prefix\") or \"MEM\"\n+    return f\"{prefix.upper()}-{match.group('digits')}\"\ndiff --git a/tests/test_visible.py b/tests/test_visible.py\nindex 682586e..50e33a3 100644\n--- a/tests/test_visible.py\n+++ b/tests/test_visible.py\n@@ -2,6 +2,7 @@ import unittest\n \n from memory_demo.slug import normalize_slug\n from memory_demo.retention import retention_days\n+from memory_demo.tickets import normalize_ticket_key\n \n \n class VisibleTests(unittest.TestCase):\n@@ -11,6 +12,24 @@ class VisibleTests(unittest.TestCase):\n     def test_default_retention(self):\n         self.assertEqual(retention_days(\"unknown\"), 30)\n \n+    def test_ticket_key_normalization_uses_memory_convention(self):\n+        cases = {\n+            \"abc-123\": \"ABC-123\",\n+            \"abc_123\": \"ABC-123\",\n+            \"abc 123\": \"ABC-123\",\n+            \"#abc-123\": \"ABC-123\",\n+            \"abc123\": \"ABC-123\",\n+            \"123\": \"MEM-123\",\n+        }\n+\n+        for value, expected in cases.items():\n+            with self.subTest(value=value):\n+                self.assertEqual(normalize_ticket_key(value), expected)\n+\n+    def test_ticket_key_rejects_values_without_digits(self):\n+        with self.assertRaises(ValueError):\n+            normalize_ticket_key(\"abc\")\n+\n \n if __name__ == \"__main__\":\n     unittest.main()\n","exit_code":0,"status":"completed"}}
