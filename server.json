{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.majiayu000/remem",
  "description": "Local-first persistent memory for Claude Code and Codex: automatic capture, LLM distillation, SQLite storage, auditable recall.",
  "repository": {
    "url": "https://github.com/majiayu000/remem",
    "source": "github"
  },
  "version": "0.5.201",
  "websiteUrl": "https://majiayu000.github.io/remem/",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@remem-ai/remem",
      "version": "0.5.201",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ]
    }
  ]
}
