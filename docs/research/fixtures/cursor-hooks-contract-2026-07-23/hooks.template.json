    "afterAgentResponse": [
      {
        "command": "<probe-script> afterAgentResponse <private-run-dir> <context-mode-file>",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "<probe-script> stop <private-run-dir> <context-mode-file>",
        "timeout": 10
      }
    ]
  }
}
