      {
        "command": "<probe-script> subagentStart <private-run-dir> <context-mode-file>",
        "timeout": 10
      }
    ],
    "subagentStop": [
      {
        "command": "<probe-script> subagentStop <private-run-dir> <context-mode-file>",
        "timeout": 10
      }
