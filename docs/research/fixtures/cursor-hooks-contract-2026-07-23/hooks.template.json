{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "<probe-script> sessionStart <private-run-dir> <context-mode-file>",
        "timeout": 10
      }
    ],
    "sessionEnd": [
      {
        "command": "<probe-script> sessionEnd <private-run-dir> <context-mode-file>",
        "timeout": 10
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "<probe-script> beforeSubmitPrompt <private-run-dir> <context-mode-file>",
        "timeout": 10
      }
    ],
    "preToolUse": [
      {
        "command": "<probe-script> preToolUse <private-run-dir> <context-mode-file>",
        "timeout": 10
      }
    ],
    "postToolUse": [
      {
        "command": "<probe-script> postToolUse <private-run-dir> <context-mode-file>",
        "timeout": 10
      }
    ],
    "postToolUseFailure": [
      {
        "command": "<probe-script> postToolUseFailure <private-run-dir> <context-mode-file>",
        "timeout": 10
      }
    ],
    "beforeReadFile": [
      {
        "command": "<probe-script> beforeReadFile <private-run-dir> <context-mode-file>",
        "timeout": 10
      }
